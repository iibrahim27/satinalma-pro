<Window x:Class="SatinalmaYonetici.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Satınalma Yönetici — Platform"
        Height="780" Width="1180"
        MinHeight="680" MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="Segoe UI">

  <Grid>
    <!-- ==================== GİRİŞ ==================== -->
    <Grid x:Name="GirisPaneli">
      <Grid.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Color="#0A1F42" Offset="0" />
          <GradientStop Color="#0F2A5A" Offset="0.45" />
          <GradientStop Color="#1E3A8A" Offset="1" />
        </LinearGradientBrush>
      </Grid.Background>

      <!-- soft glow blobs -->
      <Ellipse Width="420" Height="420" HorizontalAlignment="Left" VerticalAlignment="Top"
               Margin="-120,-80,0,0" Opacity="0.18">
        <Ellipse.Fill>
          <RadialGradientBrush>
            <GradientStop Color="#6366F1" Offset="0" />
            <GradientStop Color="Transparent" Offset="1" />
          </RadialGradientBrush>
        </Ellipse.Fill>
      </Ellipse>
      <Ellipse Width="360" Height="360" HorizontalAlignment="Right" VerticalAlignment="Bottom"
               Margin="0,0,-100,-60" Opacity="0.15">
        <Ellipse.Fill>
          <RadialGradientBrush>
            <GradientStop Color="#22D3EE" Offset="0" />
            <GradientStop Color="Transparent" Offset="1" />
          </RadialGradientBrush>
        </Ellipse.Fill>
      </Ellipse>

      <Border MaxWidth="440" HorizontalAlignment="Center" VerticalAlignment="Center"
              Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
              CornerRadius="22" Padding="32,28" Margin="24">

        <StackPanel>
          <Border Width="56" Height="56" CornerRadius="16" HorizontalAlignment="Center"
                  Background="{StaticResource AccentGradientBrush}" Margin="0,0,0,14">
            <TextBlock Text="SP" Foreground="White" FontWeight="Bold" FontSize="18"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>

          <TextBlock Text="Satınalma Yönetici" FontSize="22" FontWeight="Bold"
                     Foreground="#0F172A" HorizontalAlignment="Center" />
          <TextBlock Text="Platform yönetim paneli — yalnızca platform sahibi için"
                     FontSize="12.5" Foreground="#64748B"
                     TextAlignment="Center" HorizontalAlignment="Center"
                     Margin="0,6,0,22" TextWrapping="Wrap" />

          <TextBlock Text="E-posta" Style="{StaticResource FieldLabelStyle}" />
          <TextBox x:Name="GirisEposta"
                   Foreground="#0F172A" Background="White" CaretBrush="#0F172A"
                   Height="40" Padding="12,8" FontSize="14"
                   BorderBrush="#CBD5E1" BorderThickness="1"
                   VerticalContentAlignment="Center"
                   Margin="0,0,0,12" KeyDown="GirisAlani_KeyDown" />

          <TextBlock Text="Şifre" Style="{StaticResource FieldLabelStyle}" />
          <PasswordBox x:Name="GirisSifre"
                       Foreground="#0F172A" Background="White" CaretBrush="#0F172A"
                       Height="40" Padding="12,8" FontSize="14"
                       BorderBrush="#CBD5E1" BorderThickness="1"
                       VerticalContentAlignment="Center"
                       Margin="0,0,0,18" KeyDown="GirisAlani_KeyDown" />

          <Button Content="Giriş Yap" Style="{StaticResource PrimaryButtonStyle}"
                  Height="46" Click="Giris_Click" Margin="0,0,0,10" />

          <Button Content="İlk kurulum: Beni platform admin yap"
                  Style="{StaticResource LinkButtonStyle}"
                  HorizontalAlignment="Center"
                  Click="Bootstrap_Click" />

          <TextBlock x:Name="GirisHata" Foreground="{StaticResource DangerBrush}"
                     FontSize="12" TextWrapping="Wrap" Margin="0,12,0,0"
                     TextAlignment="Center" Visibility="Collapsed" />

          <TextBlock x:Name="GirisSurum" Text="v1.0.0"
                     Foreground="#94A3B8" FontSize="11"
                     HorizontalAlignment="Center" Margin="0,16,0,0" />
        </StackPanel>
      </Border>
    </Grid>

    <!-- ==================== YÖNETİM ==================== -->
    <Grid x:Name="YonetimPanel" Visibility="Collapsed">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <!-- üst bar -->
      <Border Grid.Row="0" Background="{StaticResource HeroBackgroundBrush}" Padding="22,16">
        <DockPanel LastChildFill="True">
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
            <Button x:Name="BtnKurulum" Content="Platform admin yap" Style="{StaticResource GhostButtonStyle}"
                    Margin="0,0,8,0" Click="Bootstrap_Click" Visibility="Collapsed" />
            <Button Content="Firmalardan ayır" Style="{StaticResource GhostButtonStyle}"
                    Margin="0,0,8,0" Click="PlatformAyir_Click"
                    ToolTip="Platform hesabınızı tüm firmaların kullanıcı listelerinden çıkarır" />
            <Button Content="Çıkış" Style="{StaticResource GhostButtonStyle}"
                    Width="88" Click="Cikis_Click" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Border Width="40" Height="40" CornerRadius="12" Margin="0,0,12,0"
                    Background="{StaticResource AccentGradientBrush}">
              <TextBlock Text="SP" Foreground="White" FontWeight="Bold" FontSize="13"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="Satınalma Platform Yönetimi" Foreground="White"
                         FontSize="17" FontWeight="SemiBold" />
              <TextBlock Text="Firmalar · Kullanıcılar · Kiracı izolasyonu"
                         Foreground="#A5B4FC" FontSize="12" Margin="0,2,0,0" />
            </StackPanel>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- içerik -->
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,18,20,8">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="340" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="1.35*" MinWidth="420" />
          </Grid.ColumnDefinitions>

          <!-- Firmalar kartı -->
          <Border Grid.Column="0" Style="{StaticResource CardStyle}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="220" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <DockPanel Grid.Row="0" Margin="0,0,0,6">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                  <Button Content="Yenile" Style="{StaticResource SecondaryButtonStyle}"
                          Margin="0,0,8,0" Click="FirmalariYukle_Click" />
                  <Button Content="+ Yeni Firma" Style="{StaticResource PrimaryButtonStyle}"
                          Click="YeniFirma_Click" />
                </StackPanel>
                <TextBlock Text="Firmalar" Style="{StaticResource SectionTitleStyle}" />
              </DockPanel>

              <TextBlock Grid.Row="1" Style="{StaticResource HintTextStyle}"
                         Text="Her firma kendi verisini görür. Firma kodu yalnızca yönetim içindir; müşteri giriş ekranında görünmez." />

              <Border Grid.Row="2" CornerRadius="12" BorderBrush="{StaticResource LineBrush}"
                      BorderThickness="1" ClipToBounds="True" Margin="0,0,0,14">
                <DataGrid x:Name="FirmaGrid"
                          Style="{StaticResource AppDataGridStyle}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionChanged="FirmaGrid_SelectionChanged">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Kod" Binding="{Binding Kod}" Width="80" />
                    <DataGridTextColumn Header="Ad" Binding="{Binding Ad}" Width="*" />
                    <DataGridTextColumn Header="Lisans" Binding="{Binding LisansOzeti}" Width="150" />
                    <DataGridCheckBoxColumn Header="Aktif" Binding="{Binding Aktif}" Width="55" />
                  </DataGrid.Columns>
                </DataGrid>
              </Border>

              <Border Grid.Row="3" Background="#F8FAFC" BorderBrush="{StaticResource LineBrush}"
                      BorderThickness="1" CornerRadius="12" Padding="14"
                      TextElement.Foreground="{StaticResource InkBrush}">
                <StackPanel>
                  <TextBlock Text="Firma düzenle" FontWeight="SemiBold" FontSize="13.5"
                             Foreground="{StaticResource InkBrush}" Margin="0,0,0,10" />

                  <TextBlock Text="Firma kodu" Style="{StaticResource FieldLabelStyle}" />
                  <TextBox x:Name="FirmaKod" Foreground="#0F172A" Background="White" CaretBrush="#0F172A"
                           Height="40" Padding="12,8" FontSize="14" BorderBrush="#CBD5E1" BorderThickness="1"
                           VerticalContentAlignment="Center" Margin="0,0,0,10" />

                  <TextBlock Text="Firma adı" Style="{StaticResource FieldLabelStyle}" />
                  <TextBox x:Name="FirmaAd" Foreground="#0F172A" Background="White" CaretBrush="#0F172A"
                           Height="40" Padding="12,8" FontSize="14" BorderBrush="#CBD5E1" BorderThickness="1"
                           VerticalContentAlignment="Center" Margin="0,0,0,10" />

                  <TextBlock Text="Lisans tipi" Style="{StaticResource FieldLabelStyle}" />
                  <ComboBox x:Name="FirmaLisansTipi" Foreground="#0F172A" Background="White"
                            Height="40" Padding="10,6" FontSize="14" BorderBrush="#CBD5E1" BorderThickness="1"
                            VerticalContentAlignment="Center" Margin="0,0,0,10">
                    <ComboBoxItem Tag="deneme" Content="30 günlük deneme" IsSelected="True" />
                    <ComboBoxItem Tag="yillik" Content="Yıllık lisans (365 gün)" />
                  </ComboBox>

                  <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="10" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                      <TextBlock Text="Lisans başlangıç" Style="{StaticResource FieldLabelStyle}" />
                      <DatePicker x:Name="FirmaLisansBaslangic" Height="40" FontSize="14"
                                  BorderBrush="#CBD5E1" Margin="0,0,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                      <TextBlock Text="Lisans bitiş" Style="{StaticResource FieldLabelStyle}" />
                      <DatePicker x:Name="FirmaLisansBitis" Height="40" FontSize="14"
                                  BorderBrush="#CBD5E1" Margin="0,0,0,0" />
                    </StackPanel>
                  </Grid>

                  <TextBlock x:Name="FirmaLisansDurum" Style="{StaticResource HintTextStyle}"
                             Text="Yeni firmaya otomatik 30 gün deneme verilir. Tarihleri elle de ayarlayabilirsiniz." Margin="0,0,0,10" />

                  <CheckBox x:Name="FirmaAktif" Content="Aktif" IsChecked="True" Margin="0,0,0,12" />
                  <StackPanel Orientation="Horizontal">
                    <Button Content="Firmayı Kaydet" Style="{StaticResource PrimaryButtonStyle}"
                            MinWidth="140" Click="FirmaKaydet_Click" Margin="0,0,8,0" />
                    <Button Content="Lisansı yenile" Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="120" Click="LisansYenile_Click" Margin="0,0,8,0"
                            ToolTip="Bugünden itibaren deneme=30 gün veya yıllık=365 gün yeniden başlatır" />
                    <Button Content="Firmayı Sil" Style="{StaticResource DangerButtonStyle}"
                            MinWidth="110" Click="FirmaSil_Click"
                            ToolTip="Firmayı ve tüm verisini kalıcı olarak siler (geri alınamaz)" />
                  </StackPanel>
                </StackPanel>
              </Border>
            </Grid>
          </Border>

          <!-- Kullanıcılar kartı -->
          <Border Grid.Column="2" Style="{StaticResource CardStyle}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="220" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <DockPanel Grid.Row="0" Margin="0,0,0,6">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                  <Button Content="Eski kullanıcıları aktar" Style="{StaticResource SecondaryButtonStyle}"
                          Margin="0,0,8,0" Click="LegacyAktar_Click"
                          ToolTip="Eski /users koleksiyonundaki aktif hesapları bu firmaya taşır" />
                  <Button Content="+ Yeni Kullanıcı"
                          Style="{StaticResource PrimaryButtonStyle}"
                          Click="YeniKullanici_Click" />
                </StackPanel>
                <TextBlock x:Name="KullaniciBaslik"
                           Text="Kullanıcılar"
                           Style="{StaticResource SectionTitleStyle}" />
              </DockPanel>

              <TextBlock Grid.Row="1" Style="{StaticResource HintTextStyle}"
                         Text="Platform sahibi yalnızca e-posta ile Yönetici uygulamasına girer; firmaya kullanıcı olarak eklenmez. Firma kullanıcılarına ayrı kullanıcı adı verin." />

              <Border Grid.Row="2" CornerRadius="12" BorderBrush="{StaticResource LineBrush}"
                      BorderThickness="1" ClipToBounds="True" Margin="0,0,0,14">
                <DataGrid x:Name="KullaniciGrid"
                          Style="{StaticResource AppDataGridStyle}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionChanged="KullaniciGrid_SelectionChanged">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Kullanıcı adı" Binding="{Binding KullaniciAdi}" Width="130" />
                    <DataGridTextColumn Header="Ad Soyad" Binding="{Binding AdSoyad}" Width="*" />
                    <DataGridTextColumn Header="Rol" Binding="{Binding Rol}" Width="100" />
                    <DataGridCheckBoxColumn Header="Aktif" Binding="{Binding Aktif}" Width="60" />
                  </DataGrid.Columns>
                </DataGrid>
              </Border>

              <Border Grid.Row="3" Background="#F8FAFC" BorderBrush="{StaticResource LineBrush}"
                      BorderThickness="1" CornerRadius="12" Padding="14"
                      TextElement.Foreground="{StaticResource InkBrush}">
                <StackPanel>
                  <TextBlock Text="Kullanıcı düzenle" FontWeight="SemiBold" FontSize="13.5"
                             Foreground="{StaticResource InkBrush}" Margin="0,0,0,10" />

                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="12" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                      <TextBlock Text="Kullanıcı adı" Style="{StaticResource FieldLabelStyle}" />
                      <TextBox x:Name="KullaniciAdi" Foreground="#0F172A" Background="White" CaretBrush="#0F172A"
                               Height="40" Padding="12,8" FontSize="14" BorderBrush="#CBD5E1" BorderThickness="1"
                               VerticalContentAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,10">
                      <TextBlock Text="E-posta (şifre sıfırlama)" Style="{StaticResource FieldLabelStyle}" />
                      <TextBox x:Name="KullaniciEposta" Foreground="#0F172A" Background="White" CaretBrush="#0F172A"
                               Height="40" Padding="12,8" FontSize="14" BorderBrush="#CBD5E1" BorderThickness="1"
                               VerticalContentAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
                      <TextBlock Text="Ad Soyad" Style="{StaticResource FieldLabelStyle}" />
                      <TextBox x:Name="KullaniciAdSoyad" Foreground="#0F172A" Background="White" CaretBrush="#0F172A"
                               Height="40" Padding="12,8" FontSize="14" BorderBrush="#CBD5E1" BorderThickness="1"
                               VerticalContentAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,10">
                      <TextBlock Text="Rol" Style="{StaticResource FieldLabelStyle}" />
                      <ComboBox x:Name="RolKutusu" Foreground="#0F172A" Background="White"
                                Height="40" Padding="10,6" FontSize="14" BorderBrush="#CBD5E1" BorderThickness="1"
                                VerticalContentAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,10">
                      <TextBlock Text="Saha (opsiyonel)" Style="{StaticResource FieldLabelStyle}" />
                      <TextBox x:Name="KullaniciSaha" Foreground="#0F172A" Background="White" CaretBrush="#0F172A"
                               Height="40" Padding="12,8" FontSize="14" BorderBrush="#CBD5E1" BorderThickness="1"
                               VerticalContentAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,10">
                      <TextBlock Text="Şifre (yeni kullanıcıda zorunlu)" Style="{StaticResource FieldLabelStyle}" />
                      <PasswordBox x:Name="KullaniciSifre" Foreground="#0F172A" Background="White" CaretBrush="#0F172A"
                                   Height="40" Padding="12,8" FontSize="14" BorderBrush="#CBD5E1" BorderThickness="1"
                                   VerticalContentAlignment="Center" />
                    </StackPanel>

                    <CheckBox Grid.Row="3" Grid.Column="0" x:Name="KullaniciAktif"
                              Content="Aktif" IsChecked="True" VerticalAlignment="Center" />
                    <StackPanel Grid.Row="3" Grid.Column="2" Orientation="Horizontal"
                                HorizontalAlignment="Right">
                      <Button Content="Kullanıcıyı Sil" Style="{StaticResource DangerButtonStyle}"
                              MinWidth="130" Margin="0,0,8,0" Click="KullaniciSil_Click"
                              ToolTip="Seçili kullanıcıyı kalıcı olarak siler" />
                      <Button Content="Kullanıcıyı Kaydet"
                              Style="{StaticResource PrimaryButtonStyle}"
                              MinWidth="160" Click="KullaniciKaydet_Click" />
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Border>
            </Grid>
          </Border>
        </Grid>
      </ScrollViewer>

      <!-- durum çubuğu -->
      <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource LineBrush}"
              BorderThickness="0,1,0,0" Padding="20,10">
        <DockPanel>
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
            <Button Content="Güncelleme kontrol" Style="{StaticResource LinkButtonStyle}"
                    Margin="0,0,12,0" Click="GuncellemeKontrol_Click"
                    ToolTip="Yeni sürüm varsa indirip uygulamayı günceller" />
            <TextBlock x:Name="AltSurumMetni" Text="v1.0.0"
                       Foreground="{StaticResource InkMutedBrush}" FontSize="11"
                       VerticalAlignment="Center" />
          </StackPanel>
          <TextBlock x:Name="DurumMetni" Text="Hazır"
                     Foreground="{StaticResource InkMutedBrush}" FontSize="12"
                     VerticalAlignment="Center" />
        </DockPanel>
      </Border>
    </Grid>
  </Grid>
</Window>
