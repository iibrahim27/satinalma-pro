<Window x:Class="SatinalmaPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:dash="clr-namespace:SatinalmaPro.Controls.Dashboard"
        xmlns:helpers="clr-namespace:SatinalmaPro.Helpers"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Satınalma Pro"
        Icon="Assets/app.ico"
        Height="900"
        Width="1600"
        MinHeight="720"
        MinWidth="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource DashBackgroundBrush}"
        FontFamily="Segoe UI"
        Focusable="True">

  <Grid Background="{StaticResource DashBackgroundBrush}">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="280" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0"
            BorderBrush="{StaticResource DashBorderBrush}"
            BorderThickness="0,0,1,0">
      <dash:AppSidebarView x:Name="Sidebar" />
    </Border>

    <Grid Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Background="{StaticResource DashBackgroundBrush}" Padding="32,28,32,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <dash:DashboardHeaderView x:Name="Header" />

          <Border x:Name="ModulBaslikPanel" Grid.Row="1" Margin="0,0,0,16"
                  Visibility="Collapsed" Style="{StaticResource DashCardBorderStyle}" Padding="16,14">
            <StackPanel Orientation="Horizontal">
              <Button Style="{StaticResource DashGhostButtonStyle}" Padding="10,8" Click="Home_Click"
                      ToolTip="Ana Sayfaya dön (Esc)">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                             Foreground="{StaticResource DashTextSecondaryBrush}" Margin="0,0,8,0" />
                  <TextBlock Text="Ana Sayfa" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Rectangle Width="1" Margin="14,4" Fill="{StaticResource DashBorderBrush}" />
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                <Border x:Name="ModulIkonZemin" Width="40" Height="40" CornerRadius="12"
                        Background="{StaticResource DashNavActiveBrush}">
                  <TextBlock x:Name="TxtModulIkon" FontFamily="Segoe MDL2 Assets" FontSize="16"
                             Foreground="{StaticResource DashPrimaryBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                  <TextBlock x:Name="TxtModulBaslik" FontSize="18" FontWeight="SemiBold"
                             Foreground="{StaticResource DashTextBrush}" />
                  <TextBlock x:Name="TxtModulAltBaslik" FontSize="12"
                             Foreground="{StaticResource DashTextSecondaryBrush}" Margin="0,2,0,0" />
                </StackPanel>
              </StackPanel>
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <Border Grid.Row="1" Padding="32,0,32,0" Background="{StaticResource DashBackgroundBrush}">
        <ContentControl x:Name="MainRegion" helpers:ScrollWheelHelper.IsEnabled="True" />
      </Border>

      <Border Grid.Row="2" Padding="32,8,32,14" Background="{StaticResource DashBackgroundBrush}">
        <Grid>
          <TextBlock x:Name="TxtAltBilgi" FontSize="11" Foreground="{StaticResource DashTextSecondaryBrush}"
                     HorizontalAlignment="Left" VerticalAlignment="Center" Opacity="0.85" />
          <Button x:Name="BtnYonetimTeklifOnay" Style="{StaticResource DashGhostButtonStyle}"
                  Visibility="Collapsed" Padding="10,6" HorizontalAlignment="Right"
                  Click="YonetimTeklifOnay_Click" ToolTip="Mobil onay bekleyen teklifler">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="Teklif Onay" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
