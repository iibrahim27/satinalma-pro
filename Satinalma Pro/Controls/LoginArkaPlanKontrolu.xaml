<UserControl x:Class="SatinalmaPro.Controls.LoginArkaPlanKontrolu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ClipToBounds="True">
  <UserControl.Resources>
    <Storyboard x:Key="ParcacikAnimasyonu" RepeatBehavior="Forever">
      <DoubleAnimation Storyboard.TargetName="P1" Storyboard.TargetProperty="(Canvas.Top)"
                       From="40" To="520" Duration="0:0:14" AutoReverse="True" />
      <DoubleAnimation Storyboard.TargetName="P2" Storyboard.TargetProperty="(Canvas.Top)"
                       From="120" To="460" Duration="0:0:18" AutoReverse="True" />
      <DoubleAnimation Storyboard.TargetName="P3" Storyboard.TargetProperty="(Canvas.Top)"
                       From="220" To="560" Duration="0:0:16" AutoReverse="True" />
      <DoubleAnimation Storyboard.TargetName="Cizgi1" Storyboard.TargetProperty="Opacity"
                       From="0.08" To="0.22" Duration="0:0:5" AutoReverse="True" />
      <DoubleAnimation Storyboard.TargetName="Cizgi2" Storyboard.TargetProperty="Opacity"
                       From="0.06" To="0.18" Duration="0:0:7" AutoReverse="True" />
    </Storyboard>
  </UserControl.Resources>
  <UserControl.Triggers>
    <EventTrigger RoutedEvent="Loaded">
      <BeginStoryboard Storyboard="{StaticResource ParcacikAnimasyonu}" />
    </EventTrigger>
  </UserControl.Triggers>

  <Grid>
    <Grid.Background>
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0A1F42" Offset="0" />
        <GradientStop Color="#0F2A5A" Offset="0.55" />
        <GradientStop Color="#1E4A8C" Offset="1" />
      </LinearGradientBrush>
    </Grid.Background>

    <Canvas>
      <Line x:Name="Cizgi1" X1="0" Y1="120" X2="800" Y2="180" Stroke="#4F46E5" StrokeThickness="1" Opacity="0.12" />
      <Line x:Name="Cizgi2" X1="0" Y1="280" X2="800" Y2="340" Stroke="#6D5BFF" StrokeThickness="1" Opacity="0.10" />
      <Ellipse x:Name="P1" Canvas.Left="80" Canvas.Top="40" Width="8" Height="8" Fill="#6D5BFF" Opacity="0.35" />
      <Ellipse Canvas.Left="220" Canvas.Top="180" Width="6" Height="6" Fill="#4F46E5" Opacity="0.28" />
      <Ellipse x:Name="P2" Canvas.Left="360" Canvas.Top="120" Width="10" Height="10" Fill="#6D5BFF" Opacity="0.30" />
      <Ellipse Canvas.Left="140" Canvas.Top="320" Width="5" Height="5" Fill="#FFFFFF" Opacity="0.18" />
      <Ellipse x:Name="P3" Canvas.Left="480" Canvas.Top="220" Width="7" Height="7" Fill="#4F46E5" Opacity="0.32" />
      <Ellipse Canvas.Left="560" Canvas.Top="80" Width="4" Height="4" Fill="#FFFFFF" Opacity="0.20" />
    </Canvas>
  </Grid>
</UserControl>
