<UserControl x:Class="SatinalmaPro.Controls.UygulamaIkonAnimasyonu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Width="{Binding IkonBoyutu, ElementName=Root}"
             Height="{Binding IkonBoyutu, ElementName=Root}">
  <UserControl.Resources>
    <Storyboard x:Key="IkonNefesAnimasyonu" RepeatBehavior="Forever">
      <DoubleAnimation Storyboard.TargetName="IkonOlcek"
                       Storyboard.TargetProperty="ScaleX"
                       From="0.92" To="1.06" Duration="0:0:1.15"
                       AutoReverse="True">
        <DoubleAnimation.EasingFunction>
          <SineEase EasingMode="EaseInOut" />
        </DoubleAnimation.EasingFunction>
      </DoubleAnimation>
      <DoubleAnimation Storyboard.TargetName="IkonOlcek"
                       Storyboard.TargetProperty="ScaleY"
                       From="0.92" To="1.06" Duration="0:0:1.15"
                       AutoReverse="True">
        <DoubleAnimation.EasingFunction>
          <SineEase EasingMode="EaseInOut" />
        </DoubleAnimation.EasingFunction>
      </DoubleAnimation>
      <DoubleAnimation Storyboard.TargetName="Hale"
                       Storyboard.TargetProperty="Opacity"
                       From="0.18" To="0.42" Duration="0:0:1.15"
                       AutoReverse="True" />
      <DoubleAnimation Storyboard.TargetName="HaleOlcek"
                       Storyboard.TargetProperty="ScaleX"
                       From="0.95" To="1.12" Duration="0:0:1.15"
                       AutoReverse="True" />
      <DoubleAnimation Storyboard.TargetName="HaleOlcek"
                       Storyboard.TargetProperty="ScaleY"
                       From="0.95" To="1.12" Duration="0:0:1.15"
                       AutoReverse="True" />
    </Storyboard>
  </UserControl.Resources>
  <UserControl.Triggers>
    <EventTrigger RoutedEvent="Loaded">
      <BeginStoryboard Storyboard="{StaticResource IkonNefesAnimasyonu}" />
    </EventTrigger>
  </UserControl.Triggers>

  <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
    <Ellipse x:Name="Hale" Fill="{StaticResource DashPrimaryBrush}" Opacity="0.25"
             Width="{Binding IkonBoyutu, ElementName=Root}"
             Height="{Binding IkonBoyutu, ElementName=Root}"
             RenderTransformOrigin="0.5,0.5">
      <Ellipse.RenderTransform>
        <ScaleTransform x:Name="HaleOlcek" ScaleX="1" ScaleY="1" />
      </Ellipse.RenderTransform>
    </Ellipse>
    <Border RenderTransformOrigin="0.5,0.5" CornerRadius="18">
      <Border.RenderTransform>
        <ScaleTransform x:Name="IkonOlcek" ScaleX="1" ScaleY="1" />
      </Border.RenderTransform>
      <Image Source="pack://application:,,,/Assets/app.ico"
             Width="{Binding IkonBoyutu, ElementName=Root}"
             Height="{Binding IkonBoyutu, ElementName=Root}"
             Stretch="Uniform" />
    </Border>
  </Grid>
</UserControl>
