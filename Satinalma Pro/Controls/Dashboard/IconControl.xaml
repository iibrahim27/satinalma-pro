<UserControl x:Class="SatinalmaPro.Controls.Dashboard.IconControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
  <Viewbox Width="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
           Height="{Binding IconSize, RelativeSource={RelativeSource AncestorType=UserControl}}">
    <Grid x:Name="IconHost" Width="24" Height="24" />
  </Viewbox>
</UserControl>
