<UserControl x:Class="SatinalmaPro.Controls.Dashboard.ErpOpenRecordsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Style="{StaticResource DashCardBorderStyle}" Padding="0" MinHeight="320">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <TextBlock Text="Açık Talepler" FontSize="15" FontWeight="SemiBold"
                 Foreground="{StaticResource DashTextBrush}" Margin="20,18,20,12" />
      <Border Grid.Row="1" Style="{StaticResource DashModernGridHeaderStyle}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*" />
            <ColumnDefinition Width="0.9*" />
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="0.9*" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="0.8*" />
          </Grid.ColumnDefinitions>
          <TextBlock Text="Talep No" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource DashTextSecondaryBrush}" />
          <TextBlock Grid.Column="1" Text="Tarih" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource DashTextSecondaryBrush}" />
          <TextBlock Grid.Column="2" Text="Talep Eden" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource DashTextSecondaryBrush}" />
          <TextBlock Grid.Column="3" Text="Vade" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource DashTextSecondaryBrush}" />
          <TextBlock Grid.Column="4" Text="Tutar" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource DashTextSecondaryBrush}" />
          <TextBlock Grid.Column="5" Text="Kalan" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource DashTextSecondaryBrush}" />
          <TextBlock Grid.Column="6" Text="Durum" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource DashTextSecondaryBrush}" />
        </Grid>
      </Border>
      <ItemsControl x:Name="Liste" Grid.Row="2" Margin="0">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Padding="20,12" BorderBrush="{StaticResource DashBorderBrush}" BorderThickness="0,0,0,1"
                    Background="White">
              <Border.Style>
                <Style TargetType="Border">
                  <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter Property="Background" Value="#F8FAFC" />
                    </Trigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="1.1*" />
                  <ColumnDefinition Width="0.9*" />
                  <ColumnDefinition Width="1.2*" />
                  <ColumnDefinition Width="0.9*" />
                  <ColumnDefinition Width="1*" />
                  <ColumnDefinition Width="1*" />
                  <ColumnDefinition Width="0.8*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding No}" FontSize="12" Foreground="{StaticResource DashTextBrush}" />
                <TextBlock Grid.Column="1" Text="{Binding Tarih}" FontSize="12" Foreground="{StaticResource DashTextSecondaryBrush}" />
                <TextBlock Grid.Column="2" Text="{Binding Cari}" FontSize="12" Foreground="{StaticResource DashTextBrush}" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="3" Text="{Binding Vade}" FontSize="12" Foreground="{StaticResource DashTextSecondaryBrush}" />
                <TextBlock Grid.Column="4" Text="{Binding Tutar}" FontSize="12" Foreground="{StaticResource DashTextBrush}" />
                <TextBlock Grid.Column="5" Text="{Binding Kalan}" FontSize="12" Foreground="{StaticResource DashTextBrush}" />
                <Border Grid.Column="6" Style="{StaticResource DashBadgeStyle}" HorizontalAlignment="Left"
                        Background="{Binding DurumArkaplan}">
                  <TextBlock Text="{Binding Durum}" FontSize="10" FontWeight="SemiBold" Foreground="{Binding DurumOnplan}" />
                </Border>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <TextBlock x:Name="TxtAltBilgi" Grid.Row="3" Margin="20,10,20,14" FontSize="11"
                 Foreground="{StaticResource DashTextSecondaryBrush}" />
    </Grid>
  </Border>
</UserControl>
