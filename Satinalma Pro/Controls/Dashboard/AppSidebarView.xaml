<UserControl x:Class="SatinalmaPro.Controls.Dashboard.AppSidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dash="clr-namespace:SatinalmaPro.Controls.Dashboard"
             Width="280"
             Background="White">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Padding="24,28,24,20" BorderBrush="{StaticResource DashBorderBrush}" BorderThickness="0,0,0,1">
      <Image x:Name="ImgLogo" MaxHeight="56" Stretch="Uniform" HorizontalAlignment="Left" />
    </Border>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12,16,12,12">
      <StackPanel x:Name="NavPanel" />
    </ScrollViewer>

    <Border Grid.Row="2" Padding="16,14" BorderBrush="{StaticResource DashBorderBrush}" BorderThickness="0,1,0,0">
      <Button x:Name="BtnProfil" Style="{StaticResource DashGhostButtonStyle}" Padding="10,10"
              HorizontalContentAlignment="Stretch" Click="BtnProfil_Click">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <Border Width="40" Height="40" CornerRadius="20" Background="{StaticResource DashPrimaryBrush}">
            <TextBlock x:Name="TxtAvatar" Text="İP" Foreground="White" FontWeight="SemiBold"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>

          <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
            <TextBlock x:Name="TxtKullaniciAd" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource DashTextBrush}" TextTrimming="CharacterEllipsis" />
            <TextBlock x:Name="TxtKullaniciRol" FontSize="12"
                       Foreground="{StaticResource DashTextSecondaryBrush}" />
          </StackPanel>

          <dash:IconControl Grid.Column="2" Kind="ChevronDown" IconSize="16"
                            StrokeBrush="{StaticResource DashTextSecondaryBrush}"
                            VerticalAlignment="Center" />
        </Grid>
      </Button>
    </Border>
  </Grid>
</UserControl>
