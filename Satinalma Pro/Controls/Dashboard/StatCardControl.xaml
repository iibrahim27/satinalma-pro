<UserControl x:Class="SatinalmaPro.Controls.Dashboard.StatCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dash="clr-namespace:SatinalmaPro.Controls.Dashboard"
             MinHeight="132">
  <Border Style="{StaticResource DashCardBorderStyle}" Padding="18,16,18,12">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Border x:Name="IconZemin" Width="40" Height="40" CornerRadius="10" VerticalAlignment="Top">
          <dash:IconControl x:Name="Icon" IconSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <Button Grid.Column="2" Style="{StaticResource DashGhostButtonStyle}" Padding="4,2" BorderThickness="0"
                Background="Transparent" VerticalAlignment="Top" IsEnabled="False" Opacity="0.5">
          <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                     Foreground="{StaticResource DashTextSecondaryBrush}" />
        </Button>
      </Grid>

      <StackPanel Grid.Row="1" Margin="0,12,0,8">
        <TextBlock x:Name="TxtBaslik" FontSize="12" Foreground="{StaticResource DashTextSecondaryBrush}" />
        <TextBlock x:Name="TxtDeger" FontSize="24" FontWeight="Bold"
                   Foreground="{StaticResource DashTextBrush}" Margin="0,4,0,0" />
        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
          <TextBlock x:Name="TxtTrend" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
          <TextBlock x:Name="TxtAlt" FontSize="11" Foreground="{StaticResource DashTextSecondaryBrush}"
                     Margin="8,0,0,0" VerticalAlignment="Center" />
        </StackPanel>
      </StackPanel>

      <dash:ErpSparklineControl x:Name="Sparkline" Grid.Row="2" Height="32" />
    </Grid>
  </Border>
</UserControl>
