<UserControl x:Class="SatinalmaPro.Controls.Dashboard.StatCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dash="clr-namespace:SatinalmaPro.Controls.Dashboard"
             Height="120">
  <Border Style="{StaticResource DashCardBorderStyle}" Padding="20,16">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <Border x:Name="IconZemin" Width="44" Height="44" CornerRadius="22" VerticalAlignment="Center">
        <dash:IconControl x:Name="Icon" IconSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
      </Border>

      <StackPanel Grid.Column="1" Margin="16,0,12,0" VerticalAlignment="Center">
        <TextBlock x:Name="TxtBaslik" FontSize="13" Foreground="{StaticResource DashTextSecondaryBrush}" />
        <TextBlock x:Name="TxtDeger" FontSize="26" FontWeight="SemiBold"
                   Foreground="{StaticResource DashTextBrush}" Margin="0,4,0,0" />
        <TextBlock x:Name="TxtAlt" FontSize="12" Foreground="{StaticResource DashTextSecondaryBrush}" Margin="0,2,0,0" />
      </StackPanel>

      <TextBlock x:Name="TxtTrend" Grid.Column="2" VerticalAlignment="Bottom"
                 FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4" />
    </Grid>
  </Border>
</UserControl>
