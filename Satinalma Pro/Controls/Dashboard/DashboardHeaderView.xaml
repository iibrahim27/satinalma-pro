<UserControl x:Class="SatinalmaPro.Controls.Dashboard.DashboardHeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dash="clr-namespace:SatinalmaPro.Controls.Dashboard">
  <Grid Margin="0,0,0,28">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="Auto" />
    </Grid.ColumnDefinitions>

    <StackPanel VerticalAlignment="Center">
      <TextBlock x:Name="TxtKarsilama" FontSize="28" FontWeight="SemiBold"
                 Foreground="{StaticResource DashTextBrush}" />
      <TextBlock Text="Satınalma süreçlerinizi kolayca yönetin."
                 FontSize="14" Foreground="{StaticResource DashTextSecondaryBrush}" Margin="0,6,0,0" />
    </StackPanel>

    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
      <Button x:Name="BtnBildirim" Style="{StaticResource DashGhostButtonStyle}" Margin="0,0,10,0"
              Click="BtnBildirim_Click" ToolTip="Bildirimler">
        <Grid>
          <dash:IconControl Kind="Bell" IconSize="18" StrokeBrush="{StaticResource DashTextBrush}" />
          <Border x:Name="BadgeBildirim" Background="{StaticResource DashPrimaryBrush}"
                  CornerRadius="8" MinWidth="18" Height="18"
                  HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12,-6,-6,0"
                  Visibility="Collapsed">
            <TextBlock x:Name="TxtBadgeSayi" Foreground="White" FontSize="10" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0" />
          </Border>
        </Grid>
      </Button>

      <Button x:Name="BtnTema" Style="{StaticResource DashGhostButtonStyle}" Margin="0,0,10,0"
              Padding="12,10" Click="BtnTema_Click" ToolTip="Gece / Gündüz">
        <dash:IconControl x:Name="TemaIkon" Kind="Moon" IconSize="18"
                          StrokeBrush="{StaticResource DashTextBrush}" />
      </Button>

      <Button x:Name="BtnHizliIslem" Style="{StaticResource DashPrimaryButtonStyle}"
              Click="BtnHizliIslem_Click">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="+" FontSize="16" FontWeight="Bold" Margin="0,0,8,0" />
          <TextBlock Text="Hızlı İşlem" VerticalAlignment="Center" />
          <dash:IconControl Kind="ChevronDown" IconSize="14" StrokeBrush="White"
                            Margin="10,0,0,0" VerticalAlignment="Center" />
        </StackPanel>
      </Button>
    </StackPanel>
  </Grid>
</UserControl>
