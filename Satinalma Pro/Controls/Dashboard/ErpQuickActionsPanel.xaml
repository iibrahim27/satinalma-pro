<UserControl x:Class="SatinalmaPro.Controls.Dashboard.ErpQuickActionsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dash="clr-namespace:SatinalmaPro.Controls.Dashboard">
  <Border Style="{StaticResource DashCardBorderStyle}" Padding="20,18" MinHeight="280">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <TextBlock Text="Hızlı İşlemler" FontSize="15" FontWeight="SemiBold"
                 Foreground="{StaticResource DashTextBrush}" Margin="0,0,0,14" />
      <UniformGrid Grid.Row="1" Rows="3" Columns="2">
        <Button Style="{StaticResource DashQuickActionButtonStyle}" Margin="0,0,8,8" Tag="Satınalma" Click="HizliIslem_Click">
          <StackPanel>
            <dash:IconControl Kind="ShoppingCart" IconSize="20" StrokeBrush="{StaticResource DashPrimaryBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="Yeni Talep" FontSize="12" Margin="0,8,0,0" HorizontalAlignment="Center" Foreground="{StaticResource DashTextBrush}" />
          </StackPanel>
        </Button>
        <Button Style="{StaticResource DashQuickActionButtonStyle}" Margin="8,0,0,8" Tag="Satınalma" Click="HizliIslem_Click">
          <StackPanel>
            <dash:IconControl Kind="ClipboardList" IconSize="20" StrokeBrush="{StaticResource DashPrimaryBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="Teklif Girişi" FontSize="12" Margin="0,8,0,0" HorizontalAlignment="Center" />
          </StackPanel>
        </Button>
        <Button Style="{StaticResource DashQuickActionButtonStyle}" Margin="0,0,8,8" Tag="Alınan Malzemeler" Click="HizliIslem_Click">
          <StackPanel>
            <dash:IconControl Kind="Package" IconSize="20" StrokeBrush="{StaticResource DashPrimaryBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="Malzeme Kaydı" FontSize="12" Margin="0,8,0,0" HorizontalAlignment="Center" />
          </StackPanel>
        </Button>
        <Button Style="{StaticResource DashQuickActionButtonStyle}" Margin="8,0,0,8" Tag="Finansman Raporlama" Click="HizliIslem_Click">
          <StackPanel>
            <dash:IconControl Kind="Wallet" IconSize="20" StrokeBrush="{StaticResource DashPrimaryBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="Tahsilat Girişi" FontSize="12" Margin="0,8,0,0" HorizontalAlignment="Center" />
          </StackPanel>
        </Button>
        <Button Style="{StaticResource DashQuickActionButtonStyle}" Margin="0,0,8,0" Tag="Stok Yönetimi" Click="HizliIslem_Click">
          <StackPanel>
            <dash:IconControl Kind="Warehouse" IconSize="20" StrokeBrush="{StaticResource DashPrimaryBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="Stok Kartı" FontSize="12" Margin="0,8,0,0" HorizontalAlignment="Center" />
          </StackPanel>
        </Button>
        <Button Style="{StaticResource DashQuickActionButtonStyle}" Margin="8,0,0,0" Tag="Raporlamalar" Click="HizliIslem_Click">
          <StackPanel>
            <dash:IconControl Kind="FileBarChart" IconSize="20" StrokeBrush="{StaticResource DashPrimaryBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="Raporlar" FontSize="12" Margin="0,8,0,0" HorizontalAlignment="Center" />
          </StackPanel>
        </Button>
      </UniformGrid>
    </Grid>
  </Border>
</UserControl>
