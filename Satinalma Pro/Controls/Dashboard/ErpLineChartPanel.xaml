<UserControl x:Class="SatinalmaPro.Controls.Dashboard.ErpLineChartPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Style="{StaticResource DashCardBorderStyle}" Padding="20,18" MinHeight="280">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <Grid Margin="0,0,0,12">
        <TextBlock Text="Aylık Harcama Grafiği" FontSize="15" FontWeight="SemiBold"
                   Foreground="{StaticResource DashTextBrush}" />
        <TextBlock x:Name="TxtYil" HorizontalAlignment="Right" VerticalAlignment="Center"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{StaticResource DashTextSecondaryBrush}" Text="—" />
      </Grid>
      <Canvas x:Name="ChartCanvas" Grid.Row="1" ClipToBounds="True" />
    </Grid>
  </Border>
</UserControl>
