<UserControl x:Class="SatinalmaPro.Controls.Dashboard.ErpRightWidgetsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel>
    <Border Style="{StaticResource DashCardBorderStyle}" Padding="18,16" Margin="0,0,0,16">
      <StackPanel>
        <TextBlock Text="Hatırlatmalar" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource DashTextBrush}" Margin="0,0,0,12" />
        <ItemsControl x:Name="HatirlatmaListe">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Ellipse Width="8" Height="8" Fill="{Binding Renk}" VerticalAlignment="Top" Margin="0,5,10,0" />
                <TextBlock Text="{Binding Metin}" FontSize="12" Foreground="{StaticResource DashTextBrush}" TextWrapping="Wrap" />
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </Border>

    <Border Style="{StaticResource DashCardBorderStyle}" Padding="18,16" Margin="0,0,0,16">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock Text="Finansal Özet" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource DashTextBrush}" Margin="0,0,0,12" />
          <TextBlock x:Name="TxtGelir" FontSize="12" Margin="0,0,0,6" />
          <TextBlock x:Name="TxtGider" FontSize="12" Margin="0,0,0,6" />
          <TextBlock x:Name="TxtKar" FontSize="12" FontWeight="SemiBold" />
        </StackPanel>
        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
          <Border Width="72" Height="72" CornerRadius="36" BorderBrush="{StaticResource DashPrimaryBrush}" BorderThickness="6">
            <TextBlock x:Name="TxtMarj" FontSize="11" FontWeight="Bold" Foreground="{StaticResource DashPrimaryBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" />
          </Border>
        </StackPanel>
      </Grid>
    </Border>

    <Border Style="{StaticResource DashCardBorderStyle}" Padding="18,16">
      <StackPanel>
        <TextBlock Text="En Çok Alınan Malzemeler" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource DashTextBrush}" Margin="0,0,0,12" />
        <ItemsControl x:Name="TopUrunListe">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Ad}" FontSize="12" Foreground="{StaticResource DashTextBrush}" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1" Text="{Binding Tutar}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource DashTextBrush}" />
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
