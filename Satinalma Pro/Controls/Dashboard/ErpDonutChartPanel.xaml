<UserControl x:Class="SatinalmaPro.Controls.Dashboard.ErpDonutChartPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Style="{StaticResource DashCardBorderStyle}" Padding="20,18" MinHeight="280">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <TextBlock Text="Harcama Dağılımı" FontSize="15" FontWeight="SemiBold"
                 Foreground="{StaticResource DashTextBrush}" Margin="0,0,0,12" />
      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Viewbox Grid.Column="0" MaxHeight="160" HorizontalAlignment="Center">
          <Canvas x:Name="DonutCanvas" Width="160" Height="160" />
        </Viewbox>
        <StackPanel x:Name="LegendPanel" Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0" />
      </Grid>
    </Grid>
  </Border>
</UserControl>
