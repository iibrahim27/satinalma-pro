<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Color x:Key="DashPrimary">#2563EB</Color>
  <Color x:Key="DashBackground">#F7F9FC</Color>
  <Color x:Key="DashCard">#FFFFFF</Color>
  <Color x:Key="DashBorder">#E8EDF5</Color>
  <Color x:Key="DashText">#111827</Color>
  <Color x:Key="DashTextSecondary">#64748B</Color>
  <Color x:Key="DashNavActive">#EAF2FF</Color>
  <Color x:Key="DashNavHover">#F1F5F9</Color>
  <Color x:Key="DashSuccess">#10B981</Color>
  <Color x:Key="DashWarning">#F59E0B</Color>
  <Color x:Key="DashDanger">#EF4444</Color>
  <Color x:Key="DashPurple">#8B5CF6</Color>

  <SolidColorBrush x:Key="DashPrimaryBrush" Color="{StaticResource DashPrimary}" />
  <SolidColorBrush x:Key="DashBackgroundBrush" Color="{StaticResource DashBackground}" />
  <SolidColorBrush x:Key="DashCardBrush" Color="{StaticResource DashCard}" />
  <SolidColorBrush x:Key="DashBorderBrush" Color="{StaticResource DashBorder}" />
  <SolidColorBrush x:Key="DashTextBrush" Color="{StaticResource DashText}" />
  <SolidColorBrush x:Key="DashTextSecondaryBrush" Color="{StaticResource DashTextSecondary}" />
  <SolidColorBrush x:Key="DashNavActiveBrush" Color="{StaticResource DashNavActive}" />
  <SolidColorBrush x:Key="DashNavHoverBrush" Color="{StaticResource DashNavHover}" />

  <DropShadowEffect x:Key="DashCardShadow"
                    BlurRadius="18"
                    ShadowDepth="0"
                    Opacity="0.06"
                    Color="#0F172A" />

  <DropShadowEffect x:Key="DashCardShadowHover"
                    BlurRadius="28"
                    ShadowDepth="2"
                    Opacity="0.10"
                    Color="#0F172A" />

  <Style x:Key="DashCardBorderStyle" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource DashCardBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource DashBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="18" />
    <Setter Property="Effect" Value="{StaticResource DashCardShadow}" />
  </Style>

  <Style x:Key="DashGhostButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="{StaticResource DashCardBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource DashBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Foreground" Value="{StaticResource DashTextBrush}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Padding" Value="14,10" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="B"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="12"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="B" Property="Background" Value="{StaticResource DashNavHoverBrush}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="DashPrimaryButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="{StaticResource DashPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Padding" Value="16,10" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="B"
                  Background="{TemplateBinding Background}"
                  CornerRadius="12"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="B" Property="Opacity" Value="0.92" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="B" Property="Opacity" Value="0.86" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="DashNavButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Shell"
                  Background="Transparent"
                  CornerRadius="12"
                  Padding="12,10"
                  Margin="0,1">
            <Grid>
              <Border x:Name="Accent" Width="3" HorizontalAlignment="Left"
                      CornerRadius="2" Background="{StaticResource DashPrimaryBrush}"
                      Visibility="Collapsed" />
              <ContentPresenter Margin="6,0,0,0" />
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Shell" Property="Background" Value="{StaticResource DashNavHoverBrush}" />
            </Trigger>
            <Trigger Property="Tag" Value="Active">
              <Setter TargetName="Shell" Property="Background" Value="{StaticResource DashNavActiveBrush}" />
              <Setter TargetName="Accent" Property="Visibility" Value="Visible" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="DashBadgeStyle" TargetType="Border">
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="8,3" />
    <Setter Property="HorizontalAlignment" Value="Right" />
  </Style>

  <Style x:Key="DashSectionLinkStyle" TargetType="Button">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{StaticResource DashPrimaryBrush}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Padding" Value="4,2" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <ContentPresenter />
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Opacity" Value="0.75" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
