<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:SatinalmaPro.Controls">

  <Color x:Key="LoginNavy">#0F2A5A</Color>
  <Color x:Key="LoginAccentStart">#4F46E5</Color>
  <Color x:Key="LoginAccentEnd">#6D5BFF</Color>
  <Color x:Key="LoginGlassFill">#F2FFFFFF</Color>
  <Color x:Key="LoginGlassStroke">#66FFFFFF</Color>

  <SolidColorBrush x:Key="LoginNavyBrush" Color="{StaticResource LoginNavy}" />
  <SolidColorBrush x:Key="LoginGlassFillBrush" Color="{StaticResource LoginGlassFill}" />
  <SolidColorBrush x:Key="LoginGlassStrokeBrush" Color="{StaticResource LoginGlassStroke}" />

  <LinearGradientBrush x:Key="LoginAccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="{StaticResource LoginAccentStart}" Offset="0" />
    <GradientStop Color="{StaticResource LoginAccentEnd}" Offset="1" />
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="LoginHeroBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#0A1F42" Offset="0" />
    <GradientStop Color="{StaticResource LoginNavy}" Offset="0.55" />
    <GradientStop Color="#1E4A8C" Offset="1" />
  </LinearGradientBrush>

  <DropShadowEffect x:Key="LoginCardShadow" BlurRadius="28" ShadowDepth="0" Opacity="0.14" Color="#0F2A5A" />
  <DropShadowEffect x:Key="LoginGlowShadow" BlurRadius="20" ShadowDepth="0" Opacity="0.35" Color="#4F46E5" />

  <controls:LoginBoyutCarpanConverter x:Key="LoginBoyutCarpanConverter" />

  <Style x:Key="LoginGlassCardStyle" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource LoginGlassFillBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource LoginGlassStrokeBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="24" />
    <Setter Property="Padding" Value="28,24" />
    <Setter Property="Effect" Value="{StaticResource LoginCardShadow}" />
  </Style>

  <Style x:Key="LoginFieldLabelStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource InkMutedBrush}" />
    <Setter Property="Margin" Value="4,0,0,6" />
  </Style>

  <Style x:Key="LoginTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource FilterBoxStyle}">
    <Setter Property="Height" Value="44" />
    <Setter Property="Padding" Value="14,10" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
    <Style.Triggers>
      <Trigger Property="IsKeyboardFocused" Value="True">
        <Setter Property="BorderBrush" Value="{StaticResource LoginAccentStart}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="LoginPasswordBoxStyle" TargetType="PasswordBox">
    <Setter Property="Height" Value="44" />
    <Setter Property="Padding" Value="14,10" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Style.Triggers>
      <Trigger Property="IsKeyboardFocused" Value="True">
        <Setter Property="BorderBrush">
          <Setter.Value>
            <SolidColorBrush Color="{StaticResource LoginAccentStart}" />
          </Setter.Value>
        </Setter>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="LoginPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryToolbarButtonStyle}">
    <Setter Property="MinHeight" Value="50" />
    <Setter Property="Height" Value="50" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Padding" Value="16,12" />
    <Setter Property="Background" Value="{StaticResource LoginAccentGradientBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="BtnBorder" CornerRadius="14" Background="{TemplateBinding Background}"
                  Padding="{TemplateBinding Padding}">
            <Border.Effect>
              <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.22" Color="#4F46E5" />
            </Border.Effect>
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="BtnBorder" Property="RenderTransform">
                <Setter.Value>
                  <ScaleTransform ScaleX="1.02" ScaleY="1.02" />
                </Setter.Value>
              </Setter>
              <Setter TargetName="BtnBorder" Property="RenderTransformOrigin" Value="0.5,0.5" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="BtnBorder" Property="Opacity" Value="0.55" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Storyboard x:Key="LoginCardShakeStoryboard">
    <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)">
      <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0" />
      <LinearDoubleKeyFrame KeyTime="0:0:0.05" Value="12" />
      <LinearDoubleKeyFrame KeyTime="0:0:0.1" Value="-12" />
      <LinearDoubleKeyFrame KeyTime="0:0:0.15" Value="8" />
      <LinearDoubleKeyFrame KeyTime="0:0:0.2" Value="-8" />
      <LinearDoubleKeyFrame KeyTime="0:0:0.25" Value="0" />
    </DoubleAnimationUsingKeyFrames>
  </Storyboard>

  <Storyboard x:Key="LoginCardEnterStoryboard">
    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5" />
    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                     From="36" To="0" Duration="0:0:0.5">
      <DoubleAnimation.EasingFunction>
        <CubicEase EasingMode="EaseOut" />
      </DoubleAnimation.EasingFunction>
    </DoubleAnimation>
  </Storyboard>

</ResourceDictionary>
