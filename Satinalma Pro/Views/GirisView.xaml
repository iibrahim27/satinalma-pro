<UserControl x:Class="SatinalmaPro.Views.GirisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:controls="clr-namespace:SatinalmaPro.Controls"
             x:Name="Root">

  <UserControl.Resources>
    <Storyboard x:Key="KartSallaAnimasyonu">
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PanelGiris" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)">
        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0" />
        <LinearDoubleKeyFrame KeyTime="0:0:0.05" Value="10" />
        <LinearDoubleKeyFrame KeyTime="0:0:0.1" Value="-10" />
        <LinearDoubleKeyFrame KeyTime="0:0:0.15" Value="6" />
        <LinearDoubleKeyFrame KeyTime="0:0:0.2" Value="-6" />
        <LinearDoubleKeyFrame KeyTime="0:0:0.25" Value="0" />
      </DoubleAnimationUsingKeyFrames>
    </Storyboard>
  </UserControl.Resources>

  <Grid>
    <StackPanel x:Name="PanelGiris" RenderTransformOrigin="0.5,0.5">
      <StackPanel.RenderTransform>
        <TranslateTransform X="0" />
      </StackPanel.RenderTransform>

      <StackPanel x:Name="PanelKartBaslik" Visibility="Collapsed">
        <controls:UygulamaIkonAnimasyonu x:Name="KartLogo"
                                         IkonBoyutu="64"
                                         GirisModu="True"
                                         HorizontalAlignment="Center"
                                         Margin="0,0,0,12" />
        <TextBlock Text="Giriş Yap" FontSize="22" FontWeight="Bold"
                   Foreground="{StaticResource InkBrush}" Margin="0,0,0,4" />
        <TextBlock Text="Hesabınıza erişmek için bilgilerinizi girin" FontSize="13"
                   Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,20" />
      </StackPanel>

      <StackPanel x:Name="PanelTamBaslik">
        <controls:UygulamaIkonAnimasyonu IkonBoyutu="80" GirisModu="True" HorizontalAlignment="Center" Margin="0,0,0,16" />
        <TextBlock Text="Satınalma Pro" FontSize="24" FontWeight="SemiBold"
                   Foreground="{StaticResource InkBrush}" HorizontalAlignment="Center" Margin="0,0,0,4" />
        <TextBlock Text="Kurumsal Satınalma Yönetim Sistemi" FontSize="13"
                   Foreground="{StaticResource InkMutedBrush}" HorizontalAlignment="Center"
                   TextAlignment="Center" Margin="0,0,0,28" />
      </StackPanel>

      <TextBlock Text="Kullanıcı Adı" Style="{StaticResource LoginFieldLabelStyle}" />
      <TextBox x:Name="TxtEposta" Style="{StaticResource LoginTextBoxStyle}" Margin="0,0,0,14"
               ui:ControlHelper.PlaceholderText="ornek@firma.com" KeyDown="GirisAlani_KeyDown" />

      <TextBlock Text="Şifre" Style="{StaticResource LoginFieldLabelStyle}" />
      <Grid Margin="0,0,0,8">
        <PasswordBox x:Name="TxtSifre" Style="{StaticResource LoginPasswordBoxStyle}"
                     KeyDown="GirisAlani_KeyDown" />
        <TextBox x:Name="TxtSifreGoster" Style="{StaticResource LoginTextBoxStyle}"
                 Visibility="Collapsed" KeyDown="GirisAlani_KeyDown" />
        <Button x:Name="BtnSifreGoster" Content="👁" HorizontalAlignment="Right"
                VerticalAlignment="Center" Margin="0,0,8,0" Width="32" Height="32"
                Background="Transparent" BorderThickness="0" Cursor="Hand"
                Click="BtnSifreGoster_Click" ToolTip="Şifreyi göster/gizle" />
      </Grid>

      <Button Style="{StaticResource ToolbarButtonStyle}" Content="Şifremi unuttum"
              HorizontalAlignment="Right" Padding="8,4" FontSize="11" Margin="0,0,0,12"
              BorderThickness="0" Background="Transparent" Foreground="#4F46E5"
              Click="SifremiUnuttum_Click" />

      <CheckBox x:Name="ChkBeniHatirla" Content="Beni hatırla" FontSize="13"
                Foreground="{StaticResource InkBrush}" Margin="0,0,0,4"
                IsChecked="False"
                Checked="TercihKutusu_Degisti" Unchecked="TercihKutusu_Degisti" />

      <CheckBox x:Name="ChkSifremiHatirla" Content="Şifreyi hatırla" FontSize="13"
                Foreground="{StaticResource InkBrush}" Margin="0,0,0,4"
                IsChecked="False"
                Checked="TercihKutusu_Degisti" Unchecked="TercihKutusu_Degisti" />

      <Border x:Name="BilgiKutusu" Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1"
              CornerRadius="12" Padding="12,10" Margin="0,8,0,0" Visibility="Collapsed">
        <TextBlock x:Name="TxtBilgi" Foreground="#166534" FontSize="12" TextWrapping="Wrap" />
      </Border>

      <Border x:Name="HataKutusu" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1"
              CornerRadius="12" Padding="12,10" Margin="0,8,0,0" Visibility="Collapsed">
        <TextBlock x:Name="TxtHata" Foreground="#DC2626" FontSize="12" TextWrapping="Wrap" />
      </Border>

      <Button x:Name="BtnGiris" Style="{StaticResource LoginPrimaryButtonStyle}"
              Content="Giriş Yap" Click="Giris_Click" Margin="0,20,0,0"
              HorizontalAlignment="Stretch" />

      <StackPanel Margin="0,20,0,0">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
          <Ellipse x:Name="SunucuDurumNokta" Width="8" Height="8" Fill="#22C55E" Margin="0,0,8,0" VerticalAlignment="Center" />
          <TextBlock x:Name="TxtSunucuDurum" FontSize="11" Foreground="{StaticResource InkMutedBrush}" VerticalAlignment="Center" />
        </StackPanel>
        <TextBlock x:Name="TxtVersiyon" FontSize="11" Foreground="{StaticResource InkMutedBrush}"
                   HorizontalAlignment="Center" Margin="0,8,0,0" />
        <TextBlock Text="Satınalma Pro" FontSize="11" Foreground="{StaticResource InkMutedBrush}"
                   HorizontalAlignment="Center" Margin="0,4,0,0" Opacity="0.8" />
      </StackPanel>
    </StackPanel>

    <StackPanel x:Name="PanelSifreSifir" Visibility="Collapsed">
      <Button Style="{StaticResource ToolbarButtonStyle}" HorizontalAlignment="Left"
              Padding="0,4" Margin="0,0,0,16" BorderThickness="0" Background="Transparent"
              Click="GeriGiris_Click">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                     Margin="0,0,8,0" VerticalAlignment="Center" />
          <TextBlock Text="Girişe dön" VerticalAlignment="Center" />
        </StackPanel>
      </Button>

      <controls:UygulamaIkonAnimasyonu IkonBoyutu="64" GirisModu="True" HorizontalAlignment="Center" Margin="0,0,0,16" />

      <TextBlock Text="Şifremi Unuttum" FontSize="24" FontWeight="SemiBold"
                 Foreground="{StaticResource InkBrush}" Margin="0,0,0,6" />
      <TextBlock Text="E-posta adresinize şifre sıfırlama bağlantısı gönderilir."
                 FontSize="13" Foreground="{StaticResource InkMutedBrush}"
                 TextWrapping="Wrap" Margin="0,0,0,24" />

      <TextBlock Text="E-posta" Style="{StaticResource LoginFieldLabelStyle}" />
      <TextBox x:Name="TxtSifirEposta" Style="{StaticResource LoginTextBoxStyle}" Margin="0,0,0,8"
               ui:ControlHelper.PlaceholderText="ornek@firma.com" KeyDown="SifirAlani_KeyDown" />

      <Border x:Name="SifirHataKutusu" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1"
              CornerRadius="12" Padding="12,10" Margin="0,8,0,0" Visibility="Collapsed">
        <TextBlock x:Name="TxtSifirHata" Foreground="#DC2626" FontSize="12" TextWrapping="Wrap" />
      </Border>

      <Border x:Name="SifirBilgiKutusu" Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1"
              CornerRadius="12" Padding="12,10" Margin="0,8,0,0" Visibility="Collapsed">
        <TextBlock x:Name="TxtSifirBilgi" Foreground="#166534" FontSize="12" TextWrapping="Wrap" />
      </Border>

      <Button x:Name="BtnSifirGonder" Style="{StaticResource LoginPrimaryButtonStyle}"
              Content="Sıfırlama Bağlantısı Gönder" Click="SifirGonder_Click"
              Margin="0,20,0,0" HorizontalAlignment="Stretch" />
    </StackPanel>
  </Grid>
</UserControl>
