<UserControl x:Class="SatinalmaPro.Views.GirisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:controls="clr-namespace:SatinalmaPro.Controls">

  <Grid>
    <!-- Giriş paneli -->
    <StackPanel x:Name="PanelGiris">
      <controls:UygulamaIkonAnimasyonu IkonBoyutu="80" HorizontalAlignment="Center" Margin="0,0,0,16" />

      <TextBlock Text="Satınalma Pro" FontSize="24" FontWeight="SemiBold"
                 Foreground="{StaticResource InkBrush}" HorizontalAlignment="Center" Margin="0,0,0,4" />
      <TextBlock Text="Kurumsal Satınalma Yönetim Sistemi" FontSize="13"
                 Foreground="{StaticResource InkMutedBrush}" HorizontalAlignment="Center"
                 TextAlignment="Center" Margin="0,0,0,28" />

      <TextBlock Text="E-posta" FontSize="12" FontWeight="SemiBold"
                 Foreground="{StaticResource InkBrush}" Margin="0,0,0,6" />
      <TextBox x:Name="TxtEposta" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,16"
               ui:ControlHelper.PlaceholderText="ornek@firma.com" KeyDown="GirisAlani_KeyDown" />

      <TextBlock Text="Şifre" FontSize="12" FontWeight="SemiBold"
                 Foreground="{StaticResource InkBrush}" Margin="0,0,0,6" />
      <PasswordBox x:Name="TxtSifre" Height="40" Padding="12,8" Margin="0,0,0,8"
                   BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                   KeyDown="GirisAlani_KeyDown" />

      <Button Style="{StaticResource ToolbarButtonStyle}" Content="Şifremi unuttum"
              HorizontalAlignment="Right" Padding="8,4" FontSize="11" Margin="0,0,0,12"
              BorderThickness="0" Background="Transparent"
              Click="SifremiUnuttum_Click" />

      <CheckBox x:Name="ChkBeniHatirla" Content="Beni hatırla" FontSize="13"
                Foreground="{StaticResource InkBrush}" Margin="0,0,0,4"
                Checked="TercihKutusu_Degisti" Unchecked="TercihKutusu_Degisti" />

      <CheckBox x:Name="ChkSifremiHatirla" Content="Şifreyi hatırla" FontSize="13"
                Foreground="{StaticResource InkBrush}" Margin="0,0,0,4"
                Checked="TercihKutusu_Degisti" Unchecked="TercihKutusu_Degisti" />

      <Border x:Name="BilgiKutusu" Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1"
              CornerRadius="10" Padding="12,10" Margin="0,8,0,0" Visibility="Collapsed">
        <TextBlock x:Name="TxtBilgi" Foreground="#166534" FontSize="12" TextWrapping="Wrap" />
      </Border>

      <Border x:Name="HataKutusu" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1"
              CornerRadius="10" Padding="12,10" Margin="0,8,0,0" Visibility="Collapsed">
        <TextBlock x:Name="TxtHata" Foreground="#DC2626" FontSize="12" TextWrapping="Wrap" />
      </Border>

      <Button x:Name="BtnGiris" Style="{StaticResource PrimaryToolbarButtonStyle}"
              Content="Giriş Yap" Click="Giris_Click" Margin="0,20,0,0"
              Padding="16,12" MinHeight="46" Height="46" FontSize="14" HorizontalAlignment="Stretch" />
    </StackPanel>

    <!-- Şifre sıfırlama paneli -->
    <StackPanel x:Name="PanelSifreSifir" Visibility="Collapsed">
      <Button Style="{StaticResource ToolbarButtonStyle}" HorizontalAlignment="Left"
              Padding="0,4" Margin="0,0,0,16" BorderThickness="0" Background="Transparent"
              Click="GeriGiris_Click">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                     Margin="0,0,8,0" VerticalAlignment="Center" />
          <TextBlock Text="Girişe dön" VerticalAlignment="Center" />
        </StackPanel>
      </Button>

      <controls:UygulamaIkonAnimasyonu IkonBoyutu="64" HorizontalAlignment="Center" Margin="0,0,0,16" />

      <TextBlock Text="Şifremi Unuttum" FontSize="24" FontWeight="SemiBold"
                 Foreground="{StaticResource InkBrush}" Margin="0,0,0,6" />
      <TextBlock Text="E-posta adresinize şifre sıfırlama bağlantısı gönderilir."
                 FontSize="13" Foreground="{StaticResource InkMutedBrush}"
                 TextWrapping="Wrap" Margin="0,0,0,24" />

      <TextBlock Text="E-posta" FontSize="12" FontWeight="SemiBold"
                 Foreground="{StaticResource InkBrush}" Margin="0,0,0,6" />
      <TextBox x:Name="TxtSifirEposta" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,8"
               ui:ControlHelper.PlaceholderText="ornek@firma.com" KeyDown="SifirAlani_KeyDown" />

      <Border x:Name="SifirHataKutusu" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1"
              CornerRadius="10" Padding="12,10" Margin="0,8,0,0" Visibility="Collapsed">
        <TextBlock x:Name="TxtSifirHata" Foreground="#DC2626" FontSize="12" TextWrapping="Wrap" />
      </Border>

      <Border x:Name="SifirBilgiKutusu" Background="#F0FDF4" BorderBrush="#BBF7D0" BorderThickness="1"
              CornerRadius="10" Padding="12,10" Margin="0,8,0,0" Visibility="Collapsed">
        <TextBlock x:Name="TxtSifirBilgi" Foreground="#166534" FontSize="12" TextWrapping="Wrap" />
      </Border>

      <Button x:Name="BtnSifirGonder" Style="{StaticResource PrimaryToolbarButtonStyle}"
              Content="Sıfırlama Bağlantısı Gönder" Click="SifirGonder_Click"
              Margin="0,20,0,0" Padding="16,12" MinHeight="46" Height="46"
              FontSize="14" HorizontalAlignment="Stretch" />
    </StackPanel>
  </Grid>
</UserControl>
