<UserControl x:Class="SatinalmaPro.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dash="clr-namespace:SatinalmaPro.Controls.Dashboard"
             xmlns:helpers="clr-namespace:SatinalmaPro.Helpers"
             helpers:ScrollWheelHelper.IsEnabled="True">
  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,24">
    <StackPanel x:Name="Root" Margin="0,0,0,8">

      <!-- Hoş geldiniz + tarih + rapor -->
      <Grid Margin="0,0,0,20">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel VerticalAlignment="Center">
          <TextBlock x:Name="TxtKarsilama" FontSize="26" FontWeight="Bold" Foreground="{StaticResource DashTextBrush}" />
          <TextBlock x:Name="TxtAltBaslik" Text="Satınalma süreçlerinizi kolayca yönetin."
                     FontSize="14" Foreground="{StaticResource DashTextSecondaryBrush}" Margin="0,6,0,0" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <Border Background="{StaticResource DashCardBrush}" BorderBrush="{StaticResource DashBorderBrush}"
                  BorderThickness="1" CornerRadius="10" Padding="14,10" Margin="0,0,12,0">
            <TextBlock x:Name="TxtTarihSaat" FontSize="12" Foreground="{StaticResource DashTextSecondaryBrush}" />
          </Border>
          <Button x:Name="BtnRaporOlustur" Style="{StaticResource DashPrimaryButtonStyle}" Click="BtnRaporOlustur_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Rapor Oluştur" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>

      <!-- 5 KPI -->
      <UniformGrid x:Name="StatGrid" Rows="1" Columns="5" Margin="0,0,0,20" />

      <!-- Orta: grafik + hızlı işlemler -->
      <Grid Margin="0,0,0,20">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="2*" />
          <ColumnDefinition Width="16" />
          <ColumnDefinition Width="1.4*" />
          <ColumnDefinition Width="16" />
          <ColumnDefinition Width="1.1*" />
        </Grid.ColumnDefinitions>
        <dash:ErpLineChartPanel x:Name="LineChart" Grid.Column="0" />
        <dash:ErpDonutChartPanel x:Name="DonutChart" Grid.Column="2" />
        <dash:ErpQuickActionsPanel x:Name="QuickActions" Grid.Column="4" />
      </Grid>

      <!-- Alt: timeline + grid + widget -->
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="1.1*" />
          <ColumnDefinition Width="16" />
          <ColumnDefinition Width="2*" />
          <ColumnDefinition Width="16" />
          <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>
        <dash:ActivityPanelControl x:Name="ActivityPanel" Grid.Column="0" />
        <dash:ErpOpenRecordsPanel x:Name="OpenRecords" Grid.Column="2" />
        <dash:ErpRightWidgetsPanel x:Name="RightWidgets" Grid.Column="4" />
      </Grid>

      <!-- Modül kartları gizli — navigasyon sidebar'dan -->
      <WrapPanel x:Name="ModulPanel" Visibility="Collapsed" />
    </StackPanel>
  </ScrollViewer>
</UserControl>
