<UserControl x:Class="SatinalmaPro.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:SatinalmaPro.Views">
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
  </UserControl.Resources>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Büyük anasayfa logosu -->
    <Border Grid.Row="0" Margin="0,0,0,20" HorizontalAlignment="Center" MinHeight="100">
      <Image x:Name="ImgAnasayfaLogo"
             MaxHeight="140"
             MaxWidth="520"
             Stretch="Uniform"
             HorizontalAlignment="Center"
             VerticalAlignment="Center" />
    </Border>

    <ItemsControl Grid.Row="1"
                  ItemsSource="{Binding Modules}"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Center"
                  Margin="0,0,0,16">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <UniformGrid Columns="5" />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate DataType="{x:Type views:ModulKarti}">
          <Button Style="{StaticResource NexusCardStyle}"
                  Tag="{Binding Title}"
                  Click="ModuleCard_Click">
            <Grid MinHeight="188" Margin="4,0">
              <StackPanel VerticalAlignment="Center">
                <Border Width="44"
                        Height="44"
                        CornerRadius="14"
                        Margin="0,0,0,14"
                        HorizontalAlignment="Left">
                  <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                      <GradientStop Color="{Binding GradientStart}" Offset="0" />
                      <GradientStop Color="{Binding GradientEnd}" Offset="1" />
                    </LinearGradientBrush>
                  </Border.Background>
                  <TextBlock Text="{Binding IconGlyph}"
                             FontFamily="Segoe MDL2 Assets"
                             FontSize="18"
                             Foreground="White"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="{Binding Title}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource InkBrush}"
                           TextWrapping="Wrap"
                           LineHeight="20" />
                <TextBlock Text="{Binding Subtitle}"
                           FontSize="11"
                           Foreground="{StaticResource InkMutedBrush}"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"
                           LineHeight="15" />
              </StackPanel>
              <TextBlock Text="{Binding Number}"
                         FontSize="10"
                         FontWeight="Bold"
                         Foreground="{StaticResource InkMutedBrush}"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Top"
                         Opacity="0.45" />
              <Border MinWidth="22"
                      Height="22"
                      Padding="6,0"
                      CornerRadius="11"
                      Background="#E11D48"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="0,28,0,0"
                      Visibility="{Binding BildirimRozetiGorunur, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding BildirimRozetiMetni}"
                           FontSize="11"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </Border>
            </Grid>
          </Button>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
  </Grid>
</UserControl>
