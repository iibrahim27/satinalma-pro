<Window x:Class="SatinalmaPro.Views.TeklifsizFirmaFiyatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Firma/Fiyat Girişi" Width="560" Height="520"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip">
  <DockPanel Margin="20">
    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
      <TextBlock x:Name="TxtBaslik" FontSize="16" FontWeight="SemiBold" />
      <TextBlock x:Name="TxtAlt" Foreground="#64748B" Margin="0,4,0,0" />
    </StackPanel>
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button Content="İptal" Width="96" Margin="0,0,8,0" IsCancel="True" Click="Iptal_Click" />
      <Button Content="Kaydet" Width="110" IsDefault="True" Click="Kaydet_Click" />
    </StackPanel>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <ItemsControl x:Name="KalemListesi">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="#F8FAFC" CornerRadius="10" Padding="12" Margin="0,0,0,10">
              <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="{Binding Malzeme}" />
                <TextBlock Foreground="#64748B" Margin="0,2,0,8">
                  <Run Text="{Binding Miktar, StringFormat=N2, Mode=OneWay}" />
                  <Run Text=" " />
                  <Run Text="{Binding Birim, Mode=OneWay}" />
                </TextBlock>
                <TextBox Margin="0,0,0,6" Tag="Firma" Text="{Binding FirmaAdi, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Tag="Birim Fiyat" Text="{Binding BirimFiyatMetin, UpdateSourceTrigger=PropertyChanged}" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</Window>
