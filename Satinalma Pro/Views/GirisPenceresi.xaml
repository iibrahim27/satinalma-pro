<Window x:Class="SatinalmaPro.Views.GirisPenceresi"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SatinalmaPro.Views"
        Title="Satınalma Pro — Giriş"
        Width="440"
        Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White">

  <Grid>
    <Rectangle Fill="{StaticResource GridPatternBrush}" Opacity="0.45" />
    <Ellipse Width="360" Height="360" HorizontalAlignment="Right" VerticalAlignment="Top"
             Margin="0,-120,-80,0" Fill="{StaticResource AuraBrush}" Opacity="0.08" />
    <Ellipse Width="280" Height="280" HorizontalAlignment="Left" VerticalAlignment="Bottom"
             Margin="-80,0,0,-80" Fill="{StaticResource AuraBrush}" Opacity="0.06" />
    <views:GirisView x:Name="GirisKontrol" Margin="32,28" VerticalAlignment="Center" />
  </Grid>
</Window>
