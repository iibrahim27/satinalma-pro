<Window x:Class="SatinalmaPro.Views.AcilisEkrani"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        Title="Satınalma Pro"
        Width="560"
        Height="680"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        Topmost="False"
        ResizeMode="NoResize">

  <Border Background="White"
          CornerRadius="20"
          BorderBrush="{StaticResource LineBrush}"
          BorderThickness="1"
          Padding="32,28">
    <Border.Effect>
      <DropShadowEffect BlurRadius="32" ShadowDepth="0" Opacity="0.12" Color="#000000" />
    </Border.Effect>
    <Grid>
      <Button x:Name="BtnKapat"
              Content="✕"
              Width="32"
              Height="32"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="0,-8,-8,0"
              Background="Transparent"
              BorderThickness="0"
              Foreground="{StaticResource InkMutedBrush}"
              FontSize="14"
              Cursor="Hand"
              ToolTip="Kapat"
              Click="BtnKapat_Click" />

    <StackPanel VerticalAlignment="Center">
      <Border CornerRadius="16"
              Background="#FAFBFC"
              BorderBrush="{StaticResource LineBrush}"
              BorderThickness="1"
              Margin="0,0,0,24"
              HorizontalAlignment="Center">
        <Image x:Name="ImgAcilis"
               Width="420"
               Height="280"
               Stretch="Uniform"
               Margin="12"
               gif:ImageBehavior.AnimatedSource="pack://application:,,,/Assets/acilisgif.gif"
               gif:ImageBehavior.RepeatBehavior="Forever" />
      </Border>

      <TextBlock x:Name="TxtBaslik"
                 Text="Uygulama yükleniyor..."
                 FontSize="18"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource InkBrush}"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,8" />

      <TextBlock x:Name="TxtDurum"
                 Text="Veriler alınıyor..."
                 FontSize="13"
                 Foreground="{StaticResource InkMutedBrush}"
                 HorizontalAlignment="Center"
                 Margin="0,0,0,20" />

      <Grid x:Name="PrgTrack" Margin="0,0,0,6">
        <Border Height="10"
                CornerRadius="5"
                Background="#F1F3F6" />
        <Border x:Name="PrgDolgu"
                Height="10"
                CornerRadius="5"
                HorizontalAlignment="Left"
                Width="0">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
              <GradientStop Color="#DC2626" Offset="0" />
              <GradientStop Color="#EA580C" Offset="1" />
            </LinearGradientBrush>
          </Border.Background>
        </Border>
      </Grid>

      <TextBlock x:Name="TxtYuzde"
                 Text="0%"
                 FontSize="11"
                 Foreground="{StaticResource InkMutedBrush}"
                 HorizontalAlignment="Right" />
    </StackPanel>
    </Grid>
  </Border>
</Window>
