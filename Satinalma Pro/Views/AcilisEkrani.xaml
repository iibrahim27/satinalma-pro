<Window x:Class="SatinalmaPro.Views.AcilisEkrani"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SatinalmaPro.Controls"
        Title="Satınalma Pro"
        Width="480"
        Height="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        ResizeMode="NoResize">

  <Border x:Name="AnaCerceve"
          Background="White"
          CornerRadius="20"
          BorderBrush="{StaticResource LineBrush}"
          BorderThickness="1"
          Padding="32,28"
          PreviewMouseLeftButtonDown="PencereSurukle_Preview">
    <Border.Effect>
      <DropShadowEffect BlurRadius="32" ShadowDepth="0" Opacity="0.12" Color="#000000" />
    </Border.Effect>
    <Grid>
      <Button x:Name="BtnKapat"
              Content="✕"
              Width="32"
              Height="32"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Margin="0,-8,-8,0"
              Background="Transparent"
              BorderThickness="0"
              Foreground="{StaticResource InkMutedBrush}"
              FontSize="14"
              Cursor="Hand"
              ToolTip="Kapat"
              Click="BtnKapat_Click" />

      <ScrollViewer x:Name="PanelYukleme"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel VerticalAlignment="Center" Margin="0,8,0,0">
          <controls:UygulamaIkonAnimasyonu IkonBoyutu="96" HorizontalAlignment="Center" Margin="0,0,0,20" />

          <TextBlock Text="Satınalma Pro"
                     FontSize="24"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource InkBrush}"
                     HorizontalAlignment="Center" />
          <TextBlock Text="Kurumsal Satınalma Yönetim Sistemi"
                     FontSize="13"
                     Foreground="{StaticResource InkMutedBrush}"
                     HorizontalAlignment="Center"
                     TextAlignment="Center"
                     Margin="0,6,0,24" />

          <StackPanel Margin="0,0,0,24">
            <TextBlock Text="✓  Kurumsal satınalma süreçleri" FontSize="13" Foreground="{StaticResource InkBrush}" Margin="0,0,0,10" />
            <TextBlock Text="✓  Teklif ve onay yönetimi" FontSize="13" Foreground="{StaticResource InkBrush}" Margin="0,0,0,10" />
            <TextBlock Text="✓  Stok ve mal kabul takibi" FontSize="13" Foreground="{StaticResource InkBrush}" Margin="0,0,0,10" />
            <TextBlock Text="✓  Anlık bildirimler" FontSize="13" Foreground="{StaticResource InkBrush}" />
          </StackPanel>

          <TextBlock x:Name="TxtBaslik"
                     Text="Uygulama yükleniyor..."
                     FontSize="15"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource InkBrush}"
                     HorizontalAlignment="Center"
                     Margin="0,0,0,6" />

          <TextBlock x:Name="TxtDurum"
                     Text="Veriler alınıyor..."
                     FontSize="13"
                     Foreground="{StaticResource InkMutedBrush}"
                     HorizontalAlignment="Center"
                     TextAlignment="Center"
                     Margin="0,0,0,18" />

          <Grid x:Name="PrgTrack" Margin="0,0,0,6">
            <Border Height="10" CornerRadius="5" Background="#F1F3F6" />
            <Border x:Name="PrgDolgu"
                    Height="10"
                    CornerRadius="5"
                    HorizontalAlignment="Left"
                    Width="0">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                  <GradientStop Color="#2563EB" Offset="0" />
                  <GradientStop Color="#1D4ED8" Offset="1" />
                </LinearGradientBrush>
              </Border.Background>
            </Border>
          </Grid>

          <TextBlock x:Name="TxtYuzde"
                     Text="0%"
                     FontSize="11"
                     Foreground="{StaticResource InkMutedBrush}"
                     HorizontalAlignment="Right"
                     Margin="0,0,0,16" />

          <TextBlock x:Name="TxtVersiyon"
                     FontSize="11"
                     Foreground="{StaticResource InkMutedBrush}"
                     HorizontalAlignment="Center" />
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Border>
</Window>
