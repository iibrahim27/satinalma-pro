<Window x:Class="SatinalmaPro.Views.BildirimlerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bildirimler"
        Width="480" Height="560"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA">

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
      <TextBlock Text="Bildirimler" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
      <Button x:Name="BtnTumunuOkundu" Content="Tümünü okundu işaretle" Margin="16,0,0,0"
              Padding="10,6" Click="TumunuOkundu_Click" />
      <Button x:Name="BtnTemizle" Content="Temizle" Margin="8,0,0,0"
              Padding="10,6" Click="Temizle_Click" />
    </StackPanel>

    <ListBox Grid.Row="1" x:Name="Liste" BorderThickness="0" Background="Transparent"
             SelectionChanged="Liste_SelectionChanged">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Margin="0,0,0,8" Padding="12" Background="White" CornerRadius="8"
                  BorderBrush="#E0E0E0" BorderThickness="1">
            <StackPanel>
              <TextBlock Text="{Binding Baslik}" FontWeight="SemiBold" Foreground="#1B3A5C" TextWrapping="Wrap" />
              <TextBlock Text="{Binding Mesaj}" Foreground="#666" Margin="0,4,0,0" TextWrapping="Wrap" />
              <TextBlock Text="{Binding OlusturmaTarihi}" Foreground="#999" FontSize="11" Margin="0,6,0,0" />
            </StackPanel>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <TextBlock Grid.Row="2" x:Name="TxtBos" Text="Bildirim yok." Foreground="#999"
               HorizontalAlignment="Center" Margin="0,8,0,0" Visibility="Collapsed" />
  </Grid>
</Window>
