<Window x:Class="SatinalmaPro.Views.Modules.RaporCokluSecWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        xmlns:ui="http://schemas.modernwpf.com/2019"

        ui:WindowHelper.UseModernWindowStyle="True"

        Title="Seçim"

        Width="480"

        Height="520"

        MinHeight="420"

        WindowStartupLocation="CenterOwner"

        ResizeMode="CanResizeWithGrip"

        Background="{StaticResource DashBackgroundBrush}">

  <Grid Margin="20">

    <Grid.RowDefinitions>

      <RowDefinition Height="Auto" />

      <RowDefinition Height="Auto" />

      <RowDefinition Height="*" />

      <RowDefinition Height="Auto" />

    </Grid.RowDefinitions>



    <StackPanel Grid.Row="0" Margin="0,0,0,12">

      <TextBlock x:Name="TxtBaslik" Text="Seçim Yapın"

                 FontSize="17" FontWeight="SemiBold"

                 Foreground="{StaticResource InkBrush}" />

      <TextBlock x:Name="TxtAciklama" Text="Birden fazla öğe seçebilirsiniz."

                 FontSize="12" Foreground="{StaticResource InkMutedBrush}"

                 Margin="0,4,0,0" TextWrapping="Wrap" />

    </StackPanel>



    <Grid Grid.Row="1" Margin="0,0,0,10">

      <Grid.ColumnDefinitions>

        <ColumnDefinition Width="*" />

        <ColumnDefinition Width="Auto" />

        <ColumnDefinition Width="Auto" />

      </Grid.ColumnDefinitions>

      <TextBox x:Name="TxtAra" Grid.Column="0" Margin="0,0,8,0"

               ui:ControlHelper.PlaceholderText="Ara..." TextChanged="TxtAra_TextChanged" />

      <Button Grid.Column="1" Content="Tümünü Seç" Style="{StaticResource ToolbarButtonStyle}"

              Margin="0,0,6,0" Click="TumunuSec_Click" />

      <Button Grid.Column="2" Content="Temizle" Style="{StaticResource ToolbarButtonStyle}"

              Click="Temizle_Click" />

    </Grid>



    <Border Grid.Row="2" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"

            CornerRadius="10" Padding="4">

      <ScrollViewer Style="{StaticResource ModuleScrollViewerStyle}">

        <ItemsControl x:Name="SecimListesi" />

      </ScrollViewer>

    </Border>



    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">

      <TextBlock x:Name="TxtSecimSayisi" Text="0 seçili" VerticalAlignment="Center"

                 Foreground="{StaticResource InkMutedBrush}" FontSize="12" Margin="0,0,16,0" />

      <Button Content="İptal" Style="{StaticResource ToolbarButtonStyle}" Width="90"

              Margin="0,0,8,0" Click="Iptal_Click" />

      <Button Content="Uygula" Style="{StaticResource PrimaryToolbarButtonStyle}" Width="100"

              IsDefault="True" Click="Tamam_Click" />

    </StackPanel>

  </Grid>

</Window>


