<UserControl x:Class="SatinalmaPro.Views.Modules.SatinalmaShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dash="clr-namespace:SatinalmaPro.Controls.Dashboard"
             xmlns:helpers="clr-namespace:SatinalmaPro.Helpers"
             Background="{StaticResource SatModBgBrush}"
             helpers:ScrollWheelHelper.IsEnabled="True">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="260" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Sol menü -->
    <Border Grid.Column="0"
            Background="{StaticResource DashCardBrush}"
            BorderBrush="{StaticResource DashBorderBrush}"
            BorderThickness="0,0,1,0"
            Effect="{StaticResource ModuleCardShadow}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="18,20,18,16"
                BorderBrush="{StaticResource DashBorderBrush}"
                BorderThickness="0,0,0,1">
          <StackPanel Orientation="Horizontal">
            <Border Width="42" Height="42" CornerRadius="12" Margin="0,0,12,0"
                    Background="{StaticResource SatModIconGradient}">
              <dash:IconControl Kind="ShoppingCart" IconSize="20" StrokeBrush="White"
                                HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="Satınalma" FontSize="16" FontWeight="Bold"
                         Foreground="{StaticResource DashTextBrush}" />
              <TextBlock x:Name="TxtKullanici" FontSize="11"
                         Foreground="{StaticResource DashTextSecondaryBrush}"
                         Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />
            </StackPanel>
          </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="8,10,8,16">
          <StackPanel x:Name="NavPanel" />
        </ScrollViewer>
      </Grid>
    </Border>

    <!-- İçerik alanı -->
    <Grid Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Border Grid.Row="0"
              Style="{StaticResource ModulePageCardStyle}"
              BorderThickness="0,0,0,1"
              CornerRadius="0"
              Padding="24,18">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel VerticalAlignment="Center">
            <TextBlock x:Name="TxtBaslik" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource DashTextBrush}" />
            <TextBlock x:Name="TxtAciklama" Style="{StaticResource SatModHint}" Margin="0,5,0,0" />
          </StackPanel>

          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
            <Button x:Name="BtnYeniTalep" Style="{StaticResource PrimaryToolbarButtonStyle}"
                    Click="BtnYeniTalep_Click" Margin="0,0,8,0" Padding="16,9" Visibility="Collapsed">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="+" FontSize="15" FontWeight="Bold" Margin="0,0,8,0" />
                <TextBlock Text="Yeni Talep" />
              </StackPanel>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="Excel_Click" Margin="0,0,8,0"
                    Padding="12,9" ToolTip="Excel">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0" />
                <TextBlock Text="Excel" />
              </StackPanel>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="Pdf_Click" Margin="0,0,8,0"
                    Padding="12,9" ToolTip="PDF">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0" />
                <TextBlock Text="PDF" />
              </StackPanel>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="Yazdir_Click" Margin="0,0,8,0"
                    Padding="12,9" ToolTip="Yazdır">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0" />
                <TextBlock Text="Yazdır" />
              </StackPanel>
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="Yenile_Click"
                    ToolTip="Yenile (F5)" Padding="12,9" Margin="0,0,8,0">
              <dash:IconControl Kind="TrendingUp" IconSize="16" StrokeBrush="{StaticResource DashTextSecondaryBrush}" />
            </Button>
            <Button Style="{StaticResource ToolbarButtonStyle}" Click="Bildirim_Click"
                    Padding="12,9" ToolTip="Bildirimler">
              <TextBlock Text="&#xE7ED;" FontFamily="Segoe MDL2 Assets" FontSize="14" />
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <Border Grid.Row="1" Padding="24,18,24,20" Background="{StaticResource SatModBgBrush}">
        <ContentControl x:Name="IcerikAlani" />
      </Border>
    </Grid>
  </Grid>
</UserControl>
