<Window x:Class="SatinalmaPro.Views.Modules.FiloZimmetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Araç Zimmet"
        Width="460" Height="280" MinWidth="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="White">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <StackPanel Grid.Row="0" Margin="0,0,0,16">
      <TextBlock x:Name="TxtBaslik" FontSize="20" FontWeight="SemiBold" />
      <TextBlock Text="Şoför / operatör adını girin. Zimmet formu otomatik oluşturulur."
                 FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
    </StackPanel>
    <StackPanel Grid.Row="1">
      <TextBlock Text="Şoför / Operatör Adı" Style="{StaticResource FilterLabelStyle}" />
      <TextBox x:Name="TxtSofor" Style="{StaticResource FilterBoxStyle}" />
    </StackPanel>
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button Content="İptal" Style="{StaticResource ToolbarButtonStyle}" Width="100" Margin="0,0,8,0" Click="Iptal_Click" />
      <Button Content="Zimmetle" Style="{StaticResource PrimaryToolbarButtonStyle}" Width="110" Click="Zimmetle_Click" />
    </StackPanel>
  </Grid>
</Window>
