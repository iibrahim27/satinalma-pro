<Window x:Class="SatinalmaPro.Views.Modules.SatinalmaTeklifDuzenleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Teklif Girişi"
        Width="960"
        Height="680"
        MinWidth="800"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="White">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,16">
      <TextBlock Text="Firma Teklifi" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
      <TextBlock Text="Malzeme bazında marka, birim fiyat ve KDV girin" FontSize="12"
                 Foreground="{StaticResource InkMutedBrush}" Margin="0,4,0,0" />
    </StackPanel>

    <Grid Grid.Row="1" Margin="0,0,0,14">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid Grid.Row="0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="2*" />
          <ColumnDefinition Width="12" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="12" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="12" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="12" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
          <TextBlock Text="Firma Adı *" FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,4" />
          <TextBox x:Name="TxtFirmaAdi" Style="{StaticResource FilterBoxStyle}" />
        </StackPanel>
        <StackPanel Grid.Column="2">
          <TextBlock Text="USD Kuru" FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,4" />
          <TextBox x:Name="TxtUsdKuru" Style="{StaticResource FilterBoxStyle}" TextChanged="KurMetniDegisti" />
        </StackPanel>
        <StackPanel Grid.Column="4">
          <TextBlock Text="EUR Kuru" FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,4" />
          <TextBox x:Name="TxtEurKuru" Style="{StaticResource FilterBoxStyle}" TextChanged="KurMetniDegisti" />
        </StackPanel>
        <StackPanel Grid.Column="6">
          <TextBlock Text="Vade (gün)" FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,4" />
          <TextBox x:Name="TxtVade" Style="{StaticResource FilterBoxStyle}" />
        </StackPanel>
        <StackPanel Grid.Column="8">
          <TextBlock Text="Teslim Süresi" FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,4" />
          <TextBox x:Name="TxtTeslim" Style="{StaticResource FilterBoxStyle}" />
        </StackPanel>
      </Grid>
      <Grid Grid.Row="1" Margin="0,12,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="12" />
          <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
          <TextBlock Text="Ödeme Şekli" FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,4" />
          <TextBox x:Name="TxtOdeme" Style="{StaticResource FilterBoxStyle}" />
        </StackPanel>
        <StackPanel Grid.Column="2">
          <TextBlock Text="Açıklama" FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,4" />
          <TextBox x:Name="TxtAciklama" Style="{StaticResource FilterBoxStyle}" />
        </StackPanel>
      </Grid>
    </Grid>

    <DataGrid x:Name="FiyatGrid" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False"
              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
              BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
              RowHeight="36" FontSize="12" Margin="0,0,0,12"
              BeginningEdit="FiyatGrid_BeginningEdit"
              CellEditEnding="FiyatGrid_CellEditEnding"
              RowEditEnding="FiyatGrid_RowEditEnding"
              PreparingCellForEdit="FiyatGrid_PreparingCellForEdit">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Malzeme" Binding="{Binding Malzeme}" Width="*" IsReadOnly="True" />
        <DataGridTextColumn Header="Miktar" Binding="{Binding MiktarMetni}" Width="90" IsReadOnly="True" />
        <DataGridTextColumn Header="Marka" Binding="{Binding Marka, UpdateSourceTrigger=LostFocus}" Width="110" />
        <DataGridComboBoxColumn x:Name="ParaBirimiSutunu" Header="Para" Width="72"
                                SelectedItemBinding="{Binding ParaBirimi, UpdateSourceTrigger=LostFocus}" />
        <DataGridTextColumn Header="Birim Fiyat" Binding="{Binding BirimFiyatMetni, UpdateSourceTrigger=LostFocus}" Width="100" />
        <DataGridTextColumn Header="KDV %" Binding="{Binding KdvOraniMetni, UpdateSourceTrigger=LostFocus}" Width="64" />
        <DataGridTextColumn Header="Satır Toplam" Binding="{Binding SatirToplamMetni}" Width="110" IsReadOnly="True" />
      </DataGrid.Columns>
    </DataGrid>

    <Border Grid.Row="3" Background="#FAFBFC" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
            CornerRadius="10" Padding="12,10" Margin="0,0,0,16">
      <Grid>
        <TextBlock x:Name="TxtKurBilgi" FontSize="11" Foreground="{StaticResource InkMutedBrush}" VerticalAlignment="Center" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <TextBlock x:Name="TxtAraToplam" Margin="0,0,16,0" FontSize="12" VerticalAlignment="Center" />
          <TextBlock x:Name="TxtKdvToplam" Margin="0,0,16,0" FontSize="12" VerticalAlignment="Center" />
          <TextBlock x:Name="TxtGenelToplam" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" />
        </StackPanel>
      </Grid>
    </Border>

    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"
              Content="İptal" Click="Iptal_Click" />
      <Button Style="{StaticResource PrimaryToolbarButtonStyle}"
              Content="Kaydet" Click="Kaydet_Click" />
    </StackPanel>
  </Grid>
</Window>
