<UserControl x:Class="SatinalmaPro.Views.Modules.AkaryakitView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:helpers="clr-namespace:SatinalmaPro.Helpers"
             xmlns:controls="clr-namespace:SatinalmaPro.Views.Controls">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="12" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="12" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" CornerRadius="14" Padding="20,18" BorderThickness="1"
              Background="#ECFDF5" BorderBrush="#10B981">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="#10B981" Margin="0,0,14,0">
            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock Text="Gelen Akaryakıt" FontSize="12" Foreground="#047857" FontWeight="SemiBold" />
            <TextBlock x:Name="TxtGelenAkaryakit" Text="0 Lt" FontSize="28" FontWeight="Bold"
                       Foreground="#059669" Margin="0,4,0,0" />
            <TextBlock x:Name="TxtGelenKayit" Text="0 alım kaydı" FontSize="11" Foreground="#6B7280" Margin="0,2,0,0" />
          </StackPanel>
        </Grid>
      </Border>

      <Border Grid.Column="2" CornerRadius="14" Padding="20,18" BorderThickness="1"
              Background="#EFF6FF" BorderBrush="#3B82F6">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="#3B82F6" Margin="0,0,14,0">
            <TextBlock Text="&#xE7C5;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock Text="Stok Akaryakıt" FontSize="12" Foreground="#1D4ED8" FontWeight="SemiBold" />
            <TextBlock x:Name="TxtStokAkaryakit" Text="0 Lt" FontSize="28" FontWeight="Bold"
                       Foreground="#2563EB" Margin="0,4,0,0" />
            <TextBlock x:Name="TxtStokDurum" Text="Gelen − dağıtılan" FontSize="11" Foreground="#6B7280" Margin="0,2,0,0" />
          </StackPanel>
        </Grid>
      </Border>

      <Border Grid.Column="4" CornerRadius="14" Padding="20,18" BorderThickness="1"
              Background="#FFFBEB" BorderBrush="#F59E0B">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="#F59E0B" Margin="0,0,14,0">
            <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock Text="Dağıtılan Akaryakıt" FontSize="12" Foreground="#B45309" FontWeight="SemiBold" />
            <TextBlock x:Name="TxtDagitilanAkaryakit" Text="0 Lt" FontSize="28" FontWeight="Bold"
                       Foreground="#D97706" Margin="0,4,0,0" />
            <TextBlock x:Name="TxtDagitilanKayit" Text="0 dağıtım kaydı" FontSize="11" Foreground="#6B7280" Margin="0,2,0,0" />
          </StackPanel>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
            CornerRadius="14" Padding="14,12" Margin="0,0,0,12">
      <Grid>
        <StackPanel Orientation="Horizontal">
          <Button Style="{StaticResource PrimaryToolbarButtonStyle}" Click="ExcelYukle_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Excel Yükle" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="SablonIndir_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Şablon İndir" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="PdfIndir_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="PDF İndir" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="PdfYazdir_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="PDF Yazdır" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="YeniKayit_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Yeni Kayıt" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="DisaAktar_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Dışa Aktar" />
            </StackPanel>
          </Button>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Style="{StaticResource ToolbarButtonStyle}" Margin="0" Click="Yenile_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Yenile" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
            CornerRadius="14" Padding="14,12,30,12" Margin="0,0,0,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" MinWidth="180" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,10,0">
          <TextBlock Text="Ara" Style="{StaticResource FilterLabelStyle}" />
          <Grid>
            <TextBox x:Name="TxtArama" Style="{StaticResource FilterBoxStyle}" TextChanged="FiltreDegisti"
                     ui:ControlHelper.PlaceholderText="Plaka, tedarikçi, şoför, teslim alan ara..." />
            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                       Foreground="{StaticResource InkMutedBrush}" HorizontalAlignment="Right"
                       VerticalAlignment="Center" Margin="0,0,12,0" IsHitTestVisible="False" />
          </Grid>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="0,0,8,0">
          <TextBlock Text="Başlangıç" Style="{StaticResource FilterLabelStyle}" />
          <DatePicker x:Name="DpBaslangic" Width="130" SelectedDateChanged="FiltreDegisti" />
        </StackPanel>

        <StackPanel Grid.Column="2" Margin="0,0,8,0">
          <TextBlock Text="Bitiş" Style="{StaticResource FilterLabelStyle}" />
          <DatePicker x:Name="DpBitis" Width="130" SelectedDateChanged="FiltreDegisti" />
        </StackPanel>

        <StackPanel Grid.Column="3" Margin="0,0,8,0">
          <TextBlock Text="Kayıt Tipi" Style="{StaticResource FilterLabelStyle}" />
          <ComboBox x:Name="CmbKayitTipi" Style="{StaticResource FilterComboStyle}"
                    Width="115" SelectionChanged="FiltreDegisti" />
        </StackPanel>

        <StackPanel Grid.Column="4" Margin="0,0,8,0">
          <TextBlock Text="Araç Tipi" Style="{StaticResource FilterLabelStyle}" />
          <ComboBox x:Name="CmbAracTipi" Style="{StaticResource FilterComboStyle}"
                    Width="110" SelectionChanged="FiltreDegisti" />
        </StackPanel>

        <StackPanel Grid.Column="5" Margin="0,0,8,0">
          <TextBlock Text="Yakıt Türü" Style="{StaticResource FilterLabelStyle}" />
          <ComboBox x:Name="CmbYakitTuru" Style="{StaticResource FilterComboStyle}"
                    Width="100" SelectionChanged="FiltreDegisti" />
        </StackPanel>

        <StackPanel Grid.Column="6" Margin="0,0,8,0">
          <TextBlock Text="Plaka / Kod" Style="{StaticResource FilterLabelStyle}" />
          <ComboBox x:Name="CmbPlaka" Style="{StaticResource FilterComboStyle}"
                    Width="120" SelectionChanged="FiltreDegisti" />
        </StackPanel>

        <Button Grid.Column="7" Style="{StaticResource ToolbarButtonStyle}" Margin="0"
                VerticalAlignment="Bottom" Content="Filtreleri Temizle" Click="FiltreleriTemizle_Click" />
      </Grid>
    </Border>

    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12">
      <Border Style="{StaticResource StatChipStyle}">
        <StackPanel>
          <TextBlock Text="Toplam Kayıt" FontSize="11" Foreground="{StaticResource InkMutedBrush}" />
          <TextBlock x:Name="TxtToplamKayit" Text="0" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" Margin="0,2,0,0" />
        </StackPanel>
      </Border>
      <Border Style="{StaticResource StatChipStyle}">
        <StackPanel>
          <TextBlock Text="Alınan Tutar" FontSize="11" Foreground="{StaticResource InkMutedBrush}" />
          <TextBlock x:Name="TxtToplamTutar" Text="₺0" FontSize="22" FontWeight="SemiBold" Foreground="#F59E0B" Margin="0,2,0,0" />
        </StackPanel>
      </Border>
      <Border Style="{StaticResource StatChipStyle}" Margin="0">
        <StackPanel>
          <TextBlock Text="Filtrelenen" FontSize="11" Foreground="{StaticResource InkMutedBrush}" />
          <TextBlock x:Name="TxtFiltrelenen" Text="0 kayıt" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" Margin="0,2,0,0" />
        </StackPanel>
      </Border>
    </StackPanel>

    <Border Grid.Row="4" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
            CornerRadius="14" Padding="14,12,30,12" Margin="0,0,0,12">
      <StackPanel Orientation="Horizontal">
        <Button x:Name="BtnKayitDuzenle" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"
                IsEnabled="False" Click="KayitDuzenle_Click" Content="Düzenle" />
        <Button x:Name="BtnKayitSil" Style="{StaticResource ToolbarButtonStyle}" Margin="0"
                IsEnabled="False" Click="KayitSil_Click" Content="Sil" />
      </StackPanel>
    </Border>

    <Border Grid.Row="5" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
            CornerRadius="14" Padding="1">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
      <DataGrid x:Name="YakitGrid" Grid.Row="0" Style="{StaticResource ModuleDataGridStyle}"
                AlternatingRowBackground="Transparent"                 LoadingRow="YakitGrid_LoadingRow"
                SelectionChanged="YakitGrid_SelectionChanged"
                MouseDoubleClick="YakitGrid_MouseDoubleClick" ScrollViewer.HorizontalScrollBarVisibility="Auto">
        <DataGrid.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Düzenle" Click="MenuDuzenle_Click" />
            <Separator />
            <MenuItem Header="Sil" Click="MenuSil_Click" />
          </ContextMenu>
        </DataGrid.ContextMenu>
        <DataGrid.Columns>
          <DataGridTextColumn Header="Kayıt Tipi" Binding="{Binding KayitTipi}" Width="90" />
          <DataGridTextColumn Header="Tarih" Binding="{Binding Tarih}" Width="95" />
          <DataGridTextColumn Header="Miktar" Binding="{Binding MiktarMetin}" Width="90" />
          <DataGridTextColumn Header="Birim" Binding="{Binding BirimMetin}" Width="55" />
          <DataGridTextColumn Header="Birim Fiyatı" Binding="{Binding BirimFiyatiMetin}" Width="100" />
          <DataGridTextColumn Header="Toplam Tutar" Binding="{Binding ToplamTutarMetin}" Width="110" />
          <DataGridTextColumn Header="Tedarikçi" Binding="{Binding TedarikciMetin}" Width="120" />
          <DataGridTextColumn Header="Teslim Alan" Binding="{Binding TeslimAlanMetin}" Width="110" />
          <DataGridTextColumn Header="Plaka" Binding="{Binding PlakaMetin}" Width="100" />
          <DataGridTextColumn Header="Araç Tipi" Binding="{Binding AracTipiMetin}" Width="95" />
          <DataGridTextColumn Header="Araç / Makine" Binding="{Binding AracMakineMetin}" Width="130" />
          <DataGridTextColumn Header="Yakıt" Binding="{Binding YakitTuruMetin}" Width="75" />
          <DataGridTextColumn Header="Km" Binding="{Binding KmSayaciMetin}" Width="75" />
          <DataGridTextColumn Header="Saat" Binding="{Binding SaatSayaciMetin}" Width="75" />
          <DataGridTextColumn Header="Şoför" Binding="{Binding SoforMetin}" Width="110" />
          <DataGridTextColumn Header="Saha" Binding="{Binding SahaMetin}" Width="100" />
          <DataGridTextColumn Header="L/100km" Binding="{Binding Tuketim100KmMetin}" Width="95" />
          <DataGridTextColumn Header="Lt/Saat" Binding="{Binding TuketimSaatMetin}" Width="90" />
          <DataGridTextColumn Header="Açıklama" Binding="{Binding AciklamaMetin}" Width="*" MinWidth="120" />
        </DataGrid.Columns>
      </DataGrid>
      <controls:SayfalamaCubugu x:Name="SayfalamaBar" Grid.Row="1" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
