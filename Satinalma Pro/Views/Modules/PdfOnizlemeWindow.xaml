<Window x:Class="SatinalmaPro.Views.Modules.PdfOnizlemeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        ui:WindowHelper.UseModernWindowStyle="True"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        Title="PDF Önizleme"
        Width="920"
        Height="720"
        MinWidth="720"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource DashBackgroundBrush}">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,12">
      <TextBlock x:Name="TxtBaslik" FontSize="18" FontWeight="SemiBold" />
      <TextBlock x:Name="TxtAlt" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,4,0,0" />
    </StackPanel>

    <Border Grid.Row="1" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="10">
      <wv2:WebView2 x:Name="PdfGoruntuleyici" />
    </Border>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
      <Button Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"
              Click="Kapat_Click" Content="Kapat" />
      <Button Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"
              Click="Yazdir_Click" Content="Yazdır" />
      <Button Style="{StaticResource PrimaryToolbarButtonStyle}"
              Click="Indir_Click" Content="İndir" />
    </StackPanel>
  </Grid>
</Window>
