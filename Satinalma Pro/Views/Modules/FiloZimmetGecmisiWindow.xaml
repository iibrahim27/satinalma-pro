<Window x:Class="SatinalmaPro.Views.Modules.FiloZimmetGecmisiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Zimmet PDF Geçmişi"
        Width="760" Height="480" MinWidth="640" MinHeight="400"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" Background="White">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,12">
      <TextBlock x:Name="TxtBaslik" FontSize="20" FontWeight="SemiBold" />
      <TextBlock Text="Kayıtlı zimmet formlarını görüntüleyebilir veya yeniden yazdırabilirsiniz."
                 FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
      <TextBlock x:Name="TxtKlasor" FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,6,0,0"
                 TextWrapping="Wrap" />
    </StackPanel>

    <DataGrid x:Name="ZimmetGrid" Grid.Row="1" Style="{StaticResource ModuleDataGridStyle}"
              AlternatingRowBackground="Transparent" IsReadOnly="True" AutoGenerateColumns="False"
              SelectionMode="Single" SelectionChanged="ZimmetGrid_SelectionChanged"
              MouseDoubleClick="ZimmetGrid_MouseDoubleClick">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Şoför" Binding="{Binding SoforAdi}" Width="*" MinWidth="140" />
        <DataGridTextColumn Header="Zimmet Tarihi" Binding="{Binding Tarih}" Width="105" />
        <DataGridTextColumn Header="Durum" Binding="{Binding DurumMetin}" Width="110" />
        <DataGridTextColumn Header="PDF Dosyası" Binding="{Binding PdfDurumMetin}" Width="180" />
      </DataGrid.Columns>
    </DataGrid>

    <Grid Grid.Row="2" Margin="0,16,0,0">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
        <Button Style="{StaticResource ToolbarButtonStyle}" Content="Klasörü Aç" Click="KlasoruAc_Click" />
      </StackPanel>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="BtnPdfAc" Style="{StaticResource ToolbarButtonStyle}" Content="PDF Aç"
                Width="100" Margin="0,0,8,0" IsEnabled="False" Click="PdfAc_Click" />
        <Button x:Name="BtnPdfYazdir" Style="{StaticResource ToolbarButtonStyle}" Content="Yazdır"
                Width="100" Margin="0,0,8,0" IsEnabled="False" Click="PdfYazdir_Click" />
        <Button Content="Kapat" Style="{StaticResource ToolbarButtonStyle}" Width="100" Click="Kapat_Click" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>
