<UserControl x:Class="SatinalmaPro.Views.Modules.StokYonetimiView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:controls="clr-namespace:SatinalmaPro.Views.Controls">
  <UserControl.Resources>
    <Style x:Key="StokNavActiveStyle" TargetType="Button" BasedOn="{StaticResource SatinalmaNavPillStyle}">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border CornerRadius="10" Padding="{TemplateBinding Padding}">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                  <GradientStop Color="#14B8A6" Offset="0" />
                  <GradientStop Color="#2DD4BF" Offset="1" />
                </LinearGradientBrush>
              </Border.Background>
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Üst şerit -->
    <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
            CornerRadius="14" Padding="14,12" Margin="0,0,0,12">
      <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,14,0">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#14B8A6" Offset="0" />
                <GradientStop Color="#2DD4BF" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>
            <TextBlock Text="&#xE7BF;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
            <TextBlock Text="Stok Yönetimi" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
            <TextBlock Text="Depo stok takibi ve hareket yönetimi" FontSize="11"
                       Foreground="{StaticResource InkMutedBrush}" Margin="0,2,0,0" />
          </StackPanel>
          <Border Background="#F8FAFC" CornerRadius="10" Padding="4" BorderBrush="{StaticResource LineBrush}" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
              <Button x:Name="BtnNavDurum" Style="{StaticResource StokNavActiveStyle}" Content="Stok Durumu" Click="NavDurum_Click" />
              <Button x:Name="BtnNavHareket" Style="{StaticResource SatinalmaNavPillStyle}" Content="Stok Hareketleri" Click="NavHareket_Click" />
              <Button x:Name="BtnNavSayim" Style="{StaticResource SatinalmaNavPillStyle}" Content="Stok Sayım" Click="NavSayim_Click" />
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
          <Button x:Name="BtnStokGiris" Style="{StaticResource PrimaryToolbarButtonStyle}" Margin="0,0,8,0" Click="StokGiris_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Stok Girişi" />
            </StackPanel>
          </Button>
          <Button x:Name="BtnStokCikis" Style="{StaticResource ToolbarButtonStyle}" Click="StokCikis_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE738;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Stok Çıkışı" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- STOK DURUMU -->
    <Grid x:Name="PanelDurum" Grid.Row="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
              CornerRadius="14" Padding="14,12" Margin="0,0,0,12">
        <StackPanel Orientation="Horizontal">
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="PdfIndir_Click" Margin="0,0,8,0" Content="PDF İndir" />
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="DisaAktar_Click" Margin="0,0,8,0" Content="Excel Dışa Aktar" />
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="YeniDurumKayit_Click" Content="Yeni Stok Kalemi" />
          <Button Style="{StaticResource ToolbarButtonStyle}" Margin="8,0,0,0" Click="Yenile_Click" Content="Yenile" />
        </StackPanel>
      </Border>
      <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
              CornerRadius="14" Padding="14,12" Margin="0,0,0,12">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="180" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" Margin="0,0,10,0">
            <TextBlock Text="Ara" Style="{StaticResource FilterLabelStyle}" />
            <TextBox x:Name="TxtArama" Style="{StaticResource FilterBoxStyle}" TextChanged="FiltreDegisti"
                     ui:ControlHelper.PlaceholderText="Malzeme, depo veya kategori ara..." />
          </StackPanel>
          <StackPanel Grid.Column="1" Margin="0,0,8,0">
            <TextBlock Text="Kategori" Style="{StaticResource FilterLabelStyle}" />
            <ComboBox x:Name="CmbKategori" Style="{StaticResource FilterComboStyle}" Width="140" SelectionChanged="FiltreDegisti" />
          </StackPanel>
          <StackPanel Grid.Column="2" Margin="0,0,8,0">
            <TextBlock Text="Depo / Saha" Style="{StaticResource FilterLabelStyle}" />
            <ComboBox x:Name="CmbDepoSaha" Style="{StaticResource FilterComboStyle}" Width="150" SelectionChanged="FiltreDegisti" />
          </StackPanel>
          <StackPanel Grid.Column="3">
            <TextBlock Text="Durum" Style="{StaticResource FilterLabelStyle}" />
            <ComboBox x:Name="CmbDurum" Style="{StaticResource FilterComboStyle}" Width="110" SelectionChanged="FiltreDegisti" />
          </StackPanel>
        </Grid>
      </Border>
      <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
        <Border Style="{StaticResource StatChipStyle}">
          <StackPanel>
            <TextBlock Text="Toplam Kalem" FontSize="11" Foreground="{StaticResource InkMutedBrush}" />
            <TextBlock x:Name="TxtToplamKalem" Text="0" FontSize="22" FontWeight="SemiBold" />
          </StackPanel>
        </Border>
        <Border Style="{StaticResource StatChipStyle}">
          <StackPanel>
            <TextBlock Text="Toplam Değer" FontSize="11" Foreground="{StaticResource InkMutedBrush}" />
            <TextBlock x:Name="TxtToplamDeger" Text="₺0" FontSize="22" FontWeight="SemiBold" Foreground="#14B8A6" />
          </StackPanel>
        </Border>
        <Border Style="{StaticResource StatChipStyle}">
          <StackPanel>
            <TextBlock Text="Kritik" FontSize="11" Foreground="{StaticResource InkMutedBrush}" />
            <TextBlock x:Name="TxtKritikStok" Text="0" FontSize="22" FontWeight="SemiBold" Foreground="#F59E0B" />
          </StackPanel>
        </Border>
        <Border Style="{StaticResource StatChipStyle}" Margin="0">
          <StackPanel>
            <TextBlock Text="Tükenen" FontSize="11" Foreground="{StaticResource InkMutedBrush}" />
            <TextBlock x:Name="TxtTukenen" Text="0" FontSize="22" FontWeight="SemiBold" Foreground="#EF4444" />
          </StackPanel>
        </Border>
      </StackPanel>
      <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
              CornerRadius="14" Padding="14,10" Margin="0,0,0,12">
        <StackPanel Orientation="Horizontal">
          <Button x:Name="BtnKayitDuzenle" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"
                  IsEnabled="False" Click="KayitDuzenle_Click" Content="Düzenle" />
          <Button x:Name="BtnKayitSil" Style="{StaticResource ToolbarButtonStyle}"
                  IsEnabled="False" Click="KayitSil_Click" Content="Sil" />
        </StackPanel>
      </Border>
      <Border Grid.Row="4" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
              CornerRadius="14" Padding="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
        <DataGrid x:Name="StokGrid" Grid.Row="0" Style="{StaticResource ModuleDataGridStyle}"
                  AlternatingRowBackground="Transparent" LoadingRow="StokGrid_LoadingRow"
                  SelectionChanged="StokGrid_SelectionChanged" MouseDoubleClick="StokGrid_MouseDoubleClick">
          <DataGrid.ContextMenu>
            <ContextMenu>
              <MenuItem Header="Düzenle" Click="KayitDuzenle_Click" />
              <Separator />
              <MenuItem Header="Sil" Click="KayitSil_Click" />
            </ContextMenu>
          </DataGrid.ContextMenu>
          <DataGrid.Columns>
            <DataGridTextColumn Header="Malzeme" Binding="{Binding MalzemeAdi}" Width="150" />
            <DataGridTextColumn Header="Kategori" Binding="{Binding Kategori}" Width="100" />
            <DataGridTextColumn Header="Mevcut" Binding="{Binding MevcutMiktar, StringFormat=N2}" Width="80" />
            <DataGridTextColumn Header="Min." Binding="{Binding MinimumStok, StringFormat=N2}" Width="70" />
            <DataGridTextColumn Header="Birim" Binding="{Binding Birim}" Width="60" />
            <DataGridTextColumn Header="Depo" Binding="{Binding DepoSaha}" Width="110" />
            <DataGridTextColumn Header="Birim Maliyet" Binding="{Binding BirimMaliyet, StringFormat='₺{0:N2}'}" Width="100" />
            <DataGridTextColumn Header="Toplam Değer" Binding="{Binding ToplamDeger, StringFormat='₺{0:N2}'}" Width="105" />
            <DataGridTextColumn Header="Durum" Binding="{Binding DurumMetin}" Width="70" />
            <DataGridTextColumn Header="Son Günc." Binding="{Binding SonGuncelleme}" Width="90" />
            <DataGridTextColumn Header="Açıklama" Binding="{Binding Aciklama}" Width="*" MinWidth="100" />
          </DataGrid.Columns>
        </DataGrid>
        <controls:SayfalamaCubugu x:Name="StokSayfalamaBar" Grid.Row="1" />
        </Grid>
      </Border>
    </Grid>

    <!-- STOK HAREKETLERİ -->
    <Grid x:Name="PanelHareket" Grid.Row="1" Visibility="Collapsed">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
              CornerRadius="14" Padding="14,12" Margin="0,0,0,12">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="160" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" Margin="0,0,10,0">
            <TextBlock Text="Ara" Style="{StaticResource FilterLabelStyle}" />
            <TextBox x:Name="TxtHareketAra" Style="{StaticResource FilterBoxStyle}"
                     TextChanged="HareketFiltreDegisti"
                     ui:ControlHelper.PlaceholderText="Malzeme, belge veya açıklama..." />
          </StackPanel>
          <StackPanel Grid.Column="1" Margin="0,0,8,0">
            <TextBlock Text="Hareket Tipi" Style="{StaticResource FilterLabelStyle}" />
            <ComboBox x:Name="CmbHareketTip" Style="{StaticResource FilterComboStyle}" Width="120"
                      SelectionChanged="HareketFiltreDegisti" />
          </StackPanel>
          <StackPanel Grid.Column="2" Margin="0,0,8,0">
            <TextBlock Text="Depo / Saha" Style="{StaticResource FilterLabelStyle}" />
            <ComboBox x:Name="CmbHareketDepo" Style="{StaticResource FilterComboStyle}" Width="140"
                      SelectionChanged="HareketFiltreDegisti" />
          </StackPanel>
          <Button Grid.Column="3" Style="{StaticResource ToolbarButtonStyle}" VerticalAlignment="Bottom"
                  Content="Temizle" Click="HareketFiltreTemizle_Click" />
        </Grid>
      </Border>
      <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
              CornerRadius="14" Padding="1">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
        <DataGrid x:Name="HareketGrid" Grid.Row="0" Style="{StaticResource ModuleDataGridStyle}"
                  AlternatingRowBackground="Transparent" IsReadOnly="True"
                  MouseDoubleClick="HareketGrid_MouseDoubleClick"
                  PreviewMouseRightButtonDown="HareketGrid_PreviewMouseRightButtonDown">
          <DataGrid.ContextMenu>
            <ContextMenu>
              <MenuItem Header="Düzenle" Click="HareketDuzenle_Click" />
              <Separator />
              <MenuItem Header="Sil" Click="HareketSil_Click" />
            </ContextMenu>
          </DataGrid.ContextMenu>
          <DataGrid.Columns>
            <DataGridTextColumn Header="Tarih" Binding="{Binding Tarih}" Width="90" />
            <DataGridTextColumn Header="Tip" Binding="{Binding HareketTipi}" Width="70" />
            <DataGridTextColumn Header="Malzeme" Binding="{Binding MalzemeAdi}" Width="130" />
            <DataGridTextColumn Header="Miktar" Binding="{Binding MiktarGosterim}" Width="110" />
            <DataGridTextColumn Header="Birim" Binding="{Binding Birim}" Width="55" />
            <DataGridTextColumn Header="Depo" Binding="{Binding DepoSaha}" Width="100" />
            <DataGridTextColumn Header="Belge No" Binding="{Binding BelgeNo}" Width="85" />
            <DataGridTextColumn Header="İşlem Yapan" Binding="{Binding IslemYapan}" Width="100" />
            <DataGridTextColumn Header="Açıklama" Binding="{Binding Aciklama}" Width="*" MinWidth="120" />
          </DataGrid.Columns>
        </DataGrid>
        <controls:SayfalamaCubugu x:Name="HareketSayfalamaBar" Grid.Row="1" />
        </Grid>
      </Border>
    </Grid>

    <!-- STOK SAYIM -->
    <ScrollViewer x:Name="PanelSayim" Grid.Row="1" Visibility="Collapsed"
                  Style="{StaticResource ModuleScrollViewerStyle}" Padding="0,0,18,0">
      <StackPanel>
        <Border Style="{StaticResource SatinalmaCardStyle}" Margin="0,0,0,12">
          <StackPanel>
            <TextBlock Text="Stok Sayımı" Style="{StaticResource SatinalmaSectionTitleStyle}" Margin="0,0,0,12" />
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                <TextBlock Text="Tarih" Style="{StaticResource FilterLabelStyle}" />
                <TextBox x:Name="TxtSayimTarih" Style="{StaticResource FilterBoxStyle}" />
              </StackPanel>
              <StackPanel Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="3" Margin="0,0,0,10">
                <TextBlock Text="Sayım Yapılacak Stok" Style="{StaticResource FilterLabelStyle}" />
                <ComboBox x:Name="CmbSayimStok" Style="{StaticResource FilterComboStyle}"
                          SelectionChanged="SayimStokSecildi" DisplayMemberPath="SecimMetni" />
              </StackPanel>
              <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
                <TextBlock Text="Sistemdeki Miktar" Style="{StaticResource FilterLabelStyle}" />
                <TextBox x:Name="TxtSayimMevcut" Style="{StaticResource FilterBoxStyle}" IsReadOnly="True" Background="#F8FAFC" />
              </StackPanel>
              <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,10">
                <TextBlock Text="Sayım Miktarı" Style="{StaticResource FilterLabelStyle}" />
                <TextBox x:Name="TxtSayimMiktar" Style="{StaticResource FilterBoxStyle}" TextChanged="SayimFarkHesapla" />
              </StackPanel>
              <StackPanel Grid.Row="1" Grid.Column="4" Margin="0,0,0,10">
                <TextBlock Text="Fark" Style="{StaticResource FilterLabelStyle}" />
                <TextBox x:Name="TxtSayimFark" Style="{StaticResource FilterBoxStyle}" IsReadOnly="True" Background="#F8FAFC" />
              </StackPanel>
            </Grid>
            <TextBlock Text="İşlem Yapan" Style="{StaticResource FilterLabelStyle}" />
            <TextBox x:Name="TxtSayimIslemYapan" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,10" />
            <TextBlock Text="Açıklama" Style="{StaticResource FilterLabelStyle}" />
            <TextBox x:Name="TxtSayimAciklama" Style="{StaticResource FilterBoxStyle}" Height="60"
                     TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="12,10" Margin="0,0,0,12" />
            <Button Style="{StaticResource PrimaryToolbarButtonStyle}" HorizontalAlignment="Left"
                    Content="Sayımı Kaydet" Click="SayimKaydet_Click" />
          </StackPanel>
        </Border>
        <Border Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="14" Padding="1">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
          <DataGrid x:Name="SayimGrid" Grid.Row="0" Style="{StaticResource ModuleDataGridStyle}" Height="320"
                    AlternatingRowBackground="Transparent" IsReadOnly="True">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Tarih" Binding="{Binding Tarih}" Width="90" />
              <DataGridTextColumn Header="Malzeme" Binding="{Binding MalzemeAdi}" Width="140" />
              <DataGridTextColumn Header="Sayım" Binding="{Binding MiktarGosterim}" Width="130" />
              <DataGridTextColumn Header="Depo" Binding="{Binding DepoSaha}" Width="110" />
              <DataGridTextColumn Header="İşlem Yapan" Binding="{Binding IslemYapan}" Width="110" />
              <DataGridTextColumn Header="Açıklama" Binding="{Binding Aciklama}" Width="*" MinWidth="120" />
            </DataGrid.Columns>
          </DataGrid>
          <controls:SayfalamaCubugu x:Name="SayimSayfalamaBar" Grid.Row="1" />
          </Grid>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
