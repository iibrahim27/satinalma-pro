<UserControl x:Class="SatinalmaPro.Views.Modules.StokYonetimiView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:controls="clr-namespace:SatinalmaPro.Views.Controls"
             Background="{StaticResource ErpBgBrush}">
  <UserControl.Resources>
    <Style x:Key="StokNavActiveStyle" TargetType="Button" BasedOn="{StaticResource ErpNavPillActive}" />
  </UserControl.Resources>

  <Grid Margin="24,20,24,20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" MinHeight="400" />
    </Grid.RowDefinitions>

    <!-- Üst bar -->
    <Grid Grid.Row="0" Margin="0,0,0,20">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel VerticalAlignment="Center">
        <TextBlock Text="Stok Yönetimi" Style="{StaticResource ErpPageTitle}" />
        <TextBlock Text="Ana Sayfa  ›  Stok Yönetimi" Style="{StaticResource ErpBreadcrumb}" Margin="0,6,0,0" />
        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
          <Border Background="White" CornerRadius="12" Padding="4" BorderBrush="{StaticResource ErpCardBorderBrush}" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
              <Button x:Name="BtnNavDurum" Style="{StaticResource StokNavActiveStyle}" Content="Stok Durumu" Click="NavDurum_Click" />
              <Button x:Name="BtnNavHareket" Style="{StaticResource ErpNavPill}" Content="Stok Hareketleri" Click="NavHareket_Click" />
              <Button x:Name="BtnNavSayim" Style="{StaticResource ErpNavPill}" Content="Stok Sayım" Click="NavSayim_Click" />
            </StackPanel>
          </Border>
        </StackPanel>
      </StackPanel>
      <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
        <Button x:Name="BtnDepoTopluGiris" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,8" Padding="14,9" Click="DepoTopluGiris_Click">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
            <TextBlock Text="Depo Stok Girişi" />
          </StackPanel>
        </Button>
        <Button x:Name="BtnStokGiris" Style="{StaticResource PrimaryToolbarButtonStyle}" Margin="0,0,8,8" Padding="14,9" Click="StokGiris_Click">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
            <TextBlock Text="Stok Girişi" />
          </StackPanel>
        </Button>
        <Button x:Name="BtnStokCikis" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,8" Padding="14,9" Click="StokCikis_Click">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE738;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
            <TextBlock Text="Stok Çıkışı" />
          </StackPanel>
        </Button>
        <Button Style="{StaticResource ErpIconBtn}" Click="Yenile_Click" ToolTip="Yenile">
          <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource DashTextSecondaryBrush}" />
        </Button>
      </WrapPanel>
    </Grid>

    <!-- STOK DURUMU -->
    <Grid x:Name="PanelDurum" Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="260" MinWidth="220" />
        <ColumnDefinition Width="16" />
        <ColumnDefinition Width="*" MinWidth="480" />
      </Grid.ColumnDefinitions>

      <!-- Kategori ağacı -->
      <Border x:Name="StokSolPanel" Grid.Column="0" Style="{StaticResource ErpTreePanel}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <TextBlock Text="Kategori Ağacı" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource DashTextBrush}" Margin="0,0,0,12" />
          <Grid Grid.Row="1" Margin="0,0,0,12">
            <TextBox x:Name="TxtKategoriAra" Style="{StaticResource FilterBoxStyle}" Height="36"
                     TextChanged="KategoriAraDegisti"
                     ui:ControlHelper.PlaceholderText="Kategori ara..." />
            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                       Foreground="{StaticResource InkMutedBrush}" HorizontalAlignment="Right"
                       VerticalAlignment="Center" Margin="0,0,10,0" IsHitTestVisible="False" />
          </Grid>
          <TreeView x:Name="KategoriAgaci" Grid.Row="2" BorderThickness="0" Background="Transparent"
                    SelectedItemChanged="KategoriAgaci_SelectionChanged">
            <TreeView.ItemContainerStyle>
              <Style TargetType="TreeViewItem" BasedOn="{StaticResource ErpTreeItem}" />
            </TreeView.ItemContainerStyle>
          </TreeView>
        </Grid>
      </Border>

      <!-- Ana içerik -->
      <Grid x:Name="StokIcerikGrid" Grid.Column="2">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" MinHeight="280" />
        </Grid.RowDefinitions>

        <ScrollViewer x:Name="StokKpiScroll" Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,16">
          <StackPanel x:Name="StokKpiPanel" Orientation="Horizontal" />
        </ScrollViewer>

        <Border x:Name="StokFiltreKart" Grid.Row="1" Style="{StaticResource ErpCard}" Padding="16,14" Margin="0,0,0,16">
          <Grid>
            <TextBlock Text="Filtreleme" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
            <UniformGrid Columns="4" Margin="0,36,0,0">
              <StackPanel Margin="0,0,12,0">
                <TextBlock Text="Ara" Style="{StaticResource FilterLabelStyle}" />
                <TextBox x:Name="TxtArama" Style="{StaticResource FilterBoxStyle}" Height="36" TextChanged="FiltreDegisti"
                         ui:ControlHelper.PlaceholderText="Malzeme, depo, kategori..." />
              </StackPanel>
              <StackPanel Margin="0,0,12,0">
                <TextBlock Text="Kategori" Style="{StaticResource FilterLabelStyle}" />
                <ComboBox x:Name="CmbKategori" Style="{StaticResource FilterComboStyle}" Height="36" SelectionChanged="FiltreDegisti" />
              </StackPanel>
              <StackPanel Margin="0,0,12,0">
                <TextBlock Text="Depo / Saha" Style="{StaticResource FilterLabelStyle}" />
                <ComboBox x:Name="CmbDepoSaha" Style="{StaticResource FilterComboStyle}" Height="36" SelectionChanged="FiltreDegisti" />
              </StackPanel>
              <StackPanel>
                <TextBlock Text="Durum" Style="{StaticResource FilterLabelStyle}" />
                <ComboBox x:Name="CmbDurum" Style="{StaticResource FilterComboStyle}" Height="36" SelectionChanged="FiltreDegisti" />
              </StackPanel>
            </UniformGrid>
          </Grid>
        </Border>

        <Border x:Name="StokTabloKart" Grid.Row="2" Style="{StaticResource ErpCard}" Padding="0">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Style="{StaticResource ErpTableToolbar}">
              <Grid>
                <TextBlock x:Name="TxtStokTabloBaslik" Text="Stok Listesi" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                  <Button Style="{StaticResource ErpTableToolbarBtn}" Content="Kolonlar" Click="StokKolonlar_Click" />
                  <Button Style="{StaticResource ErpTableToolbarBtn}" Content="Grupla" Click="StokGrupla_Click" />
                  <Button Style="{StaticResource ErpTableToolbarBtn}" Content="Filtre" Click="StokFiltreOdak_Click" />
                  <Button Style="{StaticResource ErpTableToolbarBtn}" Content="Excel" Click="DisaAktar_Click" />
                  <Button Style="{StaticResource ErpTableToolbarBtn}" Content="PDF" Click="PdfIndir_Click" />
                  <Button Style="{StaticResource ErpTableToolbarBtn}" Content="Yeni Kalem" Click="YeniDurumKayit_Click" />
                  <Button Style="{StaticResource ErpTableToolbarBtn}" Content="Yoğun" Click="StokYogunGorunum_Click" ToolTip="Satır yüksekliği" />
                  <Button x:Name="BtnStokTamEkran" Style="{StaticResource ErpTableToolbarBtn}" Content="Tam Ekran" Click="StokTamEkran_Click" />
                </StackPanel>
              </Grid>
            </Border>
            <DataGrid x:Name="StokGrid" Grid.Row="1" Style="{StaticResource ErpPremiumGrid}"
                      CanUserReorderColumns="True"
                      LoadingRow="StokGrid_LoadingRow" SelectionChanged="StokGrid_SelectionChanged"
                      MouseDoubleClick="StokGrid_MouseDoubleClick">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Stok Kodu" Binding="{Binding StokKoduGoster}" Width="90" />
                <DataGridTextColumn Header="Stok Adı" Binding="{Binding MalzemeAdi}" Width="150" />
                <DataGridTextColumn Header="Kategori" Binding="{Binding Kategori}" Width="100" />
                <DataGridTextColumn Header="Birim" Binding="{Binding Birim}" Width="60" />
                <DataGridTextColumn Header="Mevcut" Binding="{Binding MevcutMiktar, StringFormat=N2}" Width="80" />
                <DataGridTextColumn Header="Minimum" Binding="{Binding MinimumStok, StringFormat=N2}" Width="80" />
                <DataGridTextColumn Header="Birim Fiyat" Binding="{Binding BirimMaliyet, StringFormat='₺{0:N2}'}" Width="100" />
                <DataGridTextColumn Header="Depo" Binding="{Binding DepoSaha}" Width="100" />
                <DataGridTemplateColumn Header="Durum" Width="90">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <Border CornerRadius="6" Padding="10,4" HorizontalAlignment="Center">
                        <Border.Style>
                          <Style TargetType="Border">
                            <Setter Property="Background" Value="#DCFCE7" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding DurumMetin}" Value="Kritik">
                                <Setter Property="Background" Value="#FEE2E2" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding DurumMetin}" Value="Düşük">
                                <Setter Property="Background" Value="#FEF3C7" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding DurumMetin}" Value="Tükendi">
                                <Setter Property="Background" Value="#F1F5F9" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding DurumRozetMetin}" FontSize="11" FontWeight="SemiBold">
                          <TextBlock.Style>
                            <Style TargetType="TextBlock">
                              <Setter Property="Foreground" Value="#16A34A" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding DurumMetin}" Value="Kritik">
                                  <Setter Property="Foreground" Value="#DC2626" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DurumMetin}" Value="Düşük">
                                  <Setter Property="Foreground" Value="#D97706" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DurumMetin}" Value="Tükendi">
                                  <Setter Property="Foreground" Value="#64748B" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                      </Border>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Son Güncelleme" Binding="{Binding SonGuncelleme}" Width="100" />
                <DataGridTemplateColumn Header="" Width="48">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <Button Style="{StaticResource ErpIconBtn}" Tag="{Binding}" Click="StokSatirMenu_Click">
                        <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource InkMutedBrush}" />
                      </Button>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
            <Border Grid.Row="2" Style="{StaticResource ErpFooterBar}">
              <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <TextBlock Style="{StaticResource ErpFooterText}" Text="Toplam Kalem:" />
                  <TextBlock x:Name="TxtAltKalem" Style="{StaticResource ErpFooterValue}" Text="0" />
                  <TextBlock Style="{StaticResource ErpFooterText}" Text="Toplam Değer:" />
                  <TextBlock x:Name="TxtAltDeger" Style="{StaticResource ErpFooterValue}" Text="₺0" />
                  <TextBlock x:Name="TxtStokGrupBilgi" Style="{StaticResource ErpFooterText}" Margin="12,0,0,0" Visibility="Collapsed" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                  <TextBlock Text="Sayfa boyutu:" Style="{StaticResource ErpFooterText}" Margin="0,0,8,0" />
                  <ComboBox x:Name="CmbStokSayfaBoyutu" Width="72" Height="28" VerticalContentAlignment="Center"
                            SelectionChanged="StokSayfaBoyutuDegisti">
                    <ComboBoxItem Content="25" Tag="25" />
                    <ComboBoxItem Content="50" Tag="50" IsSelected="True" />
                    <ComboBoxItem Content="100" Tag="100" />
                    <ComboBoxItem Content="200" Tag="200" />
                  </ComboBox>
                </StackPanel>
              </Grid>
            </Border>
            <controls:SayfalamaCubugu x:Name="StokSayfalamaBar" Grid.Row="3" />
          </Grid>
        </Border>
      </Grid>
    </Grid>

    <!-- STOK HAREKETLERİ -->
    <Grid x:Name="PanelHareket" Grid.Row="1" Visibility="Collapsed">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <Border Grid.Row="0" Style="{StaticResource ErpCard}" Padding="16" Margin="0,0,0,16">
        <UniformGrid Columns="4">
          <StackPanel Margin="0,0,12,0">
            <TextBlock Text="Ara" Style="{StaticResource FilterLabelStyle}" />
            <TextBox x:Name="TxtHareketAra" Style="{StaticResource FilterBoxStyle}" Height="36"
                     TextChanged="HareketFiltreDegisti" ui:ControlHelper.PlaceholderText="Malzeme, belge..." />
          </StackPanel>
          <StackPanel Margin="0,0,12,0">
            <TextBlock Text="Hareket Tipi" Style="{StaticResource FilterLabelStyle}" />
            <ComboBox x:Name="CmbHareketTip" Style="{StaticResource FilterComboStyle}" Height="36" SelectionChanged="HareketFiltreDegisti" />
          </StackPanel>
          <StackPanel Margin="0,0,12,0">
            <TextBlock Text="Depo" Style="{StaticResource FilterLabelStyle}" />
            <ComboBox x:Name="CmbHareketDepo" Style="{StaticResource FilterComboStyle}" Height="36" SelectionChanged="HareketFiltreDegisti" />
          </StackPanel>
          <Button Style="{StaticResource ToolbarButtonStyle}" VerticalAlignment="Bottom" Content="Temizle" Click="HareketFiltreTemizle_Click" />
        </UniformGrid>
      </Border>
      <Border Grid.Row="1" Style="{StaticResource ErpCard}" Padding="0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <DataGrid x:Name="HareketGrid" Style="{StaticResource ErpPremiumGrid}" IsReadOnly="True"
                    MouseDoubleClick="HareketGrid_MouseDoubleClick" PreviewMouseRightButtonDown="HareketGrid_PreviewMouseRightButtonDown">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Tarih" Binding="{Binding Tarih}" Width="90" />
              <DataGridTextColumn Header="Tip" Binding="{Binding HareketTipi}" Width="70" />
              <DataGridTextColumn Header="Malzeme" Binding="{Binding MalzemeAdi}" Width="130" />
              <DataGridTextColumn Header="Miktar" Binding="{Binding MiktarGosterim}" Width="110" />
              <DataGridTextColumn Header="Birim" Binding="{Binding Birim}" Width="55" />
              <DataGridTextColumn Header="Depo" Binding="{Binding DepoSaha}" Width="100" />
              <DataGridTextColumn Header="Belge No" Binding="{Binding BelgeNo}" Width="85" />
              <DataGridTextColumn Header="İşlem Yapan" Binding="{Binding IslemYapan}" Width="100" />
              <DataGridTextColumn Header="Açıklama" Binding="{Binding Aciklama}" Width="*" MinWidth="120" />
            </DataGrid.Columns>
          </DataGrid>
          <controls:SayfalamaCubugu x:Name="HareketSayfalamaBar" Grid.Row="1" />
        </Grid>
      </Border>
    </Grid>

    <!-- STOK SAYIM -->
    <ScrollViewer x:Name="PanelSayim" Grid.Row="1" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <Border Style="{StaticResource ErpCard}" Margin="0,0,0,16" Padding="22">
          <StackPanel>
            <TextBlock Text="Stok Sayımı" Style="{StaticResource ErpPageTitle}" FontSize="18" Margin="0,0,0,16" />
            <UniformGrid Columns="3" Margin="0,0,0,12">
              <StackPanel Margin="0,0,12,12">
                <TextBlock Text="Tarih" Style="{StaticResource FilterLabelStyle}" />
                <TextBox x:Name="TxtSayimTarih" Style="{StaticResource FilterBoxStyle}" Height="36" />
              </StackPanel>
              <StackPanel Margin="0,0,12,12" Grid.ColumnSpan="2">
                <TextBlock Text="Sayım Yapılacak Stok" Style="{StaticResource FilterLabelStyle}" />
                <ComboBox x:Name="CmbSayimStok" Style="{StaticResource FilterComboStyle}" Height="36"
                          SelectionChanged="SayimStokSecildi" DisplayMemberPath="SecimMetni" />
              </StackPanel>
              <StackPanel Margin="0,0,12,0">
                <TextBlock Text="Sistemdeki Miktar" Style="{StaticResource FilterLabelStyle}" />
                <TextBox x:Name="TxtSayimMevcut" Style="{StaticResource ModuleReadOnlyFieldStyle}" Height="36" />
              </StackPanel>
              <StackPanel Margin="0,0,12,0">
                <TextBlock Text="Sayım Miktarı" Style="{StaticResource FilterLabelStyle}" />
                <TextBox x:Name="TxtSayimMiktar" Style="{StaticResource FilterBoxStyle}" Height="36" TextChanged="SayimFarkHesapla" />
              </StackPanel>
              <StackPanel>
                <TextBlock Text="Fark" Style="{StaticResource FilterLabelStyle}" />
                <TextBox x:Name="TxtSayimFark" Style="{StaticResource ModuleReadOnlyFieldStyle}" Height="36" />
              </StackPanel>
            </UniformGrid>
            <TextBlock Text="İşlem Yapan" Style="{StaticResource FilterLabelStyle}" />
            <TextBox x:Name="TxtSayimIslemYapan" Style="{StaticResource FilterBoxStyle}" Height="36" Margin="0,0,0,12" />
            <TextBlock Text="Açıklama" Style="{StaticResource FilterLabelStyle}" />
            <TextBox x:Name="TxtSayimAciklama" Style="{StaticResource FilterBoxStyle}" Height="64" TextWrapping="Wrap"
                     AcceptsReturn="True" VerticalContentAlignment="Top" Padding="12,10" Margin="0,0,0,16" />
            <Button Style="{StaticResource PrimaryToolbarButtonStyle}" HorizontalAlignment="Left" Padding="18,10"
                    Content="Sayımı Kaydet" Click="SayimKaydet_Click" />
          </StackPanel>
        </Border>
        <Border Style="{StaticResource ErpCard}" Padding="0">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <DataGrid x:Name="SayimGrid" Style="{StaticResource ErpPremiumGrid}" Height="320" IsReadOnly="True">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Tarih" Binding="{Binding Tarih}" Width="90" />
                <DataGridTextColumn Header="Malzeme" Binding="{Binding MalzemeAdi}" Width="140" />
                <DataGridTextColumn Header="Sayım" Binding="{Binding MiktarGosterim}" Width="130" />
                <DataGridTextColumn Header="Depo" Binding="{Binding DepoSaha}" Width="110" />
                <DataGridTextColumn Header="İşlem Yapan" Binding="{Binding IslemYapan}" Width="110" />
                <DataGridTextColumn Header="Açıklama" Binding="{Binding Aciklama}" Width="*" MinWidth="120" />
              </DataGrid.Columns>
            </DataGrid>
            <controls:SayfalamaCubugu x:Name="SayimSayfalamaBar" Grid.Row="1" />
          </Grid>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
