<UserControl x:Class="SatinalmaPro.Views.Modules.FinansmanRaporlamaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:helpers="clr-namespace:SatinalmaPro.Helpers" Background="{StaticResource DashBackgroundBrush}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Araç çubuğu -->
    <Border Grid.Row="0" Style="{StaticResource ModulePageCardStyle}" Padding="14,12" Margin="0,0,0,12">
      <Grid>
        <StackPanel Orientation="Horizontal">
          <Button Style="{StaticResource PrimaryToolbarButtonStyle}" Click="PdfIndir_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="PDF İndir" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="PdfYazdir_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="PDF Yazdır" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="ExcelAktar_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Excel Dışa Aktar" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="GelirSablon_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Gelir Şablon" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="GelirExcelYukle_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Gelir Excel Yükle" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="YeniGelir_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Yeni Gelir" />
            </StackPanel>
          </Button>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Style="{StaticResource ToolbarButtonStyle}" Margin="0" Click="Yenile_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Yenile" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Filtreler -->
    <Border Grid.Row="1" Style="{StaticResource ModulePageCardStyle}" Padding="14,12,30,12" Margin="0,0,0,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,8,0">
          <TextBlock Text="Başlangıç" Style="{StaticResource FilterLabelStyle}" />
          <DatePicker x:Name="DpBaslangic" Width="130" SelectedDateChanged="FiltreDegisti" />
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="0,0,8,0">
          <TextBlock Text="Bitiş" Style="{StaticResource FilterLabelStyle}" />
          <DatePicker x:Name="DpBitis" Width="130" SelectedDateChanged="FiltreDegisti" />
        </StackPanel>

        <StackPanel Grid.Column="2" Margin="0,0,8,0">
          <TextBlock Text="Rapor Türü" Style="{StaticResource FilterLabelStyle}" />
          <ComboBox x:Name="CmbRaporTuru" Style="{StaticResource FilterComboStyle}"
                    Width="175" SelectionChanged="FiltreDegisti" />
        </StackPanel>

        <StackPanel Grid.Column="3" Margin="0,0,8,0">
          <TextBlock Text="Modül" Style="{StaticResource FilterLabelStyle}" />
          <ComboBox x:Name="CmbModul" Style="{StaticResource FilterComboStyle}"
                    Width="155" SelectionChanged="FiltreDegisti" />
        </StackPanel>

        <StackPanel Grid.Column="4" Margin="0,0,8,0">
          <TextBlock Text="Hareket" Style="{StaticResource FilterLabelStyle}" />
          <ComboBox x:Name="CmbHareketTipi" Style="{StaticResource FilterComboStyle}"
                    Width="100" SelectionChanged="FiltreDegisti" />
        </StackPanel>

        <StackPanel Grid.Column="5" Margin="0,0,8,0">
          <TextBlock Text="Saha" Style="{StaticResource FilterLabelStyle}" />
          <ComboBox x:Name="CmbSaha" Style="{StaticResource FilterComboStyle}"
                    Width="140" SelectionChanged="FiltreDegisti" />
        </StackPanel>

        <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
          <Button Style="{StaticResource ToolbarButtonStyle}" Content="Filtreleri Temizle"
                  Margin="0,0,8,0" Click="FiltreleriTemizle_Click" />
          <Button Style="{StaticResource PrimaryToolbarButtonStyle}" Click="PdfIndir_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Filtreli PDF" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Özet kartları -->
    <ScrollViewer Grid.Row="2" Style="{StaticResource ModuleHorizontalScrollViewerStyle}" Margin="0,0,0,12">
      <StackPanel x:Name="OzetPanel" Orientation="Horizontal" />
    </ScrollViewer>

    <!-- Rapor tablosu -->
    <Border Grid.Row="3" Style="{StaticResource ModuleGridContainerStyle}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource ModuleReportHeaderStyle}" CornerRadius="12,12,0,0">
          <Grid>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                         Foreground="{StaticResource DashPrimaryBrush}" Margin="0,0,10,0" />
              <TextBlock x:Name="TxtRaporBaslik" Text="Finansal Özet" FontSize="15" FontWeight="SemiBold"
                         Foreground="{StaticResource DashTextBrush}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
              <TextBlock x:Name="TxtKayitSayisi" Text="0 kayıt" FontSize="12"
                         Foreground="{StaticResource DashTextSecondaryBrush}" Margin="0,0,16,0" VerticalAlignment="Center" />
              <TextBlock x:Name="TxtRaporToplam" Text="₺0" FontSize="16" FontWeight="SemiBold"
                         Foreground="{StaticResource DashPrimaryBrush}" VerticalAlignment="Center" />
            </StackPanel>
          </Grid>
        </Border>

        <TabControl x:Name="RaporTab" Grid.Row="1" Padding="0" BorderThickness="0" Visibility="Collapsed"
                    Style="{StaticResource ModuleTabControlStyle}"
                    ItemContainerStyle="{StaticResource ModuleTabItemStyle}">
          <TabItem Header="Modül" x:Name="TabModul">
            <DataGrid x:Name="ModulGrid" Style="{StaticResource ModuleDataGridStyle}"
                      AlternatingRowBackground="Transparent" IsReadOnly="True"
                      AutoGenerateColumns="False" MouseDoubleClick="GelirDuzenle_DoubleClick">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Modül" Binding="{Binding ModulAdi}" Width="*" MinWidth="140" />
                <DataGridTextColumn Header="Tip" Binding="{Binding Tip}" Width="70" />
                <DataGridTextColumn Header="Kayıt" Binding="{Binding KayitSayisi}" Width="65" />
                <DataGridTextColumn Header="Toplam" Binding="{Binding ToplamTutar, StringFormat='₺{0:N2}'}" Width="120" />
              </DataGrid.Columns>
            </DataGrid>
          </TabItem>
          <TabItem Header="Nakit Akışı" x:Name="TabAylik">
            <DataGrid x:Name="AylikGrid" Style="{StaticResource ModuleDataGridStyle}"
                      AlternatingRowBackground="Transparent" IsReadOnly="True" AutoGenerateColumns="False">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Ay" Binding="{Binding Ay}" Width="*" MinWidth="120" />
                <DataGridTextColumn Header="Gider" Binding="{Binding Gider, StringFormat='₺{0:N2}'}" Width="110" />
                <DataGridTextColumn Header="Gelir" Binding="{Binding Gelir, StringFormat='₺{0:N2}'}" Width="110" />
                <DataGridTextColumn Header="Net" Binding="{Binding Net, StringFormat='₺{0:N2}'}" Width="110" />
                <DataGridTextColumn Header="Hareket" Binding="{Binding HareketSayisi}" Width="75" />
              </DataGrid.Columns>
            </DataGrid>
          </TabItem>
          <TabItem Header="Vadeler" x:Name="TabVade">
            <DataGrid x:Name="VadeGrid" Style="{StaticResource ModuleDataGridStyle}"
                      AlternatingRowBackground="Transparent" IsReadOnly="True" AutoGenerateColumns="False">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Vade" Binding="{Binding VadeTarihi}" Width="85" />
                <DataGridTextColumn Header="İşlem" Binding="{Binding IslemTarihi}" Width="85" />
                <DataGridTextColumn Header="Firma" Binding="{Binding Firma}" Width="*" MinWidth="120" />
                <DataGridTextColumn Header="Belge" Binding="{Binding BelgeNo}" Width="90" />
                <DataGridTextColumn Header="Açıklama" Binding="{Binding Aciklama}" Width="*" MinWidth="100" />
                <DataGridTextColumn Header="Vade Gün" Binding="{Binding VadeGunu}" Width="70" />
                <DataGridTextColumn Header="Tutar" Binding="{Binding Tutar, StringFormat='₺{0:N2}'}" Width="95" />
                <DataGridTextColumn Header="KDV Dahil" Binding="{Binding KdvDahilTutar, StringFormat='₺{0:N2}'}" Width="100" />
                <DataGridTextColumn Header="Durum" Binding="{Binding DurumMetin}" Width="110" />
              </DataGrid.Columns>
            </DataGrid>
          </TabItem>
          <TabItem Header="Grup" x:Name="TabGrup">
            <DataGrid x:Name="GrupGrid" Style="{StaticResource ModuleDataGridStyle}"
                      AlternatingRowBackground="Transparent" IsReadOnly="True" AutoGenerateColumns="False">
              <DataGrid.Columns>
                <DataGridTextColumn x:Name="ColGrupAdi" Header="Grup" Binding="{Binding GrupAdi}" Width="*" MinWidth="130" />
                <DataGridTextColumn Header="Kayıt" Binding="{Binding KayitSayisi}" Width="65" />
                <DataGridTextColumn Header="Gider" Binding="{Binding GiderTutar, StringFormat='₺{0:N2}'}" Width="100" />
                <DataGridTextColumn Header="Gelir" Binding="{Binding GelirTutar, StringFormat='₺{0:N2}'}" Width="100" />
                <DataGridTextColumn Header="Modül Dağılımı" Binding="{Binding ModulDagilimi}" Width="*" MinWidth="160" />
              </DataGrid.Columns>
            </DataGrid>
          </TabItem>
          <TabItem Header="Hareketler" x:Name="TabHareket">
            <DataGrid x:Name="HareketGrid" Style="{StaticResource ModuleDataGridStyle}"
                      AlternatingRowBackground="Transparent" IsReadOnly="True"
                      AutoGenerateColumns="False" MouseDoubleClick="GelirDuzenle_DoubleClick">
              <DataGrid.ContextMenu>
                <ContextMenu>
                  <MenuItem Header="Düzenle" Click="GelirDuzenle_Click" />
                  <MenuItem Header="Sil" Click="GelirSil_Click" />
                </ContextMenu>
              </DataGrid.ContextMenu>
              <DataGrid.Columns>
                <DataGridTextColumn Header="Tip" Binding="{Binding Tip}" Width="55" />
                <DataGridTextColumn Header="Tarih" Binding="{Binding Tarih}" Width="85" />
                <DataGridTextColumn Header="Modül" Binding="{Binding Modul}" Width="110" />
                <DataGridTextColumn Header="Belge No" Binding="{Binding BelgeNo}" Width="90" />
                <DataGridTextColumn Header="Kategori" Binding="{Binding Kategori}" Width="90" />
                <DataGridTextColumn Header="Açıklama" Binding="{Binding Aciklama}" Width="*" MinWidth="130" />
                <DataGridTextColumn Header="Tedarikçi/Kaynak" Binding="{Binding Tedarikci}" Width="120" />
                <DataGridTextColumn Header="Saha" Binding="{Binding Saha}" Width="100" />
                <DataGridTextColumn Header="Ödeme" Binding="{Binding OdemeSekli}" Width="80" />
                <DataGridTextColumn Header="Tutar" Binding="{Binding TutarMetin}" Width="100" />
              </DataGrid.Columns>
            </DataGrid>
          </TabItem>
        </TabControl>

        <DataGrid x:Name="AnaGrid" Grid.Row="1" Style="{StaticResource ModuleDataGridStyle}"
                  AlternatingRowBackground="Transparent" IsReadOnly="True"
                  AutoGenerateColumns="False" Visibility="Visible">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Modül" Binding="{Binding ModulAdi}" Width="*" MinWidth="140" />
            <DataGridTextColumn Header="Tip" Binding="{Binding Tip}" Width="70" />
            <DataGridTextColumn Header="Kayıt" Binding="{Binding KayitSayisi}" Width="65" />
            <DataGridTextColumn Header="Toplam" Binding="{Binding ToplamTutar, StringFormat='₺{0:N2}'}" Width="120" />
          </DataGrid.Columns>
        </DataGrid>
      </Grid>
    </Border>
  </Grid>
</UserControl>
