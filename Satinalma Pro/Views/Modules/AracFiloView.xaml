<UserControl x:Class="SatinalmaPro.Views.Modules.AracFiloView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:helpers="clr-namespace:SatinalmaPro.Helpers"
             xmlns:controls="clr-namespace:SatinalmaPro.Views.Controls"
             Loaded="AracFiloView_Loaded" Background="{StaticResource DashBackgroundBrush}">
  <Grid x:Name="AnaIcerikGrid">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Style="{StaticResource ModulePageCardStyle}" Padding="14,12" Margin="0,0,0,12">
      <Grid>
        <StackPanel Orientation="Horizontal">
          <Button Style="{StaticResource PrimaryToolbarButtonStyle}" Click="YeniArac_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Yeni Araç" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="ExcelYukle_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Excel Yükle" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="SablonIndir_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Şablon İndir" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="PdfYazdir_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="PDF Yazdır" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="DisaAktar_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Dışa Aktar" />
            </StackPanel>
          </Button>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Style="{StaticResource ToolbarButtonStyle}" Margin="0" Click="Yenile_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Yenile" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1" x:Name="FiltreKart" Style="{StaticResource ModulePageCardStyle}" Padding="14,12,30,12" Margin="0,0,0,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" MinWidth="220" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,10,0">
          <TextBlock Text="Ara" Style="{StaticResource FilterLabelStyle}" />
          <Grid>
            <TextBox x:Name="TxtArama" Style="{StaticResource FilterBoxStyle}" TextChanged="FiltreDegisti"
                     ui:ControlHelper.PlaceholderText="Plaka, marka, şirket veya saha ara..." />
            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                       Foreground="{StaticResource InkMutedBrush}" HorizontalAlignment="Right"
                       VerticalAlignment="Center" Margin="0,0,12,0" IsHitTestVisible="False" />
          </Grid>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="0,0,8,0">
          <TextBlock Text="Araç Tipi" Style="{StaticResource FilterLabelStyle}" />
          <ComboBox x:Name="CmbAracTipi" Style="{StaticResource FilterComboStyle}" MinWidth="150"
                    SelectionChanged="FiltreDegisti">
            <ComboBoxItem Content="Tümü" />
            <ComboBoxItem Content="Binek" />
            <ComboBoxItem Content="İş Makinası" />
          </ComboBox>
        </StackPanel>

        <StackPanel Grid.Column="2" Margin="0,0,8,0">
          <TextBlock Text="Sahiplik" Style="{StaticResource FilterLabelStyle}" />
          <ComboBox x:Name="CmbSahiplik" Style="{StaticResource FilterComboStyle}" MinWidth="130"
                    SelectionChanged="FiltreDegisti">
            <ComboBoxItem Content="Tümü" />
            <ComboBoxItem Content="Bizim" />
            <ComboBoxItem Content="Kiralık" />
          </ComboBox>
        </StackPanel>

        <Button Grid.Column="3" Style="{StaticResource ToolbarButtonStyle}" VerticalAlignment="Bottom"
                Content="Filtreleri Temizle" Click="FiltreleriTemizle_Click" />
      </Grid>
    </Border>

    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
      <Border Style="{StaticResource StatChipStyle}">
        <StackPanel>
          <TextBlock Text="Toplam Araç" FontSize="11" Foreground="{StaticResource InkMutedBrush}" />
          <TextBlock x:Name="TxtToplamArac" Text="0" FontSize="22" FontWeight="SemiBold" Margin="0,2,0,0" />
        </StackPanel>
      </Border>
      <Border Style="{StaticResource StatChipStyle}">
        <StackPanel>
          <TextBlock Text="Toplam Gider" FontSize="11" Foreground="{StaticResource InkMutedBrush}" />
          <TextBlock x:Name="TxtToplamGider" Text="₺0" FontSize="22" FontWeight="SemiBold" Foreground="#10B981" Margin="0,2,0,0" />
        </StackPanel>
      </Border>
      <Border Style="{StaticResource StatChipStyle}">
        <StackPanel>
          <TextBlock Text="Muayenesi Yaklaşan" FontSize="11" Foreground="{StaticResource InkMutedBrush}" />
          <TextBlock x:Name="TxtYaklasanMuayene" Text="0" FontSize="22" FontWeight="SemiBold" Foreground="#D97706" Margin="0,2,0,0" />
        </StackPanel>
      </Border>
      <Border Style="{StaticResource StatChipStyle}" Margin="0">
        <StackPanel>
          <TextBlock Text="Filtrelenen" FontSize="11" Foreground="{StaticResource InkMutedBrush}" />
          <TextBlock x:Name="TxtFiltrelenen" Text="0 araç" FontSize="22" FontWeight="SemiBold" Margin="0,2,0,0" />
        </StackPanel>
      </Border>
    </StackPanel>

    <Border Grid.Row="3" Style="{StaticResource ModulePageCardStyle}" Padding="14,12,30,12" Margin="0,0,0,12">
      <StackPanel Orientation="Horizontal">
        <Button x:Name="BtnAracDetay" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"
                IsEnabled="False" Click="AracDetay_Click" Content="Araç Detayları" />
        <Button x:Name="BtnAracGider" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"
                IsEnabled="False" Click="AracGider_Click" Content="Araç Gider Kaydı" />
        <Button x:Name="BtnAracDuzenle" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"
                IsEnabled="False" Click="AracDuzenle_Click" Content="Araç Düzenle" />
        <Button x:Name="BtnAracSil" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"
                IsEnabled="False" Click="AracSil_Click" Content="Araç Sil" />
        <Button x:Name="BtnAracSevk" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"
                IsEnabled="False" Click="AracSevk_Click" Content="Araç Sevk" />
        <Button x:Name="BtnAracZimmet" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"
                IsEnabled="False" Click="AracZimmet_Click" Content="Araç Zimmet" />
        <Button x:Name="BtnZimmetIptal" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"
                IsEnabled="False" Click="ZimmetIptal_Click" Content="Zimmet İptal" />
        <Button x:Name="BtnZimmetPdf" Style="{StaticResource ToolbarButtonStyle}" Margin="0"
                IsEnabled="False" Click="ZimmetPdf_Click" Content="Zimmet PDF" />
      </StackPanel>
    </Border>

    <Border x:Name="TabloKart" Grid.Row="4" Style="{StaticResource ModuleGridContainerStyle}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Style="{StaticResource ErpTableToolbar}">
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource ErpTableToolbarBtn}" Content="Kolonlar" Click="Kolonlar_Click" />
            <Button Style="{StaticResource ErpTableToolbarBtn}" Content="Grupla" Click="Grupla_Click" />
            <Button Style="{StaticResource ErpTableToolbarBtn}" Content="Filtre" Click="FiltreOdak_Click" />
            <Button Style="{StaticResource ErpTableToolbarBtn}" Content="Yoğun" Click="YogunGorunum_Click" />
            <Button x:Name="BtnTamEkran" Style="{StaticResource ErpTableToolbarBtn}" Content="Tam Ekran" Click="TamEkran_Click" />
          </StackPanel>
        </Border>
      <DataGrid x:Name="FiloGrid" Grid.Row="1" Style="{StaticResource ModuleDataGridStyle}"
                CanUserReorderColumns="True"
                AlternatingRowBackground="Transparent" LoadingRow="FiloGrid_LoadingRow"
                SelectionChanged="FiloGrid_SelectionChanged"
                MouseDoubleClick="FiloGrid_MouseDoubleClick"
                ScrollViewer.HorizontalScrollBarVisibility="Auto">
        <DataGrid.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Detay / Düzenle" Click="MenuDetay_Click" />
            <Separator />
            <MenuItem Header="Sil" Click="MenuSil_Click" />
          </ContextMenu>
        </DataGrid.ContextMenu>
        <DataGrid.Columns>
          <DataGridTextColumn Header="Plaka" Binding="{Binding Plaka}" Width="110" />
          <DataGridTextColumn Header="Şasi No" Binding="{Binding SasiNo}" Width="120" />
          <DataGridTextColumn Header="Tip" Binding="{Binding AracTipi}" Width="95" />
          <DataGridTextColumn Header="Marka / Model" Binding="{Binding MarkaModel}" Width="140" />
          <DataGridTextColumn Header="Zimmet" Binding="{Binding ZimmetMetin}" Width="120" />
          <DataGridTextColumn Header="Sahiplik" Binding="{Binding SahiplikMetin}" Width="85" />
          <DataGridTextColumn Header="Şirket" Binding="{Binding Sirket}" Width="130" />
          <DataGridTextColumn Header="Saha" Binding="{Binding Saha}" Width="120" />
          <DataGridTextColumn Header="Muayene" Binding="{Binding MuayeneUyariMetin}" Width="120" />
          <DataGridTextColumn Header="Sigorta" Binding="{Binding SigortaUyariMetin}" Width="120" />
          <DataGridTextColumn Header="Toplam Gider" Binding="{Binding ToplamGiderMetin}" Width="115" />
          <DataGridTextColumn Header="Durum" Binding="{Binding Durum}" Width="80" />
          <DataGridTextColumn Header="Açıklama" Binding="{Binding Aciklama}" Width="*" MinWidth="120" />
        </DataGrid.Columns>
      </DataGrid>
        <Border Grid.Row="2" Style="{StaticResource ErpFooterBar}">
          <Grid>
            <TextBlock x:Name="TxtGrupBilgi" Style="{StaticResource ErpFooterText}" Visibility="Collapsed" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
              <TextBlock Text="Sayfa boyutu:" Style="{StaticResource ErpFooterText}" Margin="0,0,8,0" />
              <ComboBox x:Name="CmbSayfaBoyutu" Width="72" Height="28" VerticalContentAlignment="Center"
                        SelectionChanged="SayfaBoyutuDegisti">
                <ComboBoxItem Content="25" Tag="25" />
                <ComboBoxItem Content="50" Tag="50" IsSelected="True" />
                <ComboBoxItem Content="100" Tag="100" />
              </ComboBox>
            </StackPanel>
          </Grid>
        </Border>
      <controls:SayfalamaCubugu x:Name="SayfalamaBar" Grid.Row="3" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
