<Window x:Class="SatinalmaPro.Views.Modules.SatinalmaTalepOnizlemeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Talep Önizleme"
        Width="1040"
        Height="720"
        MinWidth="880"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="White">
  <Grid Margin="28">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,18">
      <StackPanel>
        <TextBlock Text="Talep Önizleme" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
        <TextBlock x:Name="TxtTalepNo" FontSize="14" Foreground="{StaticResource InkMutedBrush}" Margin="0,6,0,0" />
      </StackPanel>
      <Button Style="{StaticResource ToolbarButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Top"
              Padding="10,6" Click="Kapat_Click" ToolTip="Kapat">
        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
      </Button>
    </Grid>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <Border x:Name="DurumRozeti" Padding="12,7" CornerRadius="8"
                HorizontalAlignment="Left" Margin="0,0,0,18">
          <TextBlock x:Name="TxtDurum" FontSize="13" FontWeight="SemiBold" />
        </Border>

        <Grid Margin="0,0,0,18">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0">
            <TextBlock Text="Tarih" FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,4" />
            <TextBlock x:Name="TxtTarih" FontSize="14" />
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Text="Talep Yapan" FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,4" />
            <TextBlock x:Name="TxtTalepEden" FontSize="14" TextWrapping="Wrap" />
          </StackPanel>
          <StackPanel Grid.Column="4">
            <TextBlock Text="Kalem" FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,4" />
            <TextBlock x:Name="TxtKalemSayisi" FontSize="14" />
          </StackPanel>
        </Grid>

        <TextBlock Text="Talep Açıklaması" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
        <Border Background="#F8FAFC" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                CornerRadius="10" Padding="14" Margin="0,0,0,20">
          <TextBlock x:Name="TxtAciklama" FontSize="14" TextWrapping="Wrap" />
        </Border>

        <TextBlock Text="Malzeme Kalemleri" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
        <DataGrid x:Name="KalemTablosu" AutoGenerateColumns="False" CanUserAddRows="False"
                  IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                  RowHeight="38" FontSize="13" MinHeight="160" Margin="0,0,0,20">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Malzeme" Binding="{Binding Malzeme}" Width="2*" MinWidth="180" />
            <DataGridTextColumn Header="Miktar" Binding="{Binding Miktar}" Width="100"
                                ElementStyle="{StaticResource SatGridSayi}" />
            <DataGridTextColumn Header="Birim" Binding="{Binding Birim}" Width="80"
                                ElementStyle="{StaticResource SatGridOrta}" />
            <DataGridTextColumn Header="Açıklama" Binding="{Binding Aciklama}" Width="*" MinWidth="140" />
          </DataGrid.Columns>
        </DataGrid>

        <Border x:Name="EkBilgiPanel" Background="#FAFBFC" BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1" CornerRadius="10" Padding="14" Visibility="Collapsed">
          <StackPanel x:Name="EkBilgiIcerik" />
        </Border>
      </StackPanel>
    </ScrollViewer>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
      <Button Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"
              Click="Kapat_Click" Content="Kapat" />
      <Button x:Name="BtnDuzenle" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"
              Click="Duzenle_Click" Content="Düzenle" />
      <Button Style="{StaticResource PrimaryToolbarButtonStyle}"
              Click="Pdf_Click" Content="Talep PDF" />
    </StackPanel>
  </Grid>
</Window>
