<Window x:Class="SatinalmaPro.Views.Modules.StokGirisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:controls="clr-namespace:SatinalmaPro.Views.Controls"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Stok Girişi"
        Width="920"
        Height="720"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="White">
  <Grid Margin="28">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,16">
      <TextBlock Text="Stok Girişi" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
      <TextBlock Text="Birden fazla malzeme satırı ekleyerek stok ve alınan malzemelere kayıt yapın" FontSize="13"
                 Foreground="{StaticResource InkMutedBrush}" Margin="0,4,0,0" />
    </StackPanel>

    <ScrollViewer Grid.Row="1" Style="{StaticResource ModuleScrollViewerStyle}">
      <StackPanel>
        <Grid Margin="0,0,0,14">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0">
            <TextBlock Text="Tarih" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
            <TextBox x:Name="TxtTarih" Style="{StaticResource FilterBoxStyle}" />
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Text="Belge No" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
            <TextBox x:Name="TxtBelge" Style="{StaticResource FilterBoxStyle}" IsReadOnly="True" Background="#F8FAFC" />
          </StackPanel>
          <StackPanel Grid.Column="4">
            <TextBlock Text="Teslim Eden" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
            <TextBox x:Name="TxtTeslimEden" Style="{StaticResource FilterBoxStyle}" IsReadOnly="True" Background="#F8FAFC" />
          </StackPanel>
          <StackPanel Grid.Column="6">
            <TextBlock Text="Teslim Edilen" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
            <TextBox x:Name="TxtTeslimEdilen" Style="{StaticResource FilterBoxStyle}"
                     ui:ControlHelper.PlaceholderText="Malzemeyi teslim alan kişi" />
          </StackPanel>
        </Grid>

        <StackPanel Margin="0,0,0,14">
          <TextBlock Text="Tedarikçi Firması" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
          <ComboBox x:Name="CmbTedarikci" Style="{StaticResource FilterComboStyle}" IsEditable="True"
                    IsTextSearchEnabled="False" ui:ControlHelper.PlaceholderText="Listedeki cariyi seçin veya yeni firma yazın" />
        </StackPanel>

        <Border Background="#F8FAFC" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                CornerRadius="12" Padding="14" Margin="0,0,0,10">
          <StackPanel>
            <TextBlock Text="Yeni Satır" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" Margin="0,0,0,12" />
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="1.4*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="0.8*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="0.7*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="0.9*" />
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0">
                <TextBlock Text="Kategori" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
                <ComboBox x:Name="CmbKategori" Style="{StaticResource FilterComboStyle}" IsEditable="False"
                          SelectionChanged="KategoriDegisti" />
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Text="Malzeme" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
                <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Background="White" CornerRadius="4" Padding="2,0" MinHeight="34">
                  <controls:MalzemeOneriGiris x:Name="MalzemeGiris" />
                </Border>
              </StackPanel>
              <StackPanel Grid.Column="4">
                <TextBlock Text="Miktar" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
                <TextBox x:Name="TxtMiktar" Style="{StaticResource FilterBoxStyle}" />
              </StackPanel>
              <StackPanel Grid.Column="6">
                <TextBlock Text="Birim" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
                <ComboBox x:Name="CmbBirim" Style="{StaticResource FilterComboStyle}" IsEditable="False" />
              </StackPanel>
              <StackPanel Grid.Column="8">
                <TextBlock Text="Birim Fiyat" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
                <TextBox x:Name="TxtBirimFiyat" Style="{StaticResource FilterBoxStyle}"
                         ui:ControlHelper.PlaceholderText="₺ (isteğe bağlı)" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
          <Button Style="{StaticResource PrimaryToolbarButtonStyle}" Content="Satır Ekle" Margin="0,0,8,0" Click="SatirEkle_Click" />
          <Button x:Name="BtnSatirSil" Style="{StaticResource ToolbarButtonStyle}" Content="Satır Sil"
                  IsEnabled="False" Click="SatirSil_Click" />
        </StackPanel>

        <Border Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="12" Padding="1">
          <DataGrid x:Name="SatirGrid" Style="{StaticResource ModuleDataGridStyle}" Height="240"
                    AlternatingRowBackground="Transparent" IsReadOnly="True"
                    SelectionChanged="SatirGrid_SelectionChanged">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Kategori" Binding="{Binding Kategori}" Width="110" />
              <DataGridTextColumn Header="Malzeme" Binding="{Binding Malzeme}" Width="*" MinWidth="140" />
              <DataGridTextColumn Header="Miktar" Binding="{Binding MiktarGosterim}" Width="80" />
              <DataGridTextColumn Header="Birim" Binding="{Binding Birim}" Width="70" />
              <DataGridTextColumn Header="Birim Fiyat" Binding="{Binding BirimFiyatGosterim}" Width="95" />
            </DataGrid.Columns>
          </DataGrid>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button Content="İptal" Style="{StaticResource ToolbarButtonStyle}" Width="100" Margin="0,0,8,0" Click="Iptal_Click" />
      <Button Content="Kaydet" Style="{StaticResource PrimaryToolbarButtonStyle}" Width="120" Click="Kaydet_Click" />
    </StackPanel>
  </Grid>
</Window>
