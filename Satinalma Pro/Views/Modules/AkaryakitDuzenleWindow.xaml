<Window x:Class="SatinalmaPro.Views.Modules.AkaryakitDuzenleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Yakıt Kaydı Düzenle"
        Width="580"
        Height="780"
        MinWidth="500"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="White">
  <Grid Margin="28">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,20">
      <TextBlock Text="Yakıt Kaydı" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
      <TextBlock x:Name="TxtAltBaslik"
                 Text="Plaka filo parkından seçilir; araç bilgileri ve şoför otomatik doldurulur"
                 FontSize="13" Foreground="{StaticResource InkMutedBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
    </StackPanel>

    <ScrollViewer Grid.Row="1" Style="{StaticResource ModuleScrollViewerStyle}">
      <StackPanel>
        <TextBlock Text="Kayıt Tipi" Style="{StaticResource FilterLabelStyle}" />
        <ComboBox x:Name="CmbKayitTipi" Style="{StaticResource FilterComboStyle}" Margin="0,0,0,14"
                  IsEditable="False" SelectionChanged="KayitTipiDegisti">
          <ComboBoxItem Content="Dağıtılan" />
          <ComboBoxItem Content="Alınan" />
        </ComboBox>

        <TextBlock Text="Tarih" Style="{StaticResource FilterLabelStyle}" />
        <TextBox x:Name="TxtTarih" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,14"
                 ui:ControlHelper.PlaceholderText="gg.aa.yyyy" />

        <StackPanel x:Name="PanelDagitilan">
          <TextBlock Text="Plaka" Style="{StaticResource FilterLabelStyle}" />
          <ComboBox x:Name="CmbPlaka" Style="{StaticResource FilterComboStyle}" Margin="0,0,0,14"
                    SelectionChanged="PlakaSecildi" LostFocus="PlakaMetniDegisti" />

          <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
              <TextBlock Text="Araç Tipi" Style="{StaticResource FilterLabelStyle}" />
              <ComboBox x:Name="CmbAracTipi" Style="{StaticResource FilterComboStyle}">
                <ComboBoxItem Content="Araç" />
                <ComboBoxItem Content="İş Makinası" />
              </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="2">
              <TextBlock Text="Araç / Makine Adı" Style="{StaticResource FilterLabelStyle}" />
              <TextBox x:Name="TxtAracAdi" Style="{StaticResource FilterBoxStyle}" />
            </StackPanel>
          </Grid>

          <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
              <TextBlock Text="Km Sayacı" Style="{StaticResource FilterLabelStyle}" />
              <TextBox x:Name="TxtKmSayaci" Style="{StaticResource FilterBoxStyle}"
                       ui:ControlHelper.PlaceholderText="Araçlar için" />
            </StackPanel>
            <StackPanel Grid.Column="2">
              <TextBlock Text="Saat Sayacı" Style="{StaticResource FilterLabelStyle}" />
              <TextBox x:Name="TxtSaatSayaci" Style="{StaticResource FilterBoxStyle}"
                       ui:ControlHelper.PlaceholderText="İş makinaları için" />
            </StackPanel>
          </Grid>

          <TextBlock Text="Şoför / Operatör" Style="{StaticResource FilterLabelStyle}" />
          <TextBox x:Name="TxtSofor" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,14"
                   ui:ControlHelper.PlaceholderText="Aktif zimmet varsa otomatik gelir" />

          <TextBlock Text="Saha" Style="{StaticResource FilterLabelStyle}" />
          <TextBox x:Name="TxtSaha" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,14" />

          <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
              <TextBlock Text="Yakıt Türü" Style="{StaticResource FilterLabelStyle}" />
              <ComboBox x:Name="CmbYakitTuru" Style="{StaticResource FilterComboStyle}" IsEditable="True">
                <ComboBoxItem Content="Motorin" />
                <ComboBoxItem Content="Benzin" />
                <ComboBoxItem Content="AdBlue" />
              </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="2">
              <TextBlock Text="Miktar (Lt)" Style="{StaticResource FilterLabelStyle}" />
              <TextBox x:Name="TxtMiktarDagitilan" Style="{StaticResource FilterBoxStyle}" />
            </StackPanel>
          </Grid>

          <TextBlock Text="Açıklama" Style="{StaticResource FilterLabelStyle}" />
          <TextBox x:Name="TxtAciklama" Style="{StaticResource FilterBoxStyle}" Height="72" Margin="0,0,0,0"
                   TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="12,10" />
        </StackPanel>

        <StackPanel x:Name="PanelAlinan" Visibility="Collapsed">
          <TextBlock Text="Miktar" Style="{StaticResource FilterLabelStyle}" />
          <TextBox x:Name="TxtMiktarAlinan" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,14"
                   TextChanged="TutarHesapla" />

          <TextBlock Text="Birim" Style="{StaticResource FilterLabelStyle}" />
          <ComboBox x:Name="CmbBirim" Style="{StaticResource FilterComboStyle}" Margin="0,0,0,14" IsEditable="True">
            <ComboBoxItem Content="Lt" />
          </ComboBox>

          <TextBlock Text="Birim Fiyatı" Style="{StaticResource FilterLabelStyle}" />
          <TextBox x:Name="TxtBirimFiyati" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,14"
                   TextChanged="TutarHesapla" />

          <TextBlock Text="Toplam Tutar" Style="{StaticResource FilterLabelStyle}" />
          <TextBox x:Name="TxtToplamTutar" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,14"
                   IsReadOnly="True" Background="#F8FAFC" />

          <TextBlock Text="Tedarikçi" Style="{StaticResource FilterLabelStyle}" />
          <TextBox x:Name="TxtTedarikci" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,14" />

          <TextBlock Text="Teslim Alan" Style="{StaticResource FilterLabelStyle}" />
          <TextBox x:Name="TxtTeslimAlan" Style="{StaticResource FilterBoxStyle}" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
      <Button Content="İptal" Style="{StaticResource ToolbarButtonStyle}" Width="100" Margin="0,0,8,0" Click="Iptal_Click" />
      <Button Content="Kaydet" Style="{StaticResource PrimaryToolbarButtonStyle}" Width="120" Click="Kaydet_Click" />
    </StackPanel>
  </Grid>
</Window>
