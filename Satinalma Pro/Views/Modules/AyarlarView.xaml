<UserControl x:Class="SatinalmaPro.Views.Modules.AyarlarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:helpers="clr-namespace:SatinalmaPro.Helpers">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
            CornerRadius="14" Padding="14,12" Margin="0,0,0,12">
      <Grid>
        <StackPanel Orientation="Horizontal">
          <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,14,0">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#64748B" Offset="0" />
                <GradientStop Color="#94A3B8" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>
            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Ayarlar" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
            <TextBlock Text="Tüm modül ayarları, veri yönetimi ve yedekleme" FontSize="11"
                       Foreground="{StaticResource InkMutedBrush}" Margin="0,2,0,0" />
          </StackPanel>
        </StackPanel>
        <Button Style="{StaticResource PrimaryToolbarButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Center"
                Click="AyarlarKaydet_Click">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
            <TextBlock Text="Ayarları Kaydet" />
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <TabControl x:Name="AyarTab" Grid.Row="1" Padding="0">
      <!-- GENEL -->
      <TabItem Header="Genel">
        <ScrollViewer Style="{StaticResource ModuleScrollViewerStyle}" Padding="0,12,18,0">
          <StackPanel>
            <Border x:Name="BulutYonetimPanel" Style="{StaticResource SatinalmaCardStyle}" Margin="0,0,0,12">
              <StackPanel>
                <TextBlock Text="Bulut ve Kullanıcılar" Style="{StaticResource SatinalmaSectionTitleStyle}" Margin="0,0,0,8" />
                <TextBlock Text="İnternet üzerinden ortak veri ve giriş sistemi (Firebase). Yapılandırılmamışsa uygulama yerel çalışır."
                           FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,10" />
                <TextBlock Text="Uygulama klasöründeki firebase_ayarlar.json (exe ile birlikte kopyalanır)"
                           FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
                <TextBox x:Name="TxtFirebaseYolu" Style="{StaticResource FilterBoxStyle}" IsReadOnly="True" Margin="0,0,0,8" />
                <TextBlock Text="Push bildirimleri — Firebase Console → Hizmet hesapları → özel anahtar JSON"
                           FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                  <Button Style="{StaticResource ToolbarButtonStyle}" Content="FCM Service Account JSON Yükle"
                          Click="FcmServiceAccountYukle_Click" Margin="0,0,8,0" />
                  <TextBlock x:Name="TxtFcmServiceAccountDurum" VerticalAlignment="Center"
                             FontSize="11" Foreground="{StaticResource InkMutedBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                  <Button Style="{StaticResource ToolbarButtonStyle}" Content="Android google-services.json Yükle"
                          Click="GoogleServicesYukle_Click" />
                </StackPanel>
                <TextBlock x:Name="TxtGoogleServicesDurum" FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,8" />
                <TextBlock x:Name="TxtFirebaseUyari" FontSize="11" Foreground="#B45309" TextWrapping="Wrap" Margin="0,0,0,8" Visibility="Collapsed" />
                <TextBlock x:Name="TxtGuncellemeDurum" FontSize="11" Foreground="{StaticResource InkMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />
                <StackPanel Orientation="Horizontal">
                  <Button x:Name="BtnBulutaYukle" Style="{StaticResource PrimaryToolbarButtonStyle}"
                          Content="Verileri Buluta Yükle" Margin="0,0,8,0" Click="BulutaYukle_Click"
                          Visibility="Collapsed" />
                  <Button x:Name="BtnKullaniciYonetimi" Style="{StaticResource PrimaryToolbarButtonStyle}"
                          Content="Kullanıcı Yönetimi" Margin="0,0,8,0" Click="KullaniciYonetimi_Click"
                          Visibility="Collapsed" />
                  <Button Style="{StaticResource ToolbarButtonStyle}" Content="Kurulum Kılavuzunu Aç"
                          Click="FirebaseKurulum_Click" Margin="0,0,8,0" />
                  <Button Style="{StaticResource ToolbarButtonStyle}" Content="Android Firebase Kılavuzu"
                          Click="FirebaseAndroidKurulum_Click" Margin="0,0,8,0" />
                  <Button Style="{StaticResource ToolbarButtonStyle}" Content="GitHub Yayın Kılavuzu"
                          Click="GithubKurulum_Click" Margin="0,0,8,0" />
                  <Button Style="{StaticResource ToolbarButtonStyle}" Content="Sürüm Güncelleme"
                          Click="GithubSurumGuncelleme_Click" />
                </StackPanel>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource SatinalmaCardStyle}">
            <StackPanel>
              <TextBlock Text="Firma Bilgileri" Style="{StaticResource SatinalmaSectionTitleStyle}" Margin="0,0,0,8" />
              <TextBlock Text="Tüm PDF belgelerinde görünen firma adı ve logo" FontSize="11"
                         Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,14" />
              <TextBlock Text="Firma Adı" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
              <TextBox x:Name="TxtFirmaAdi" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,14"
                       TextChanged="GenelAyarDegisti" />
              <TextBlock Text="Firma Logosu" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
              <TextBlock Text="PDF ve belgelerde kullanılır. Logo program klasörüne kopyalanır." FontSize="10"
                         Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,8" Opacity="0.85" />
              <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtLogoYolu" Style="{StaticResource FilterBoxStyle}" IsReadOnly="True" />
                <Button Grid.Column="1" Style="{StaticResource ToolbarButtonStyle}" Content="Logo Seç"
                        Margin="8,0,0,0" Click="LogoSec_Click" />
              </Grid>
              <Border Width="140" Height="90" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                      CornerRadius="10" Background="#FAFBFC" HorizontalAlignment="Left" Margin="0,0,0,24">
                <Image x:Name="ImgLogoOnizleme" Stretch="Uniform" Margin="10" />
              </Border>

              <TextBlock Text="Anasayfa Logosu" Style="{StaticResource SatinalmaSectionTitleStyle}" Margin="0,0,0,8" />
              <TextBlock Text="Modül kartlarının üstünde büyük olarak görünür" FontSize="11"
                         Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,14" />
              <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtAnasayfaLogoYolu" Style="{StaticResource FilterBoxStyle}" IsReadOnly="True" />
                <Button Grid.Column="1" Style="{StaticResource ToolbarButtonStyle}" Content="Logo Seç"
                        Margin="8,0,0,0" Click="AnasayfaLogoSec_Click" />
              </Grid>
              <Border Width="280" Height="120" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                      CornerRadius="10" Background="#FAFBFC" HorizontalAlignment="Left">
                <Image x:Name="ImgAnasayfaLogoOnizleme" Stretch="Uniform" Margin="12" />
              </Border>
            </StackPanel>
          </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- SATINALMA -->
      <TabItem Header="Satınalma">
        <ScrollViewer Style="{StaticResource ModuleScrollViewerStyle}" Padding="0,12,18,0">
          <StackPanel>
            <Border Style="{StaticResource SatinalmaCardStyle}" Margin="0,0,0,12">
              <StackPanel>
                <TextBlock Text="Döviz Kurları" Style="{StaticResource SatinalmaSectionTitleStyle}" Margin="0,0,0,8" />
                <TextBlock Text="Yeni teklif girerken otomatik doldurulur. Her teklifte günlük kuru değiştirebilirsiniz."
                           FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,14" />
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0">
                    <TextBlock Text="Varsayılan USD Kuru (₺)" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="TxtVarsayilanUsdKuru" Style="{StaticResource FilterBoxStyle}" TextChanged="DovizKuruDegisti" />
                  </StackPanel>
                  <StackPanel Grid.Column="2">
                    <TextBlock Text="Varsayılan EUR Kuru (₺)" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
                    <TextBox x:Name="TxtVarsayilanEurKuru" Style="{StaticResource FilterBoxStyle}" TextChanged="DovizKuruDegisti" />
                  </StackPanel>
                </Grid>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource SatinalmaCardStyle}" Margin="0,0,0,12">
              <StackPanel>
                <TextBlock Text="Teklif İsteme Şartnameleri" Style="{StaticResource SatinalmaSectionTitleStyle}" Margin="0,0,0,8" />
                <TextBlock Text="Tedarikçi teklif talep PDF'inde tedarikçi bilgileri yerine yer alır" FontSize="11"
                           Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,10" />
                <TextBox x:Name="TxtTeklifIstemeSartnameleri" Style="{StaticResource FilterBoxStyle}"
                         Height="160" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalContentAlignment="Top" Padding="12,10"
                         TextChanged="TeklifIstemeSartnameleriDegisti" />
              </StackPanel>
            </Border>

            <Border Style="{StaticResource SatinalmaCardStyle}" Margin="0,0,0,12">
              <StackPanel>
                <TextBlock Text="Şartname Metni" Style="{StaticResource SatinalmaSectionTitleStyle}" Margin="0,0,0,8" />
                <TextBlock Text="Sipariş PDF'inde metin olarak yer alır" FontSize="11"
                           Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,10" />
                <TextBox x:Name="TxtSartnameMetni" Style="{StaticResource FilterBoxStyle}"
                         Height="160" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalContentAlignment="Top" Padding="12,10"
                         TextChanged="SartnameMetniDegisti" />
              </StackPanel>
            </Border>

            <Border Style="{StaticResource SatinalmaCardStyle}">
              <StackPanel>
                <TextBlock Text="İmza Ayarları" Style="{StaticResource SatinalmaSectionTitleStyle}" Margin="0,0,0,8" />
                <TextBlock Text="Talep ve yönetim PDF'lerinde kullanılan imza alanları" FontSize="11"
                           Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,14" />

                <Grid Margin="0,0,0,10">
                  <TextBlock Text="Şefler İmza İsimleri" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <Button Style="{StaticResource PrimaryToolbarButtonStyle}" Content="Şef İmza Ekle"
                          HorizontalAlignment="Right" Click="SefImzaEkle_Click" />
                </Grid>
                <DataGrid x:Name="SefImzaGrid" Style="{StaticResource ModuleEditableDataGridStyle}" Height="120"
                          AutoGenerateColumns="False" CanUserAddRows="False" CellEditEnding="ImzaGrid_CellEditEnding">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Ünvan" Binding="{Binding Unvan, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Width="*" />
                    <DataGridTextColumn Header="Ad Soyad" Binding="{Binding AdSoyad, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Width="*" />
                    <DataGridCheckBoxColumn Header="Aktif" Binding="{Binding Aktif, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                  </DataGrid.Columns>
                </DataGrid>
                <Button Style="{StaticResource ToolbarButtonStyle}" Content="Seçili Şef İmzasını Sil"
                        Margin="0,10,0,0" HorizontalAlignment="Left" Click="SefImzaSil_Click" />

                <Grid Margin="0,20,0,10">
                  <TextBlock Text="Yönetim İmza İsimleri" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <Button Style="{StaticResource PrimaryToolbarButtonStyle}" Content="Yönetim İmza Ekle"
                          HorizontalAlignment="Right" Click="YonetimImzaEkle_Click" />
                </Grid>
                <DataGrid x:Name="YonetimImzaGrid" Style="{StaticResource ModuleEditableDataGridStyle}" Height="120"
                          AutoGenerateColumns="False" CanUserAddRows="False" CellEditEnding="ImzaGrid_CellEditEnding">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Ünvan" Binding="{Binding Unvan, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Width="*" />
                    <DataGridTextColumn Header="Ad Soyad" Binding="{Binding AdSoyad, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Width="*" />
                    <DataGridCheckBoxColumn Header="Aktif" Binding="{Binding Aktif, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                  </DataGrid.Columns>
                </DataGrid>
                <Button Style="{StaticResource ToolbarButtonStyle}" Content="Seçili Yönetim İmzasını Sil"
                        Margin="0,10,0,0" HorizontalAlignment="Left" Click="YonetimImzaSil_Click" />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- MALZEME KATEGORİLERİ -->
      <TabItem Header="Malzeme Kategorileri">
        <ScrollViewer Style="{StaticResource ModuleScrollViewerStyle}" Padding="0,12,18,0">
          <Border Style="{StaticResource SatinalmaCardStyle}">
            <StackPanel>
              <TextBlock Text="Alınan Malzeme Kategorileri" Style="{StaticResource SatinalmaSectionTitleStyle}" Margin="0,0,0,8" />
              <TextBlock Text="Satınalma modülünden aktarım yaparken ve Alınan Malzemeler kayıtlarında kullanılır."
                         FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,14"
                         TextWrapping="Wrap" />

              <ListBox x:Name="KategoriListesi"
                       Height="220"
                       BorderBrush="{StaticResource LineBrush}"
                       BorderThickness="1"
                       Margin="0,0,0,14" />

              <Grid Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtYeniKategori" Style="{StaticResource FilterBoxStyle}"
                         ui:ControlHelper.PlaceholderText="Yeni kategori adı" />
                <Button Grid.Column="1" Style="{StaticResource PrimaryToolbarButtonStyle}" Content="Ekle"
                        Margin="8,0,0,0" Click="KategoriEkle_Click" />
                <Button Grid.Column="2" Style="{StaticResource ToolbarButtonStyle}" Content="Sil"
                        Margin="8,0,0,0" Click="KategoriSil_Click" />
              </Grid>
            </StackPanel>
          </Border>
        </ScrollViewer>
      </TabItem>

      <!-- BİRİM TERİMLERİ -->
      <TabItem Header="Birim Terimleri">
        <ScrollViewer Style="{StaticResource ModuleScrollViewerStyle}" Padding="0,12,18,0">
          <Border Style="{StaticResource SatinalmaCardStyle}">
            <StackPanel>
              <TextBlock Text="Malzeme Birim Terimleri" Style="{StaticResource SatinalmaSectionTitleStyle}" Margin="0,0,0,8" />
              <TextBlock Text="Stok giriş/çıkış formlarında ve stok kayıtlarında seçilebilir birimler."
                         FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,14"
                         TextWrapping="Wrap" />

              <ListBox x:Name="BirimListesi"
                       Height="220"
                       BorderBrush="{StaticResource LineBrush}"
                       BorderThickness="1"
                       Margin="0,0,0,14" />

              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtYeniBirim" Style="{StaticResource FilterBoxStyle}"
                         ui:ControlHelper.PlaceholderText="Yeni birim terimi" />
                <Button Grid.Column="1" Style="{StaticResource PrimaryToolbarButtonStyle}" Content="Ekle"
                        Margin="8,0,0,0" Click="BirimEkle_Click" />
                <Button Grid.Column="2" Style="{StaticResource ToolbarButtonStyle}" Content="Sil"
                        Margin="8,0,0,0" Click="BirimSil_Click" />
              </Grid>
            </StackPanel>
          </Border>
        </ScrollViewer>
      </TabItem>

      <!-- ARAÇ FİLO -->
      <TabItem Header="Araç Filo">
        <ScrollViewer Style="{StaticResource ModuleScrollViewerStyle}" Padding="0,12,18,0">
          <Border Style="{StaticResource SatinalmaCardStyle}">
            <StackPanel>
              <TextBlock Text="Zimmet Formu Maddeleri" Style="{StaticResource SatinalmaSectionTitleStyle}" Margin="0,0,0,8" />
              <TextBlock Text="Zimmet PDF maddeleri. Numaralı satırlar (1. / 2)) yeni madde başlatır; alt satırlar aynı maddeye eklenir. Numaralandırmayı siz yapın — PDF tekrar numara eklemez. Plaka, marka, şasi no ve firma adı otomatik gelir."
                         FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,14"
                         TextWrapping="Wrap" />
              <TextBox x:Name="TxtFiloZimmetMaddeleri" Style="{StaticResource FilterBoxStyle}"
                       Height="220" TextWrapping="Wrap" AcceptsReturn="True"
                       VerticalContentAlignment="Top" Padding="12,10"
                       TextChanged="FiloZimmetMaddeleriDegisti" />
              <Button Style="{StaticResource PrimaryToolbarButtonStyle}" Content="Zimmet Maddelerini Kaydet"
                      HorizontalAlignment="Left" Margin="0,12,0,0" Click="FiloZimmetKaydet_Click" />
            </StackPanel>
          </Border>
        </ScrollViewer>
      </TabItem>

      <!-- VERİ DOSYALARI -->
      <TabItem Header="Veri Dosyaları">
        <Grid Margin="0,12,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Border Grid.Row="0" Style="{StaticResource SatinalmaCardStyle}" Padding="14,12" Margin="0,0,0,12">
            <Grid>
              <StackPanel>
                <TextBlock Text="Veri Klasörü" FontWeight="SemiBold" />
                <TextBox x:Name="TxtVeriKlasoru" Style="{StaticResource FilterBoxStyle}" IsReadOnly="True"
                         Margin="0,8,0,0" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Style="{StaticResource ToolbarButtonStyle}" Content="Klasörü Aç" Margin="0,0,8,0"
                        Click="VeriKlasoruAc_Click" />
                <Button Style="{StaticResource ToolbarButtonStyle}" Content="Yenile" Click="VeriDurumYenile_Click" />
              </StackPanel>
            </Grid>
          </Border>

          <Border Grid.Row="1" Style="{StaticResource SatinalmaCardStyle}" Padding="1">
            <DataGrid x:Name="VeriDurumGrid" Style="{StaticResource ModuleDataGridStyle}"
                      AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Kategori" Binding="{Binding Kategori}" Width="100" />
                <DataGridTextColumn Header="Modül" Binding="{Binding ModulAdi}" Width="*" MinWidth="140" />
                <DataGridTextColumn Header="Dosya" Binding="{Binding DosyaAdi}" Width="180" />
                <DataGridTextColumn Header="Boyut" Binding="{Binding Boyut}" Width="80" />
                <DataGridTextColumn Header="Son Güncelleme" Binding="{Binding SonGuncelleme}" Width="130" />
                <DataGridTextColumn Header="Durum" Binding="{Binding Durum}" Width="80" />
                <DataGridTemplateColumn Header="" Width="90">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <Button Content="Sıfırla" Style="{StaticResource ToolbarButtonStyle}" Padding="8,4"
                              Tag="{Binding DosyaAdi}" Click="ModulSifirla_Click" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </Border>
        </Grid>
      </TabItem>

      <!-- YEDEKLEME -->
      <TabItem Header="Yedekleme">
        <ScrollViewer Style="{StaticResource ModuleScrollViewerStyle}" Padding="0,12,18,0">
          <StackPanel>
            <Border Style="{StaticResource SatinalmaCardStyle}" Margin="0,0,0,12">
              <StackPanel>
                <TextBlock Text="Yedek Al / Geri Yükle" Style="{StaticResource SatinalmaSectionTitleStyle}" Margin="0,0,0,8" />
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,16"
                           Text="Tüm modül verilerini ve ayarları tek bir ZIP dosyası olarak yedekleyebilir veya önceki bir yedeği geri yükleyebilirsiniz." />
                <StackPanel Orientation="Horizontal">
                  <Button Style="{StaticResource PrimaryToolbarButtonStyle}" Click="YedekAl_Click" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
                      <TextBlock Text="Yedek Al (ZIP)" />
                    </StackPanel>
                  </Button>
                  <Button Style="{StaticResource ToolbarButtonStyle}" Click="GeriYukle_Click">
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
                      <TextBlock Text="Geri Yükle" />
                    </StackPanel>
                  </Button>
                </StackPanel>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource SatinalmaCardStyle}" Background="#FFF1F2" BorderBrush="#FECDD3">
              <StackPanel>
                <TextBlock Text="Tehlikeli İşlemler" FontWeight="SemiBold" Foreground="#9F1239" Margin="0,0,0,8" />
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#BE123C" Margin="0,0,0,14"
                           Text="Tüm verileri sıfırlamak geri alınamaz. İşlem öncesi mutlaka yedek alın." />
                <Button Style="{StaticResource ToolbarButtonStyle}" HorizontalAlignment="Left"
                        Click="TumVerileriSifirla_Click" Foreground="#BE123C">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
                    <TextBlock Text="Tüm Verileri Sıfırla" />
                  </StackPanel>
                </Button>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>
  </Grid>
</UserControl>
