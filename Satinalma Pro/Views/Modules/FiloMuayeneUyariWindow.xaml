<Window x:Class="SatinalmaPro.Views.Modules.FiloMuayeneUyariWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Muayene Uyarısı"
        Width="560"
        Height="420"
        MinWidth="480"
        MinHeight="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource DashBackgroundBrush}">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,16">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                   Foreground="#D97706" Margin="0,0,10,0" VerticalAlignment="Center" />
        <TextBlock Text="Muayenesi Yaklaşan Araçlar" FontSize="20" FontWeight="SemiBold"
                   Foreground="{StaticResource InkBrush}" />
      </StackPanel>
      <TextBlock x:Name="TxtAciklama" Text="Son 15 gün içinde muayenesi dolacak araçlar listelenmiştir."
                 FontSize="13" Foreground="{StaticResource InkMutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
    </StackPanel>

    <Border Grid.Row="1" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
            CornerRadius="12" Padding="1">
      <DataGrid x:Name="UyariGrid" Style="{StaticResource ModuleDataGridStyle}"
                AlternatingRowBackground="Transparent" IsReadOnly="True"
                AutoGenerateColumns="False">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Plaka" Binding="{Binding Plaka}" Width="110" />
          <DataGridTextColumn Header="Tip" Binding="{Binding AracTipi}" Width="100" />
          <DataGridTextColumn Header="Marka / Model" Binding="{Binding MarkaModel}" Width="*" MinWidth="120" />
          <DataGridTextColumn Header="Muayene" Binding="{Binding MuayeneUyariMetin}" Width="120" />
          <DataGridTextColumn Header="Saha" Binding="{Binding Saha}" Width="110" />
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button Content="Tamam" Style="{StaticResource PrimaryToolbarButtonStyle}" Width="120"
              Click="Tamam_Click" />
    </StackPanel>
  </Grid>
</Window>
