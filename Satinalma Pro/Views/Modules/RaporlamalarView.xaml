<UserControl x:Class="SatinalmaPro.Views.Modules.RaporlamalarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:helpers="clr-namespace:SatinalmaPro.Helpers">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Araç çubuğu -->
    <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
            CornerRadius="14" Padding="14,12" Margin="0,0,0,12">
      <Grid>
        <StackPanel Orientation="Horizontal">
          <Button Style="{StaticResource PrimaryToolbarButtonStyle}" Click="PdfIndir_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="PDF İndir" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="PdfYazdir_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="PDF Yazdır" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="ExcelAktar_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Excel Dışa Aktar" />
            </StackPanel>
          </Button>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Style="{StaticResource ToolbarButtonStyle}" Margin="0" Click="Yenile_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Yenile" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Filtreler -->
    <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
            CornerRadius="14" Padding="14,12,30,12" Margin="0,0,0,12">
      <StackPanel>
        <Grid Margin="0,0,0,10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0" Margin="0,0,8,0">
            <TextBlock Text="Başlangıç" Style="{StaticResource FilterLabelStyle}" />
            <DatePicker x:Name="DpBaslangic" Width="140" SelectedDateChanged="FiltreDegisti" />
          </StackPanel>

          <StackPanel Grid.Column="1" Margin="0,0,8,0">
            <TextBlock Text="Bitiş" Style="{StaticResource FilterLabelStyle}" />
            <DatePicker x:Name="DpBitis" Width="140" SelectedDateChanged="FiltreDegisti" />
          </StackPanel>

          <StackPanel Grid.Column="2" Margin="0,0,8,0">
            <TextBlock Text="Rapor Türü" Style="{StaticResource FilterLabelStyle}" />
            <ComboBox x:Name="CmbRaporTuru" Style="{StaticResource FilterComboStyle}"
                      Width="180" SelectionChanged="FiltreDegisti" />
          </StackPanel>

          <StackPanel Grid.Column="3" Margin="0,0,8,0">
            <TextBlock Text="Modül" Style="{StaticResource FilterLabelStyle}" />
            <ComboBox x:Name="CmbModul" Style="{StaticResource FilterComboStyle}"
                      Width="170" SelectionChanged="FiltreDegisti" />
          </StackPanel>

          <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Style="{StaticResource ToolbarButtonStyle}" Content="Filtreleri Temizle"
                    Margin="0,0,8,0" Click="FiltreleriTemizle_Click" />
            <Button Style="{StaticResource PrimaryToolbarButtonStyle}" Click="PdfIndir_Click">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
                <TextBlock Text="Filtreli PDF" />
              </StackPanel>
            </Button>
          </StackPanel>
        </Grid>

        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0" Margin="0,0,8,0">
            <TextBlock Text="Kategori" Style="{StaticResource FilterLabelStyle}" />
            <Button x:Name="BtnKategoriSec" Style="{StaticResource ToolbarButtonStyle}"
                    MinWidth="170" Click="KategoriSec_Click">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
                <TextBlock x:Name="TxtKategoriSecim" Text="Tümü" />
              </StackPanel>
            </Button>
          </StackPanel>

          <StackPanel Grid.Column="1" Margin="0,0,8,0">
            <TextBlock Text="Malzeme / Hizmet" Style="{StaticResource FilterLabelStyle}" />
            <Button x:Name="BtnMalzemeSec" Style="{StaticResource ToolbarButtonStyle}"
                    MinWidth="190" Click="MalzemeSec_Click">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
                <TextBlock x:Name="TxtMalzemeSecim" Text="Tümü" />
              </StackPanel>
            </Button>
          </StackPanel>

          <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                     Text="Kategori ve malzeme filtreleri tüm modüllerde geçerlidir. PDF'de alım listesi, aylık özet ve toplam maliyet tabloları üretilir."
                     FontSize="11" Foreground="{StaticResource InkMutedBrush}" TextWrapping="Wrap" />
        </Grid>
      </StackPanel>
    </Border>

    <!-- Modül özet kartları -->
    <ScrollViewer Grid.Row="2" Style="{StaticResource ModuleHorizontalScrollViewerStyle}" Margin="0,0,0,12">
      <StackPanel x:Name="ModulOzetPanel" Orientation="Horizontal" />
    </ScrollViewer>

    <!-- Rapor tablosu -->
    <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
            CornerRadius="14" Padding="1">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F8FAFC" Padding="14,10" CornerRadius="14,14,0,0">
          <Grid>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                         Foreground="#0891B2" Margin="0,0,10,0" />
              <TextBlock x:Name="TxtRaporBaslik" Text="Genel Özet" FontSize="15" FontWeight="SemiBold"
                         Foreground="{StaticResource InkBrush}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
              <TextBlock x:Name="TxtKayitSayisi" Text="0 kayıt" FontSize="12"
                         Foreground="{StaticResource InkMutedBrush}" Margin="0,0,16,0" VerticalAlignment="Center" />
              <TextBlock x:Name="TxtRaporToplam" Text="₺0" FontSize="16" FontWeight="SemiBold"
                         Foreground="#0891B2" VerticalAlignment="Center" />
            </StackPanel>
          </Grid>
        </Border>

        <TabControl x:Name="RaporTab" Grid.Row="1" Padding="0" BorderThickness="0" Visibility="Collapsed">
          <TabItem Header="Modül Özeti" x:Name="TabModulOzet">
            <DataGrid x:Name="ModulOzetGrid" Style="{StaticResource ModuleDataGridStyle}"
                      AlternatingRowBackground="Transparent" IsReadOnly="True"
                      AutoGenerateColumns="False" ScrollViewer.HorizontalScrollBarVisibility="Auto">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Modül" Binding="{Binding ModulAdi}" Width="*" MinWidth="160" />
                <DataGridTextColumn Header="Kayıt" Binding="{Binding KayitSayisi}" Width="80" />
                <DataGridTextColumn Header="Toplam Tutar" Binding="{Binding ToplamTutar, StringFormat='₺{0:N2}'}" Width="130" />
              </DataGrid.Columns>
            </DataGrid>
          </TabItem>
          <TabItem Header="Grup Özeti" x:Name="TabGrupOzet">
            <DataGrid x:Name="GrupOzetGrid" Style="{StaticResource ModuleDataGridStyle}"
                      AlternatingRowBackground="Transparent" IsReadOnly="True"
                      AutoGenerateColumns="False" ScrollViewer.HorizontalScrollBarVisibility="Auto">
              <DataGrid.Columns>
                <DataGridTextColumn x:Name="ColGrupAdi" Header="Grup" Binding="{Binding GrupAdi}" Width="*" MinWidth="140" />
                <DataGridTextColumn Header="Kayıt" Binding="{Binding KayitSayisi}" Width="80" />
                <DataGridTextColumn Header="Toplam Tutar" Binding="{Binding ToplamTutar, StringFormat='₺{0:N2}'}" Width="130" />
                <DataGridTextColumn Header="Modül Dağılımı" Binding="{Binding ModulDagilimi}" Width="*" MinWidth="180" />
              </DataGrid.Columns>
            </DataGrid>
          </TabItem>
          <TabItem Header="Detay" x:Name="TabDetay">
            <DataGrid x:Name="DetayGrid" Style="{StaticResource ModuleDataGridStyle}"
                      AlternatingRowBackground="Transparent" IsReadOnly="True"
                      AutoGenerateColumns="False" ScrollViewer.HorizontalScrollBarVisibility="Auto">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Modül" Binding="{Binding Modul}" Width="110" />
                <DataGridTextColumn Header="Tarih" Binding="{Binding Tarih}" Width="85" />
                <DataGridTextColumn Header="Belge No" Binding="{Binding BelgeNo}" Width="95" />
                <DataGridTextColumn Header="Kategori" Binding="{Binding Kategori}" Width="95" />
                <DataGridTextColumn Header="Malzeme / Hizmet" Binding="{Binding Aciklama}" Width="*" MinWidth="140" />
                <DataGridTextColumn Header="Miktar" Binding="{Binding Miktar, StringFormat=N2}" Width="70" />
                <DataGridTextColumn Header="Birim" Binding="{Binding Birim}" Width="55" />
                <DataGridTextColumn Header="B.Fiyat" Binding="{Binding BirimFiyati, StringFormat='₺{0:N2}'}" Width="80" />
                <DataGridTextColumn Header="Artış" Binding="{Binding ArtisYuzdesiMetin}" Width="65" />
                <DataGridTextColumn Header="Tedarikçi" Binding="{Binding Tedarikci}" Width="110" />
                <DataGridTextColumn Header="Saha" Binding="{Binding Saha}" Width="100" />
                <DataGridTextColumn Header="Tutar" Binding="{Binding Tutar, StringFormat='₺{0:N2}'}" Width="95" />
              </DataGrid.Columns>
            </DataGrid>
          </TabItem>
        </TabControl>

        <DataGrid x:Name="AnaGrid" Grid.Row="1" Style="{StaticResource ModuleDataGridStyle}"
                  AlternatingRowBackground="Transparent" IsReadOnly="True"
                  AutoGenerateColumns="False" ScrollViewer.HorizontalScrollBarVisibility="Auto">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Modül" Binding="{Binding ModulAdi}" Width="*" MinWidth="160" />
            <DataGridTextColumn Header="Kayıt" Binding="{Binding KayitSayisi}" Width="80" />
            <DataGridTextColumn Header="Toplam Tutar" Binding="{Binding ToplamTutar, StringFormat='₺{0:N2}'}" Width="130" />
          </DataGrid.Columns>
        </DataGrid>
      </Grid>
    </Border>
  </Grid>
</UserControl>
