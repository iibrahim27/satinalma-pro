<UserControl x:Class="SatinalmaPro.Views.Modules.AlinanMalzemelerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:controls="clr-namespace:SatinalmaPro.Views.Controls"
             Background="{StaticResource ErpBgBrush}">
  <Grid x:Name="AnaIcerikGrid" Margin="24,20,24,20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" MinHeight="320" />
    </Grid.RowDefinitions>

    <!-- Üst bar -->
    <Grid Grid.Row="0" Margin="0,0,0,20">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel VerticalAlignment="Center">
        <TextBlock Text="Alınan Malzemeler" Style="{StaticResource ErpPageTitle}" />
        <TextBlock Text="Ana Sayfa  ›  Alınan Malzemeler" Style="{StaticResource ErpBreadcrumb}" Margin="0,6,0,0" />
        <TextBlock Text="Tedarikçi teslimatları, irsaliye ve fatura takibi" Style="{StaticResource ErpPageSubtitle}" Margin="0,4,0,0" />
      </StackPanel>
      <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
        <Button Style="{StaticResource PrimaryToolbarButtonStyle}" Click="YeniKayit_Click" Margin="0,0,8,8" Padding="14,9">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
            <TextBlock Text="Yeni Kayıt" />
          </StackPanel>
        </Button>
        <Button Style="{StaticResource ToolbarButtonStyle}" Click="ExcelYukle_Click" Margin="0,0,8,8" Padding="12,9" ToolTip="Excel Yükle">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0" />
            <TextBlock Text="Excel Yükle" />
          </StackPanel>
        </Button>
        <Button Style="{StaticResource ToolbarButtonStyle}" Click="SablonIndir_Click" Margin="0,0,8,8" Padding="12,9" ToolTip="Excel Şablonu İndir">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0" />
            <TextBlock Text="Excel Şablon" />
          </StackPanel>
        </Button>
        <Button Style="{StaticResource ToolbarButtonStyle}" Click="PdfIndir_Click" Margin="0,0,8,8" Padding="12,9">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0" />
            <TextBlock Text="PDF" />
          </StackPanel>
        </Button>
        <Button Style="{StaticResource ToolbarButtonStyle}" Click="PdfYazdir_Click" Margin="0,0,8,8" Padding="12,9">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0" />
            <TextBlock Text="Yazdır" />
          </StackPanel>
        </Button>
        <Button Style="{StaticResource ToolbarButtonStyle}" Click="DisaAktar_Click" Margin="0,0,8,8" Padding="12,9">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0" />
            <TextBlock Text="Dışa Aktar" />
          </StackPanel>
        </Button>
        <Button Style="{StaticResource ErpIconBtn}" Click="Yenile_Click" ToolTip="Yenile">
          <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource DashTextSecondaryBrush}" />
        </Button>
      </WrapPanel>
    </Grid>

    <!-- Filtre başlık + açılır panel -->
    <Border x:Name="FiltreBaslikKart" Grid.Row="1" Style="{StaticResource ErpCard}" Padding="16,14" Margin="0,0,0,16">
      <StackPanel>
        <Grid Margin="0,0,0,0">
          <TextBlock Text="Filtreleme Paneli" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource DashTextBrush}" VerticalAlignment="Center" />
          <Button x:Name="BtnFiltreToggle" Style="{StaticResource ErpFilterToggleBtn}" HorizontalAlignment="Right"
                  Click="FiltreToggle_Click" Content="▼ Filtreleri Göster" />
        </Grid>
        <Border x:Name="FilterIcerik" Style="{StaticResource ErpFilterPanel}" Margin="0,12,0,0" Padding="16,16,16,16" Visibility="Collapsed">
          <StackPanel>
            <UniformGrid Columns="4" Margin="0,0,0,12">
              <StackPanel Margin="0,0,12,12">
                <TextBlock Text="Arama" Style="{StaticResource FilterLabelStyle}" />
                <Grid>
                  <TextBox x:Name="TxtArama" Style="{StaticResource FilterBoxStyle}" Height="36"
                           TextChanged="FiltreDegisti"
                           ui:ControlHelper.PlaceholderText="Fatura, tedarikçi, malzeme..." />
                  <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                             Foreground="{StaticResource InkMutedBrush}" HorizontalAlignment="Right"
                             VerticalAlignment="Center" Margin="0,0,12,0" IsHitTestVisible="False" />
                </Grid>
              </StackPanel>
              <StackPanel Margin="0,0,12,12">
                <TextBlock Text="Başlangıç Tarihi" Style="{StaticResource FilterLabelStyle}" />
                <DatePicker x:Name="DpBaslangic" Height="36" SelectedDateChanged="FiltreDegisti" />
              </StackPanel>
              <StackPanel Margin="0,0,12,12">
                <TextBlock Text="Bitiş Tarihi" Style="{StaticResource FilterLabelStyle}" />
                <DatePicker x:Name="DpBitis" Height="36" SelectedDateChanged="FiltreDegisti" />
              </StackPanel>
              <StackPanel Margin="0,0,0,12">
                <TextBlock Text="Malzeme" Style="{StaticResource FilterLabelStyle}" />
                <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Background="White" CornerRadius="8" MinHeight="36">
                  <controls:MalzemeOneriGiris x:Name="MalzemeFiltre" />
                </Border>
              </StackPanel>
              <StackPanel Margin="0,0,12,12">
                <TextBlock Text="Tedarikçi" Style="{StaticResource FilterLabelStyle}" />
                <ComboBox x:Name="CmbTedarikci" Style="{StaticResource FilterComboStyle}" Height="36" SelectionChanged="FiltreDegisti" />
              </StackPanel>
              <StackPanel Margin="0,0,12,12">
                <TextBlock Text="Kategori" Style="{StaticResource FilterLabelStyle}" />
                <ComboBox x:Name="CmbKategori" Style="{StaticResource FilterComboStyle}" Height="36" SelectionChanged="FiltreDegisti" />
              </StackPanel>
              <StackPanel Margin="0,0,12,12">
                <TextBlock Text="Şantiye" Style="{StaticResource FilterLabelStyle}" />
                <ComboBox x:Name="CmbSantiye" Style="{StaticResource FilterComboStyle}" Height="36" SelectionChanged="FiltreDegisti" />
              </StackPanel>
              <StackPanel Margin="0,0,0,12">
                <TextBlock Text="Teslim Alan" Style="{StaticResource FilterLabelStyle}" />
                <ComboBox x:Name="CmbTeslimAlan" Style="{StaticResource FilterComboStyle}" Height="36" SelectionChanged="FiltreDegisti" />
              </StackPanel>
            </UniformGrid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
              <Button Style="{StaticResource PrimaryToolbarButtonStyle}" Content="Filtrele" Click="FiltreYenile_Click" Margin="0,0,8,0" Padding="16,8" />
              <Button Style="{StaticResource ToolbarButtonStyle}" Content="Temizle" Click="FiltreleriTemizle_Click" Margin="0,0,8,0" Padding="16,8" />
              <Button Style="{StaticResource ToolbarButtonStyle}" Click="PdfIndir_Click" Margin="0,0,8,0" Padding="16,8" Content="PDF Oluştur" />
              <Button Style="{StaticResource ToolbarButtonStyle}" Click="DisaAktar_Click" Padding="16,8" Content="Excel" />
            </StackPanel>
          </StackPanel>
        </Border>
      </StackPanel>
    </Border>

    <!-- KPI kartları -->
    <ScrollViewer x:Name="KpiScroll" Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,16">
      <StackPanel x:Name="KpiPanel" Orientation="Horizontal" />
    </ScrollViewer>

    <!-- Tablo kartı -->
    <Border x:Name="TabloKart" Grid.Row="4" Style="{StaticResource ErpCard}" Padding="0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Tablo toolbar -->
        <Border Grid.Row="0" Style="{StaticResource ErpTableToolbar}">
          <Grid>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock x:Name="TxtTabloBaslik" Text="Malzeme Listesi" FontSize="15" FontWeight="SemiBold"
                         Foreground="{StaticResource DashTextBrush}" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
              <Button Style="{StaticResource ErpTableToolbarBtn}" Content="Kolonlar" Click="Kolonlar_Click" />
              <Button Style="{StaticResource ErpTableToolbarBtn}" Content="Grupla" Click="Grupla_Click" />
              <Button Style="{StaticResource ErpTableToolbarBtn}" Content="Filtre" Click="FiltreOdak_Click" />
              <Button Style="{StaticResource ErpTableToolbarBtn}" Content="Excel" Click="DisaAktar_Click" />
              <Button Style="{StaticResource ErpTableToolbarBtn}" Content="PDF" Click="PdfIndir_Click" />
              <Button Style="{StaticResource ErpTableToolbarBtn}" Content="Yazdır" Click="PdfYazdir_Click" />
              <Button Style="{StaticResource ErpTableToolbarBtn}" Content="Yoğun" Click="YogunGorunum_Click" ToolTip="Satır yüksekliği" />
              <Button x:Name="BtnTamEkran" Style="{StaticResource ErpTableToolbarBtn}" Content="Tam Ekran" Click="TamEkran_Click" />
            </StackPanel>
          </Grid>
        </Border>

        <DataGrid x:Name="MalzemeGrid" Grid.Row="1"
                  Style="{StaticResource ErpPremiumGrid}"
                  CanUserReorderColumns="True"
                  LoadingRow="MalzemeGrid_LoadingRow"
                  SelectionChanged="MalzemeGrid_SelectionChanged"
                  MouseDoubleClick="MalzemeGrid_MouseDoubleClick"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Tarih" Binding="{Binding Tarih}" Width="95" />
            <DataGridTextColumn Header="İrsaliye No" Binding="{Binding FaturaNo}" Width="105" />
            <DataGridTextColumn Header="Sipariş No" Binding="{Binding SiparisNoGoster}" Width="100" />
            <DataGridTextColumn Header="Malzeme" Binding="{Binding MalzemeHizmet}" Width="160" />
            <DataGridTextColumn Header="Kategori" Binding="{Binding Kategori}" Width="100" />
            <DataGridTextColumn Header="Miktar" Binding="{Binding Miktar, StringFormat=N2}" Width="80" />
            <DataGridTextColumn Header="Birim" Binding="{Binding Birim}" Width="60" />
            <DataGridTextColumn Header="Birim Fiyat" Binding="{Binding BirimFiyati, StringFormat='₺{0:N2}'}" Width="100" />
            <DataGridTextColumn Header="% Artış" Binding="{Binding ArtisYuzdesiMetin}" Width="75" />
            <DataGridTextColumn Header="Toplam" Binding="{Binding ToplamTutar, StringFormat='₺{0:N2}'}" Width="110" />
            <DataGridTextColumn Header="Tedarikçi" Binding="{Binding Tedarikci}" Width="120" />
            <DataGridTextColumn Header="Şantiye" Binding="{Binding IndirildigiSaha}" Width="110" />
            <DataGridTextColumn Header="Teslim Alan" Binding="{Binding TeslimAlan}" Width="100" />
            <DataGridTextColumn Header="Açıklama" Binding="{Binding Aciklama}" Width="*" MinWidth="120" />
            <DataGridTemplateColumn Header="" Width="48" IsReadOnly="True">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <Button Style="{StaticResource ErpIconBtn}" Tag="{Binding}" Click="SatirMenu_Click" ToolTip="İşlemler">
                    <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource InkMutedBrush}" />
                  </Button>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>

        <!-- Alt özet çubuğu -->
        <Border Grid.Row="2" Style="{StaticResource ErpFooterBar}">
          <Grid>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock Style="{StaticResource ErpFooterText}" Text="Toplam Kayıt:" />
              <TextBlock x:Name="TxtAltKayit" Style="{StaticResource ErpFooterValue}" Text="0" />
              <TextBlock Style="{StaticResource ErpFooterText}" Text="Toplam Miktar:" />
              <TextBlock x:Name="TxtAltMiktar" Style="{StaticResource ErpFooterValue}" Text="0" />
              <TextBlock Style="{StaticResource ErpFooterText}" Text="Toplam Tutar:" />
              <TextBlock x:Name="TxtAltTutar" Style="{StaticResource ErpFooterValue}" Text="₺0" />
              <TextBlock x:Name="TxtGrupBilgi" Style="{StaticResource ErpFooterText}" Margin="12,0,0,0" Visibility="Collapsed" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
              <TextBlock Text="Sayfa boyutu:" Style="{StaticResource ErpFooterText}" Margin="0,0,8,0" />
              <ComboBox x:Name="CmbSayfaBoyutu" Width="72" Height="28" VerticalContentAlignment="Center"
                        SelectionChanged="SayfaBoyutuDegisti">
                <ComboBoxItem Content="25" Tag="25" />
                <ComboBoxItem Content="50" Tag="50" IsSelected="True" />
                <ComboBoxItem Content="100" Tag="100" />
                <ComboBoxItem Content="200" Tag="200" />
              </ComboBox>
            </StackPanel>
          </Grid>
        </Border>

        <controls:SayfalamaCubugu x:Name="SayfalamaBar" Grid.Row="3" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
