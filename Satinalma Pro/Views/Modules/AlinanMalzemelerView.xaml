<UserControl x:Class="SatinalmaPro.Views.Modules.AlinanMalzemelerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:helpers="clr-namespace:SatinalmaPro.Helpers"
             xmlns:controls="clr-namespace:SatinalmaPro.Views.Controls">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Araç çubuğu -->
    <Border Grid.Row="0"
            Background="White"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="14,12"
            Margin="0,0,0,12">
      <Grid>
        <StackPanel Orientation="Horizontal">
          <Button Style="{StaticResource PrimaryToolbarButtonStyle}"
                  Click="ExcelYukle_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Excel Yükle" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}"
                  Click="SablonIndir_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Excel Şablon" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}"
                  Click="PdfIndir_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="PDF İndir" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}"
                  Click="PdfYazdir_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="PDF Yazdır" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}"
                  Click="YeniKayit_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Yeni Kayıt" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}"
                  Click="DisaAktar_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Dışa Aktar" />
            </StackPanel>
          </Button>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Style="{StaticResource ToolbarButtonStyle}"
                  Margin="0"
                  Click="Yenile_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Yenile" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Filtre şeridi -->
    <Border Grid.Row="1"
            Background="White"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="14,12,30,12"
            Margin="0,0,0,12">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" MinWidth="180" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,8">
          <TextBlock Text="Ara" Style="{StaticResource FilterLabelStyle}" />
          <Grid>
            <TextBox x:Name="TxtArama"
                     Style="{StaticResource FilterBoxStyle}"
                     TextChanged="FiltreDegisti"
                     ui:ControlHelper.PlaceholderText="Fatura no, tedarikçi veya saha ara..." />
            <TextBlock Text="&#xE721;"
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="14"
                       Foreground="{StaticResource InkMutedBrush}"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"
                       IsHitTestVisible="False" />
          </Grid>
        </StackPanel>

        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,8">
          <TextBlock Text="Başlangıç" Style="{StaticResource FilterLabelStyle}" />
          <DatePicker x:Name="DpBaslangic"
                      Width="130"
                      SelectedDateChanged="FiltreDegisti" />
        </StackPanel>

        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,8,8">
          <TextBlock Text="Bitiş" Style="{StaticResource FilterLabelStyle}" />
          <DatePicker x:Name="DpBitis"
                      Width="130"
                      SelectedDateChanged="FiltreDegisti" />
        </StackPanel>

        <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,8,8">
          <TextBlock Text="Malzeme" Style="{StaticResource FilterLabelStyle}" />
          <Border BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Background="White" CornerRadius="4" Padding="2,0" MinHeight="34" Width="160">
            <controls:MalzemeOneriGiris x:Name="MalzemeFiltre" />
          </Border>
        </StackPanel>

        <StackPanel Grid.Row="0" Grid.Column="4" Margin="0,0,0,8">
          <TextBlock Text="Kategori" Style="{StaticResource FilterLabelStyle}" />
          <ComboBox x:Name="CmbKategori"
                    Style="{StaticResource FilterComboStyle}"
                    Width="140"
                    SelectionChanged="FiltreDegisti" />
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
          <TextBlock Text="Tedarikçi" Style="{StaticResource FilterLabelStyle}" />
          <ComboBox x:Name="CmbTedarikci"
                    Style="{StaticResource FilterComboStyle}"
                    SelectionChanged="FiltreDegisti" />
        </StackPanel>

        <Button Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                Style="{StaticResource ToolbarButtonStyle}"
                Margin="0,0,8,0"
                VerticalAlignment="Bottom"
                Content="Filtreleri Temizle"
                Click="FiltreleriTemizle_Click" />

        <Button Grid.Row="1" Grid.Column="3" Grid.ColumnSpan="2"
                Style="{StaticResource PrimaryToolbarButtonStyle}"
                Margin="0"
                VerticalAlignment="Bottom"
                Click="PdfIndir_Click">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
            <TextBlock Text="Filtreli PDF İndir" />
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <!-- Özet kartları -->
    <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                Margin="0,0,0,12">
      <Border Style="{StaticResource StatChipStyle}">
        <StackPanel>
          <TextBlock Text="Toplam Kayıt" FontSize="11" Foreground="{StaticResource InkMutedBrush}" />
          <TextBlock x:Name="TxtToplamKayit" Text="0" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" Margin="0,2,0,0" />
        </StackPanel>
      </Border>
      <Border Style="{StaticResource StatChipStyle}">
        <StackPanel>
          <TextBlock Text="Toplam Miktar" FontSize="11" Foreground="{StaticResource InkMutedBrush}" />
          <TextBlock x:Name="TxtToplamMiktar" Text="0 Ton" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" Margin="0,2,0,0" />
        </StackPanel>
      </Border>
      <Border Style="{StaticResource StatChipStyle}">
        <StackPanel>
          <TextBlock Text="Toplam Tutar" FontSize="11" Foreground="{StaticResource InkMutedBrush}" />
          <TextBlock x:Name="TxtToplamTutar" Text="₺0" FontSize="22" FontWeight="SemiBold" Foreground="#6366F1" Margin="0,2,0,0" />
        </StackPanel>
      </Border>
      <Border Style="{StaticResource StatChipStyle}" Margin="0">
        <StackPanel>
          <TextBlock Text="Filtrelenen" FontSize="11" Foreground="{StaticResource InkMutedBrush}" />
          <TextBlock x:Name="TxtFiltrelenen" Text="0 kayıt" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" Margin="0,2,0,0" />
        </StackPanel>
      </Border>
    </StackPanel>

    <Border Grid.Row="3"
            Background="White"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="14,12,30,12"
            Margin="0,0,0,12">
      <StackPanel Orientation="Horizontal">
        <Button x:Name="BtnKayitDuzenle" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"
                IsEnabled="False" Click="KayitDuzenle_Click" Content="Düzenle" />
        <Button x:Name="BtnKayitSil" Style="{StaticResource ToolbarButtonStyle}" Margin="0"
                IsEnabled="False" Click="KayitSil_Click" Content="Sil" />
      </StackPanel>
    </Border>

    <!-- Veri tablosu -->
    <Border Grid.Row="4"
            Background="White"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="1">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
      <DataGrid x:Name="MalzemeGrid"
                Grid.Row="0"
                Style="{StaticResource ModuleDataGridStyle}"
                AlternatingRowBackground="Transparent"
                LoadingRow="MalzemeGrid_LoadingRow"
                SelectionChanged="MalzemeGrid_SelectionChanged"
                MouseDoubleClick="MalzemeGrid_MouseDoubleClick"
                ScrollViewer.HorizontalScrollBarVisibility="Auto">
        <DataGrid.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Düzenle" Click="MenuDuzenle_Click" />
            <Separator />
            <MenuItem Header="Sil" Click="MenuSil_Click" />
          </ContextMenu>
        </DataGrid.ContextMenu>
        <DataGrid.Columns>
          <DataGridTextColumn Header="Tarih" Binding="{Binding Tarih}" Width="95" />
          <DataGridTextColumn Header="Fatura No" Binding="{Binding FaturaNo}" Width="105" />
          <DataGridTextColumn Header="Kategori" Binding="{Binding Kategori}" Width="110" />
          <DataGridTextColumn Header="Malzeme / Hizmet" Binding="{Binding MalzemeHizmet}" Width="160" />
          <DataGridTextColumn Header="Miktar" Binding="{Binding Miktar, StringFormat=N2}" Width="80" />
          <DataGridTextColumn Header="Birim" Binding="{Binding Birim}" Width="65" />
          <DataGridTextColumn Header="Birim Fiyatı" Binding="{Binding BirimFiyati, StringFormat='₺{0:N2}'}" Width="105" />
          <DataGridTextColumn Header="% Artış" Binding="{Binding ArtisYuzdesiMetin}" Width="80" />
          <DataGridTextColumn Header="Toplam Tutar" Binding="{Binding ToplamTutar, StringFormat='₺{0:N2}'}" Width="115" />
          <DataGridTextColumn Header="Tedarikçi" Binding="{Binding Tedarikci}" Width="130" />
          <DataGridTextColumn Header="İndirildiği Saha" Binding="{Binding IndirildigiSaha}" Width="120" />
          <DataGridTextColumn Header="Teslim Alan" Binding="{Binding TeslimAlan}" Width="110" />
          <DataGridTextColumn Header="Açıklama" Binding="{Binding Aciklama}" Width="*" MinWidth="140" />
        </DataGrid.Columns>
      </DataGrid>
      <controls:SayfalamaCubugu x:Name="SayfalamaBar" Grid.Row="1" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
