<Window x:Class="SatinalmaPro.Views.Modules.AracFiloGiderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Araç Giderleri"
        Width="720" Height="480" MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" Background="White">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid Grid.Row="0" Margin="0,0,0,12">
      <StackPanel>
        <TextBlock x:Name="TxtBaslik" FontSize="20" FontWeight="SemiBold" />
        <TextBlock x:Name="TxtToplam" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,4,0,0" />
      </StackPanel>
      <Button Style="{StaticResource PrimaryToolbarButtonStyle}" Content="Gider Ekle"
              HorizontalAlignment="Right" VerticalAlignment="Center" Click="GiderEkle_Click" />
    </Grid>
    <DataGrid x:Name="GiderGrid" Grid.Row="1" Style="{StaticResource ModuleDataGridStyle}"
              AlternatingRowBackground="Transparent" IsReadOnly="True" AutoGenerateColumns="False"
              SelectionChanged="GiderGrid_SelectionChanged"
              MouseDoubleClick="GiderGrid_MouseDoubleClick">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Tarih" Binding="{Binding Tarih}" Width="95" />
        <DataGridTextColumn Header="Gider Tipi" Binding="{Binding GiderTipi}" Width="110" />
        <DataGridTextColumn Header="Tutar" Binding="{Binding TutarMetin}" Width="100" />
        <DataGridTextColumn Header="Belge No" Binding="{Binding BelgeNo}" Width="100" />
        <DataGridTextColumn Header="Açıklama" Binding="{Binding Aciklama}" Width="*" MinWidth="140" />
      </DataGrid.Columns>
    </DataGrid>
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button x:Name="BtnGiderDuzenle" Content="Düzenle" Style="{StaticResource ToolbarButtonStyle}" Width="100"
              Margin="0,0,8,0" IsEnabled="False" Click="GiderDuzenle_Click" />
      <Button x:Name="BtnGiderSil" Content="Sil" Style="{StaticResource ToolbarButtonStyle}" Width="100"
              Margin="0,0,8,0" IsEnabled="False" Click="GiderSil_Click" />
      <Button Content="Kapat" Style="{StaticResource ToolbarButtonStyle}" Width="100"
              Click="Kapat_Click" />
    </StackPanel>
  </Grid>
</Window>
