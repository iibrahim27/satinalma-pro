<UserControl x:Class="SatinalmaPro.Views.Modules.Satinalma.Part1.TalepListesiView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource DashBackgroundBrush}">
  <Border Style="{StaticResource SatModCard}">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <TextBlock x:Name="TxtYardim" Style="{StaticResource SatModHint}" Margin="0,0,0,12" />

      <DataGrid x:Name="Tablo" Grid.Row="1" Style="{StaticResource SatModDataGrid}"
                MouseDoubleClick="Tablo_MouseDoubleClick">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Talep No" Binding="{Binding TalepNo}" Width="110" />
          <DataGridTextColumn Header="Tarih" Binding="{Binding Tarih}" Width="90" />
          <DataGridTextColumn Header="Talep Eden" Binding="{Binding TalepEden}" Width="140" />
          <DataGridTextColumn Header="Öncelik" Binding="{Binding Oncelik}" Width="90" />
          <DataGridTextColumn Header="Talep Durumu" Binding="{Binding TalepDurumu}" Width="*" />
          <DataGridTextColumn Header="Teklif Durumu" Binding="{Binding TeklifDurumu}" Width="*" />
        </DataGrid.Columns>
      </DataGrid>
    </Grid>
  </Border>
</UserControl>
