<UserControl x:Class="SatinalmaPro.Views.Modules.Satinalma.Part1.SatinalmaIadeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             Background="{StaticResource SatModBgBrush}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <UniformGrid x:Name="KpiPanel" Grid.Row="0" Rows="1" Columns="3" Margin="0,0,0,16" />

    <Border Grid.Row="1" Style="{StaticResource SatModPremiumCard}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" MinHeight="320" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBlock Text="İade Kayıtları" Style="{StaticResource SatModSectionTitle}" VerticalAlignment="Center" />
          <Button x:Name="BtnYeniIade" Grid.Column="1"
                  Content="Yeni İade"
                  Style="{StaticResource PrimaryToolbarButtonStyle}"
                  Padding="16,9" Margin="0,0,12,0"
                  Click="YeniIade_Click" />
          <Grid Grid.Column="2" Width="240">
            <TextBox x:Name="TxtArama" Style="{StaticResource FilterBoxStyle}" Height="36"
                     TextChanged="AramaDegisti"
                     ui:ControlHelper.PlaceholderText="İade no, firma, malzeme..." />
            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                       Foreground="{StaticResource InkMutedBrush}" HorizontalAlignment="Right"
                       VerticalAlignment="Center" Margin="0,0,12,0" IsHitTestVisible="False" />
          </Grid>
        </Grid>

        <Border Grid.Row="1" Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1">
          <Grid>
            <DataGrid x:Name="IadeGrid" Style="{StaticResource SatModPanosuGrid}"
                      CanUserSortColumns="True" CanUserResizeColumns="True">
              <DataGrid.Columns>
                <DataGridTextColumn Header="İade No" Binding="{Binding IadeNo}" Width="110" />
                <DataGridTextColumn Header="Sipariş No" Binding="{Binding SiparisNo}" Width="110" />
                <DataGridTextColumn Header="Firma" Binding="{Binding Firma}" Width="140" />
                <DataGridTextColumn Header="Malzeme" Binding="{Binding Malzeme}" Width="*" MinWidth="160" />
                <DataGridTextColumn Header="Miktar" Binding="{Binding Miktar}" Width="90" />
                <DataGridTextColumn Header="Neden" Binding="{Binding Neden}" Width="160" />
                <DataGridTextColumn Header="Durum" Binding="{Binding Durum}" Width="110" />
                <DataGridTextColumn Header="Tarih" Binding="{Binding Tarih}" Width="95" />
              </DataGrid.Columns>
            </DataGrid>

            <Border x:Name="BosPanel" Background="White" CornerRadius="12" Padding="32,28" Visibility="Collapsed">
              <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="480">
                <TextBlock Text="Henüz iade kaydı yok"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource SatModInkBrush}"
                           TextAlignment="Center" />
                <TextBlock Text="Hasarlı veya hatalı malzeme iadelerini buradan kaydedebilirsiniz. Kabul edilmiş kalemlerden seçim yapabilir veya manuel giriş yapabilirsiniz."
                           FontSize="13" Foreground="{StaticResource InkMutedBrush}"
                           TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0" />
                <Button Content="Yeni İade Oluştur"
                        Style="{StaticResource PrimaryToolbarButtonStyle}"
                        HorizontalAlignment="Center" Margin="0,20,0,0" Padding="20,10"
                        Click="YeniIade_Click" />
              </StackPanel>
            </Border>
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
</UserControl>
