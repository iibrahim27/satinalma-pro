<Window x:Class="SatinalmaPro.Views.Modules.Satinalma.Part1.TalepMiktarDuzenlemeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Talep Miktarlarını Düzenle" Height="430" Width="720"
        MinHeight="360" MinWidth="620" WindowStartupLocation="CenterOwner"
        Background="{StaticResource DashBackgroundBrush}">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Margin="0,0,0,16">
      <TextBlock Text="Talep miktarlarını güncelle" FontSize="20" FontWeight="SemiBold"
                 Foreground="{StaticResource DashTextBrush}" />
      <TextBlock x:Name="TxtAciklama" Margin="0,6,0,0" TextWrapping="Wrap"
                 Foreground="{StaticResource DashTextSecondaryBrush}" />
    </StackPanel>

    <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource DashBorderBrush}"
            BorderThickness="1" CornerRadius="10">
      <DataGrid x:Name="KalemTablosu" Style="{StaticResource SatModDataGrid}"
                AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                CanUserReorderColumns="False" SelectionMode="Single">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Malzeme" Binding="{Binding Malzeme}" Width="*" IsReadOnly="True" />
          <DataGridTextColumn Header="Birim" Binding="{Binding Birim}" Width="100" IsReadOnly="True" />
          <DataGridTextColumn Header="Talep Miktarı" Width="150">
            <DataGridTextColumn.Binding>
              <Binding Path="Miktar" UpdateSourceTrigger="PropertyChanged" StringFormat="N2" />
            </DataGridTextColumn.Binding>
          </DataGridTextColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <Grid Grid.Row="2" Margin="0,18,0,0">
      <TextBlock Text="Yalnızca miktar alanı değiştirilebilir." VerticalAlignment="Center"
                 Foreground="{StaticResource DashTextSecondaryBrush}" FontSize="12" />
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="Vazgeç" Style="{StaticResource ToolbarButtonStyle}"
                Click="Vazgec_Click" Margin="0,0,8,0" Padding="16,9" />
        <Button Content="Miktarları Kaydet" Style="{StaticResource PrimaryToolbarButtonStyle}"
                Click="Kaydet_Click" Padding="18,9" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>
