<UserControl x:Class="SatinalmaPro.Views.Modules.Satinalma.Part1.YonetimTalepDetayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource DashBackgroundBrush}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Button Style="{StaticResource SatModBackButton}" Click="Geri_Click" Content="← Listeye dön" />

    <Border Grid.Row="1" Style="{StaticResource SatModCard}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,14">
          <TextBlock x:Name="TxtBaslik" FontSize="18" FontWeight="Bold"
                     Foreground="{StaticResource SatModInkBrush}" />
          <TextBlock x:Name="TxtOzet" Style="{StaticResource SatModHint}" Margin="0,6,0,0" TextWrapping="Wrap" />
          <TextBlock x:Name="TxtOnaylayan" Style="{StaticResource SatModHint}" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1"
                CornerRadius="10" Padding="12,10" Margin="0,0,0,14">
          <TextBlock x:Name="TxtDurum" FontSize="12" Foreground="#334155" TextWrapping="Wrap" />
        </Border>

        <StackPanel Grid.Row="2">
          <TextBlock Text="Talep Kalemleri" Style="{StaticResource SatModSectionTitle}" />
          <DataGrid x:Name="KalemTablosu" Style="{StaticResource SatModDataGrid}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Malzeme" Binding="{Binding Malzeme}" Width="*" />
              <DataGridTextColumn Header="Miktar" Binding="{Binding MiktarMetni}" Width="100" />
              <DataGridTextColumn Header="Firma" Binding="{Binding Firma}" Width="*" />
              <DataGridTextColumn Header="Birim Fiyat" Binding="{Binding BirimFiyatMetni}" Width="110" />
              <DataGridTextColumn Header="Toplam" Binding="{Binding ToplamMetni}" Width="110" />
            </DataGrid.Columns>
          </DataGrid>
        </StackPanel>
      </Grid>
    </Border>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
      <Button x:Name="BtnKarsilastirmaPdf" Content="Karşılaştırma PDF" Style="{StaticResource ToolbarButtonStyle}"
              Click="KarsilastirmaPdf_Click" Margin="0,0,8,0" Padding="12,8" Visibility="Collapsed" />
      <Button x:Name="BtnOnayPdf" Content="Onay Belgesi PDF" Style="{StaticResource ToolbarButtonStyle}"
              Click="OnayPdf_Click" Padding="12,8" Visibility="Collapsed" />
    </StackPanel>
  </Grid>
</UserControl>
