<UserControl x:Class="SatinalmaPro.Views.Modules.Satinalma.Part1.SatinalmaBosSekmeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource DashBackgroundBrush}">
  <Border Background="White"
          BorderBrush="{StaticResource LineBrush}"
          BorderThickness="1"
          CornerRadius="12"
          Padding="40,36">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="520">
      <TextBlock x:Name="TxtBaslik"
                 FontSize="20"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource SatModInkBrush}"
                 TextAlignment="Center"
                 TextWrapping="Wrap" />
      <TextBlock x:Name="TxtAciklama"
                 FontSize="13"
                 Foreground="{StaticResource InkMutedBrush}"
                 TextAlignment="Center"
                 TextWrapping="Wrap"
                 Margin="0,10,0,0" />
      <Border Height="1"
              Width="56"
              Background="{StaticResource LineBrush}"
              Margin="0,22"
              HorizontalAlignment="Center" />
      <TextBlock Text="Bu sekme bir sonraki adımda doldurulacak."
                 FontSize="13"
                 Foreground="{StaticResource InkMutedBrush}"
                 TextAlignment="Center"
                 TextWrapping="Wrap" />
    </StackPanel>
  </Border>
</UserControl>
