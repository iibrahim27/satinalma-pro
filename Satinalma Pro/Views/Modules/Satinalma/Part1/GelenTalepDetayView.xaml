<UserControl x:Class="SatinalmaPro.Views.Modules.Satinalma.Part1.GelenTalepDetayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource DashBackgroundBrush}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Button Style="{StaticResource SatModBackButton}" Click="Geri_Click" Content="← Listeye dön" />

    <Border Grid.Row="1" Style="{StaticResource SatModCard}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,16">
          <TextBlock x:Name="TxtBaslik" FontSize="18" FontWeight="Bold"
                     Foreground="{StaticResource SatModInkBrush}" />
          <TextBlock x:Name="TxtOzet" Style="{StaticResource SatModHint}" Margin="0,6,0,0" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,16">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <StackPanel Margin="0,0,12,0">
            <TextBlock Text="Talep Durumu" Style="{StaticResource SatModHint}" />
            <TextBlock x:Name="TxtTalepDurumu" FontWeight="SemiBold" Margin="0,4,0,0" />
          </StackPanel>
          <StackPanel Grid.Column="1" Margin="0,0,12,0">
            <TextBlock Text="Teklif Durumu" Style="{StaticResource SatModHint}" />
            <TextBlock x:Name="TxtTeklifDurumu" FontWeight="SemiBold" Margin="0,4,0,0" />
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Text="Öncelik" Style="{StaticResource SatModHint}" />
            <TextBlock x:Name="TxtOncelik" FontWeight="SemiBold" Margin="0,4,0,0" />
          </StackPanel>
        </Grid>

        <DataGrid x:Name="KalemTablosu" Grid.Row="2" Style="{StaticResource SatModDataGrid}">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Malzeme" Binding="{Binding Malzeme}" Width="*" />
            <DataGridTextColumn Header="Miktar" Binding="{Binding MiktarGosterim}" Width="90" />
            <DataGridTextColumn Header="Birim" Binding="{Binding Birim}" Width="90" />
          </DataGrid.Columns>
        </DataGrid>
      </Grid>
    </Border>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
      <Button Content="Talep PDF" Style="{StaticResource ToolbarButtonStyle}"
              Click="TalepPdf_Click" Margin="0,0,8,0" Padding="14,8"
              ToolTip="İmzalı talep formu PDF çıktısı" />
      <Button x:Name="BtnReddet" Content="Reddet" Style="{StaticResource ToolbarButtonStyle}"
              Click="Reddet_Click" Margin="0,0,8,0" />
      <Button x:Name="BtnTeklifAl" Content="Teklif Al" Style="{StaticResource ToolbarButtonStyle}"
              Click="TeklifAl_Click" Margin="0,0,8,0" />
      <Button x:Name="BtnOnayla" Content="Onayla" Style="{StaticResource PrimaryToolbarButtonStyle}"
              Click="Onayla_Click" Padding="18,10" />
    </StackPanel>
  </Grid>
</UserControl>
