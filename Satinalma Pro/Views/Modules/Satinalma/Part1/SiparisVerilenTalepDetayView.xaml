<UserControl x:Class="SatinalmaPro.Views.Modules.Satinalma.Part1.SiparisVerilenTalepDetayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="{StaticResource DashBackgroundBrush}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Button Style="{StaticResource SatModBackButton}" Click="Geri_Click" Content="← Listeye dön" />

    <Border Grid.Row="1" Style="{StaticResource SatModCard}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,14">
          <TextBlock x:Name="TxtBaslik" FontSize="18" FontWeight="Bold"
                     Foreground="{StaticResource SatModInkBrush}" />
          <TextBlock x:Name="TxtOzet" Style="{StaticResource SatModHint}" Margin="0,6,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1" Background="#EFF6FF" BorderBrush="#93C5FD" BorderThickness="1"
                CornerRadius="10" Padding="12,10" Margin="0,0,0,14">
          <TextBlock x:Name="TxtDurum" FontSize="12" Foreground="#1D4ED8" TextWrapping="Wrap" />
        </Border>

        <StackPanel Grid.Row="2">
          <TextBlock Text="Sipariş Kalemleri" Style="{StaticResource SatModSectionTitle}" />
          <DataGrid x:Name="KalemTablosu" Style="{StaticResource SatModDataGrid}"
                    SelectionChanged="KalemTablosu_SelectionChanged"
                    MouseDoubleClick="KalemTablosu_MouseDoubleClick">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Malzeme" Binding="{Binding Malzeme}" Width="*" />
              <DataGridTextColumn Header="Sipariş" Binding="{Binding SiparisMiktariMetni}" Width="90" />
              <DataGridTextColumn Header="Kabul" Binding="{Binding KabulMiktarMetni}" Width="90" />
              <DataGridTextColumn Header="Kalan" Binding="{Binding KalanMiktarMetni}" Width="90" />
              <DataGridTextColumn Header="Firma" Binding="{Binding Firma}" Width="*" />
              <DataGridTextColumn Header="Durum" Binding="{Binding KabulDurumu}" Width="100" />
            </DataGrid.Columns>
          </DataGrid>
        </StackPanel>
      </Grid>
    </Border>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
      <Button x:Name="BtnSevkiyatiTamamla" Content="Sevkiyatı Tamamla" Style="{StaticResource ToolbarButtonStyle}"
              Click="SevkiyatiTamamla_Click" Padding="18,8" Margin="0,0,8,0" IsEnabled="False" />
      <Button x:Name="BtnMalKabul" Content="Mal Kabul — Depoya Kaydet" Style="{StaticResource PrimaryToolbarButtonStyle}"
              Click="MalKabul_Click" Padding="18,8" IsEnabled="False" />
    </StackPanel>
  </Grid>
</UserControl>
