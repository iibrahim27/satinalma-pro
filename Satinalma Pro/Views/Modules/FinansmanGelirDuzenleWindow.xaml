<Window x:Class="SatinalmaPro.Views.Modules.FinansmanGelirDuzenleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Gelir Kaydı"
        Width="540"
        Height="680"
        MinWidth="480"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="White">
  <Grid Margin="28">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,20">
      <TextBlock Text="Gelir Kaydı" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
      <TextBlock Text="Proje geliri, hakediş veya diğer gelir kayıtlarını girin"
                 FontSize="13" Foreground="{StaticResource InkMutedBrush}" Margin="0,4,0,0" />
    </StackPanel>

    <ScrollViewer Grid.Row="1" Style="{StaticResource ModuleScrollViewerStyle}">
      <StackPanel>
        <TextBlock Text="Tarih" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
        <TextBox x:Name="TxtTarih" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,14" />

        <TextBlock Text="Belge No" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
        <TextBox x:Name="TxtBelgeNo" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,14" />

        <TextBlock Text="Kategori" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
        <ComboBox x:Name="CmbKategori" Style="{StaticResource FilterComboStyle}" Margin="0,0,0,14" IsEditable="True" />

        <TextBlock Text="Açıklama" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
        <TextBox x:Name="TxtAciklama" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,14" />

        <TextBlock Text="Kaynak / Ödeyen" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
        <TextBox x:Name="TxtKaynak" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,14" />

        <TextBlock Text="Saha / Proje" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
        <TextBox x:Name="TxtSaha" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,14" />

        <Grid Margin="0,0,0,14">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0">
            <TextBlock Text="Tutar (₺)" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
            <TextBox x:Name="TxtTutar" Style="{StaticResource FilterBoxStyle}" />
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Text="Ödeme Şekli" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
            <ComboBox x:Name="CmbOdemeSekli" Style="{StaticResource FilterComboStyle}" IsEditable="True" />
          </StackPanel>
        </Grid>

        <TextBlock Text="Notlar" FontSize="12" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,6" />
        <TextBox x:Name="TxtNotlar" Style="{StaticResource FilterBoxStyle}" Height="72"
                 TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
      </StackPanel>
    </ScrollViewer>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
      <Button Style="{StaticResource ToolbarButtonStyle}" Content="İptal" Width="100" Margin="0,0,10,0" Click="Iptal_Click" />
      <Button Style="{StaticResource PrimaryToolbarButtonStyle}" Content="Kaydet" Width="110" Click="Kaydet_Click" />
    </StackPanel>
  </Grid>
</Window>
