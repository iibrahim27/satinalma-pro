<Window x:Class="SatinalmaPro.Views.Modules.CimentoDuzenleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Çimento Kaydı Düzenle"
        Width="560"
        Height="720"
        MinWidth="480"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource DashBackgroundBrush}">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,16">
      <TextBlock Text="Çimento Kaydı" Style="{StaticResource ModuleDialogTitleStyle}" />
      <TextBlock Text="Gelen çimento kaydını güncelleyin" Style="{StaticResource ModuleDialogSubtitleStyle}" />
    </StackPanel>

    <Border Grid.Row="1" Style="{StaticResource ModulePageCardStyle}" Padding="24,20">
      <ScrollViewer Style="{StaticResource ModuleScrollViewerStyle}" Padding="0">
      <StackPanel>
        <TextBlock Text="Tarih" Style="{StaticResource ModuleFormLabelStyle}" />
        <TextBox x:Name="TxtTarih" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,14" />

        <TextBlock Text="İrsaliye No" Style="{StaticResource ModuleFormLabelStyle}" />
        <TextBox x:Name="TxtIrsaliyeNo" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,14" />

        <TextBlock Text="Çimento Sınıfı" Style="{StaticResource ModuleFormLabelStyle}" />
        <ComboBox x:Name="CmbCimentoSinifi" Style="{StaticResource FilterComboStyle}" Margin="0,0,0,14" IsEditable="True">
          <ComboBoxItem Content="CEM I" />
          <ComboBoxItem Content="CEM II" />
          <ComboBoxItem Content="CEM III" />
          <ComboBoxItem Content="CEM IV" />
          <ComboBoxItem Content="Beyaz Çimento" />
          <ComboBoxItem Content="Diğer" />
        </ComboBox>

        <TextBlock Text="Çimento Cinsi" Style="{StaticResource ModuleFormLabelStyle}" />
        <ComboBox x:Name="CmbCimentoCinsi" Style="{StaticResource FilterComboStyle}" Margin="0,0,0,14" IsEditable="True">
          <ComboBoxItem Content="CEM I 42.5R" />
          <ComboBoxItem Content="CEM I 52.5N" />
          <ComboBoxItem Content="CEM II 32.5R" />
          <ComboBoxItem Content="CEM II 42.5R" />
          <ComboBoxItem Content="CEM III 32.5R" />
          <ComboBoxItem Content="Beyaz Çimento 52.5" />
        </ComboBox>

        <Grid Margin="0,0,0,14">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0">
            <TextBlock Text="Miktar" Style="{StaticResource ModuleFormLabelStyle}" />
            <TextBox x:Name="TxtMiktar" Style="{StaticResource FilterBoxStyle}" TextChanged="TutarHesapla" />
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Text="Birim" Style="{StaticResource ModuleFormLabelStyle}" />
            <TextBox x:Name="TxtBirim" Style="{StaticResource FilterBoxStyle}" />
          </StackPanel>
        </Grid>

        <Grid Margin="0,0,0,14">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0">
            <TextBlock Text="Birim Fiyatı" Style="{StaticResource ModuleFormLabelStyle}" />
            <TextBox x:Name="TxtBirimFiyati" Style="{StaticResource FilterBoxStyle}" TextChanged="TutarHesapla" />
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Text="Toplam Tutar" Style="{StaticResource ModuleFormLabelStyle}" />
            <TextBox x:Name="TxtToplamTutar" Style="{StaticResource ModuleReadOnlyFieldStyle}" />
          </StackPanel>
        </Grid>

        <TextBlock Text="Tedarikçi" Style="{StaticResource ModuleFormLabelStyle}" />
        <TextBox x:Name="TxtTedarikci" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,14" />

        <TextBlock Text="İndirildiği Saha" Style="{StaticResource ModuleFormLabelStyle}" />
        <TextBox x:Name="TxtIndirildigiSaha" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,14" />

        <TextBlock Text="Teslim Alan" Style="{StaticResource ModuleFormLabelStyle}" />
        <TextBox x:Name="TxtTeslimAlan" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,14" />

        <TextBlock Text="Açıklama" Style="{StaticResource ModuleFormLabelStyle}" />
        <TextBox x:Name="TxtAciklama" Style="{StaticResource FilterBoxStyle}" Height="80"
                 TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="12,10" />
      </StackPanel>
    </ScrollViewer>
    </Border>
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
      <Button Content="İptal" Style="{StaticResource ToolbarButtonStyle}" Width="100" Margin="0,0,8,0" Click="Iptal_Click" />
      <Button Content="Kaydet" Style="{StaticResource PrimaryToolbarButtonStyle}" Width="120" Click="Kaydet_Click" />
    </StackPanel>
  </Grid>
</Window>
