<Window x:Class="SatinalmaPro.Views.Modules.AlinanMalzemeAktarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Alınan Malzemelere Aktar"
        Width="440"
        SizeToContent="Height"
        MaxHeight="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,16">
      <TextBlock Text="Alınan Malzemelere Aktar"
                 FontSize="18"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource InkBrush}" />
      <TextBlock x:Name="TxtMalzeme"
                 TextWrapping="Wrap"
                 FontSize="13"
                 Foreground="{StaticResource InkMutedBrush}"
                 Margin="0,6,0,0" />
    </StackPanel>

    <ScrollViewer Grid.Row="1" Style="{StaticResource ModuleScrollViewerStyle}">
      <StackPanel>
        <TextBlock Text="Miktar"
                   FontSize="12"
                   Foreground="{StaticResource InkMutedBrush}"
                   Margin="0,0,0,6" />
        <TextBox x:Name="TxtMiktar"
                 Style="{StaticResource FilterBoxStyle}"
                 Margin="0,0,0,14" />

        <TextBlock Text="Kategori"
                   FontSize="12"
                   Foreground="{StaticResource InkMutedBrush}"
                   Margin="0,0,0,6" />
        <ComboBox x:Name="CmbKategori"
                  Style="{StaticResource FilterComboStyle}"
                  IsEditable="False"
                  Margin="0,0,0,14" />

        <TextBlock Text="Tarih"
                   FontSize="12"
                   Foreground="{StaticResource InkMutedBrush}"
                   Margin="0,0,0,6" />
        <TextBox x:Name="TxtTarih"
                 Style="{StaticResource FilterBoxStyle}"
                 Margin="0,0,0,14" />

        <TextBlock Text="Fiş No"
                   FontSize="12"
                   Foreground="{StaticResource InkMutedBrush}"
                   Margin="0,0,0,6" />
        <TextBox x:Name="TxtFisNo"
                 Style="{StaticResource FilterBoxStyle}"
                 Margin="0,0,0,14" />

        <TextBlock Text="Teslim Alan"
                   FontSize="12"
                   Foreground="{StaticResource InkMutedBrush}"
                   Margin="0,0,0,6" />
        <TextBox x:Name="TxtTeslimAlan"
                 Style="{StaticResource FilterBoxStyle}"
                 Margin="0,0,0,14" />

        <TextBlock Text="İndirildiği Saha"
                   FontSize="12"
                   Foreground="{StaticResource InkMutedBrush}"
                   Margin="0,0,0,6" />
        <TextBox x:Name="TxtIndirildigiSaha"
                 Style="{StaticResource FilterBoxStyle}"
                 Margin="0,0,0,14" />

        <TextBlock Text="Açıklama"
                   FontSize="12"
                   Foreground="{StaticResource InkMutedBrush}"
                   Margin="0,0,0,6" />
        <TextBox x:Name="TxtAciklama"
                 Style="{StaticResource FilterBoxStyle}"
                 Height="72"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalContentAlignment="Top"
                 Padding="12,10"
                 Margin="0,0,0,4" />
      </StackPanel>
    </ScrollViewer>

    <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,20,0,0">
      <Button Content="İptal"
              Style="{StaticResource ToolbarButtonStyle}"
              Width="90"
              Margin="0,0,8,0"
              Click="Iptal_Click" />
      <Button Content="Aktar"
              Style="{StaticResource PrimaryToolbarButtonStyle}"
              Width="100"
              IsDefault="True"
              Click="Tamam_Click" />
    </StackPanel>
  </Grid>
</Window>
