<UserControl x:Class="SatinalmaPro.Views.Modules.CimentoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:helpers="clr-namespace:SatinalmaPro.Helpers"
             xmlns:controls="clr-namespace:SatinalmaPro.Views.Controls"
             Background="{StaticResource DashBackgroundBrush}">
  <Grid x:Name="AnaIcerikGrid">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Araç çubuğu -->
    <Border Grid.Row="0" Style="{StaticResource ModulePageCardStyle}" Padding="14,12" Margin="0,0,0,12">
      <Grid>
        <StackPanel Orientation="Horizontal">
          <Button Style="{StaticResource PrimaryToolbarButtonStyle}" Click="YeniKayit_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Yeni Kayıt" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="ExcelYukle_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Excel Yükle" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="SablonIndir_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Excel Şablon" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="PdfIndir_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="PDF İndir" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="PdfYazdir_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="PDF Yazdır" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="DisaAktar_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Dışa Aktar" />
            </StackPanel>
          </Button>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Style="{StaticResource ToolbarButtonStyle}" Margin="0" Click="Yenile_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Yenile" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Filtre paneli başlık -->
    <Border x:Name="FiltreBaslikBar" Grid.Row="1" Style="{StaticResource ErpFilterToggleBarStyle}" Margin="0,0,0,0">
      <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="Kayıt Filtreleme Paneli" FontSize="13" FontWeight="SemiBold"
                     Foreground="{StaticResource DashTextBrush}" />
          <Border Style="{StaticResource ErpFilterBadgeStyle}">
            <TextBlock x:Name="TxtAktifFiltreSayisi" Text="0" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource DashPrimaryBrush}" />
          </Border>
        </StackPanel>
        <Button x:Name="BtnFiltreToggle" Style="{StaticResource ErpFilterToggleLinkStyle}"
                HorizontalAlignment="Right" Click="FiltrePaneli_Toggle">
          <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="TxtFiltreToggle" Text="Filtreleri Göster" VerticalAlignment="Center" />
            <TextBlock x:Name="IcoFiltreToggle" Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                       Margin="6,0,0,0" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <!-- Filtre paneli içerik (animasyonlu) -->
    <Border x:Name="FiltrePanelKap" Grid.Row="2" ClipToBounds="True" MaxHeight="0" Margin="0,0,0,12">
      <Border Style="{StaticResource ModulePageCardStyle}" Padding="16,14,16,16" Margin="0,8,0,0">
        <StackPanel x:Name="FiltrePanelIcerik">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" MinWidth="140" />
              <ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" MinWidth="140" />
              <ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" MinWidth="150" />
              <ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" MinWidth="150" />
              <ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" MinWidth="130" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
              <TextBlock Text="Başlangıç Tarihi" Style="{StaticResource FilterLabelStyle}" />
              <DatePicker x:Name="DpBaslangic" SelectedDateChanged="FiltreDegisti" />
            </StackPanel>
            <StackPanel Grid.Column="2">
              <TextBlock Text="Bitiş Tarihi" Style="{StaticResource FilterLabelStyle}" />
              <DatePicker x:Name="DpBitis" SelectedDateChanged="FiltreDegisti" />
            </StackPanel>
            <StackPanel Grid.Column="4">
              <TextBlock Text="Tedarikçi" Style="{StaticResource FilterLabelStyle}" />
              <ComboBox x:Name="CmbTedarikci" Style="{StaticResource FilterComboStyle}"
                        SelectionChanged="TedarikciDegisti" />
            </StackPanel>
            <StackPanel Grid.Column="6">
              <TextBlock Text="Çimento Cinsi" Style="{StaticResource FilterLabelStyle}" />
              <Button x:Name="BtnCimentoCinsiSec" Style="{StaticResource ToolbarButtonStyle}" Margin="0"
                      HorizontalAlignment="Stretch" Click="CimentoCinsiSec_Click">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
                  <TextBlock x:Name="TxtCimentoCinsiSecim" Text="Tümü" />
                </StackPanel>
              </Button>
            </StackPanel>
            <StackPanel Grid.Column="8">
              <TextBlock Text="Çimento Sınıfı" Style="{StaticResource FilterLabelStyle}" />
              <ComboBox x:Name="CmbCimentoSinifi" Style="{StaticResource FilterComboStyle}"
                        SelectionChanged="FiltreDegisti" />
            </StackPanel>
          </Grid>

          <Grid Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" MinWidth="150" />
              <ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" MinWidth="150" />
              <ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" MinWidth="150" />
              <ColumnDefinition Width="12" />
              <ColumnDefinition Width="Auto" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
              <TextBlock Text="Şantiye" Style="{StaticResource FilterLabelStyle}" />
              <ComboBox x:Name="CmbSantiye" Style="{StaticResource FilterComboStyle}"
                        SelectionChanged="FiltreDegisti" />
            </StackPanel>
            <StackPanel Grid.Column="2">
              <TextBlock Text="Teslim Alan" Style="{StaticResource FilterLabelStyle}" />
              <TextBox x:Name="TxtTeslimAlanFilter" Style="{StaticResource FilterBoxStyle}"
                       TextChanged="FiltreDegisti"
                       ui:ControlHelper.PlaceholderText="Teslim alan ara..." />
            </StackPanel>
            <StackPanel Grid.Column="4">
              <TextBlock Text="İrsaliye No" Style="{StaticResource FilterLabelStyle}" />
              <TextBox x:Name="TxtIrsaliyeNoFilter" Style="{StaticResource FilterBoxStyle}"
                       TextChanged="FiltreDegisti"
                       ui:ControlHelper.PlaceholderText="İrsaliye no..." />
            </StackPanel>
            <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Bottom">
              <Button Style="{StaticResource PrimaryToolbarButtonStyle}" Margin="0,0,8,0"
                      Click="FiltreAra_Click" Content="Ara" />
              <Button Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"
                      Click="FiltreleriTemizle_Click" Content="Temizle" />
              <Button Style="{StaticResource ToolbarButtonStyle}" Margin="0"
                      Click="FiltreUygula_Click" Content="Filtrele" />
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>
    </Border>

    <!-- KPI kartları -->
    <UniformGrid Grid.Row="3" Rows="1" Columns="4" Margin="0,0,0,12">
      <Border Style="{StaticResource ModuleKpiCardHoverStyle}" Margin="0,0,12,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Border Width="40" Height="40" CornerRadius="10" Background="{StaticResource DashPrimaryBrush}" HorizontalAlignment="Left">
            <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel Grid.Row="1" Margin="0,12,0,0">
            <TextBlock Text="Toplam Kayıt" FontSize="12" Foreground="{StaticResource DashTextSecondaryBrush}" />
            <TextBlock x:Name="TxtToplamKayit" Text="0" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource DashTextBrush}" Margin="0,4,0,0" />
            <TextBlock x:Name="TxtToplamKayitAlt" Text="Bu filtreleme için" FontSize="11"
                       Foreground="{StaticResource DashTextSecondaryBrush}" Margin="0,4,0,0" />
          </StackPanel>
        </Grid>
      </Border>

      <Border Style="{StaticResource ModuleKpiCardHoverStyle}" Margin="0,0,12,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Border Width="40" Height="40" CornerRadius="10" Background="{StaticResource DashSuccessBrush}" HorizontalAlignment="Left">
            <TextBlock Text="&#xE7C5;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel Grid.Row="1" Margin="0,12,0,0">
            <TextBlock Text="Toplam Tonaj" FontSize="12" Foreground="{StaticResource DashTextSecondaryBrush}" />
            <TextBlock x:Name="TxtToplamMiktar" Text="0 Ton" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource DashTextBrush}" Margin="0,4,0,0" />
            <TextBlock Text="Tüm çimento" FontSize="11"
                       Foreground="{StaticResource DashTextSecondaryBrush}" Margin="0,4,0,0" />
          </StackPanel>
        </Grid>
      </Border>

      <Border Style="{StaticResource ModuleKpiCardHoverStyle}" Margin="0,0,12,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Border Width="40" Height="40" CornerRadius="10" Background="#8B5CF6" HorizontalAlignment="Left">
            <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel Grid.Row="1" Margin="0,12,0,0">
            <TextBlock Text="Toplam Tutar" FontSize="12" Foreground="{StaticResource DashTextSecondaryBrush}" />
            <TextBlock x:Name="TxtToplamTutar" Text="₺0" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource DashTextBrush}" Margin="0,4,0,0" />
            <TextBlock Text="KDV dahil" FontSize="11"
                       Foreground="{StaticResource DashTextSecondaryBrush}" Margin="0,4,0,0" />
          </StackPanel>
        </Grid>
      </Border>

      <Border Style="{StaticResource ModuleKpiCardHoverStyle}" Margin="0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Border Width="40" Height="40" CornerRadius="10" Background="{StaticResource DashWarningBrush}" HorizontalAlignment="Left">
            <TextBlock Text="&#xE7BF;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel Grid.Row="1" Margin="0,12,0,0">
            <TextBlock Text="Teslim Edilen" FontSize="12" Foreground="{StaticResource DashTextSecondaryBrush}" />
            <TextBlock x:Name="TxtTeslimEdilen" Text="0" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource DashTextBrush}" Margin="0,4,0,0" />
            <TextBlock Text="Teslim edilen" FontSize="11"
                       Foreground="{StaticResource DashTextSecondaryBrush}" Margin="0,4,0,0" />
          </StackPanel>
        </Grid>
      </Border>
    </UniformGrid>

    <!-- DataGrid alanı -->
    <Border x:Name="TabloKart" Grid.Row="4" Style="{StaticResource ModuleGridContainerStyle}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Tablo üst araçları -->
        <Border Grid.Row="0" Style="{StaticResource DashModernGridHeaderStyle}">
          <Grid>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock x:Name="TxtGridBaslik" Text="Çimento Listesi (0 kayıt)" FontSize="14" FontWeight="SemiBold"
                         Foreground="{StaticResource DashTextBrush}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
              <Grid Width="220" Margin="0,0,8,0">
                <TextBox x:Name="TxtGridArama" Style="{StaticResource FilterBoxStyle}" Height="36"
                         TextChanged="FiltreDegisti"
                         ui:ControlHelper.PlaceholderText="Tabloda ara..." />
                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                           Foreground="{StaticResource InkMutedBrush}" HorizontalAlignment="Right"
                           VerticalAlignment="Center" Margin="0,0,12,0" IsHitTestVisible="False" />
              </Grid>
              <Button Style="{StaticResource ToolbarButtonStyle}" Height="36" Margin="0,0,8,0"
                      Click="FiltreOdak_Click" Content="Filtre" />
              <Button Style="{StaticResource ToolbarButtonStyle}" Height="36" Margin="0,0,8,0"
                      Click="Kolonlar_Click" Content="Kolonlar" />
              <Button Style="{StaticResource ToolbarButtonStyle}" Height="36" Margin="0,0,8,0"
                      Click="Grupla_Click" Content="Grupla" />
              <Button Style="{StaticResource ToolbarButtonStyle}" Height="36" Margin="0,0,8,0"
                      Click="DisaAktar_Click" Content="Dışa Aktar" />
              <Button x:Name="BtnYogunGorunum" Style="{StaticResource ToolbarButtonStyle}" Height="36" Margin="0,0,8,0"
                      Click="YogunGorunum_Click" ToolTip="Yoğun Görünüm" Content="Yoğun" />
              <Button x:Name="BtnTamEkran" Style="{StaticResource ToolbarButtonStyle}" Height="36" Margin="0"
                      Click="TamEkran_Click" ToolTip="Tam Ekran" Content="Tam Ekran" />
            </StackPanel>
          </Grid>
        </Border>

        <DataGrid x:Name="CimentoGrid" Grid.Row="1" Style="{StaticResource ModuleDataGridStyle}"
                  AlternatingRowBackground="#FAFBFC"
                  CanUserSortColumns="True" CanUserReorderColumns="True"
                  SelectionMode="Extended"
                  LoadingRow="CimentoGrid_LoadingRow"
                  SelectionChanged="CimentoGrid_SelectionChanged"
                  MouseDoubleClick="CimentoGrid_MouseDoubleClick"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
          <DataGrid.ContextMenu>
            <ContextMenu>
              <MenuItem Header="Düzenle" Click="MenuDuzenle_Click" />
              <Separator />
              <MenuItem Header="Sil" Click="MenuSil_Click" />
            </ContextMenu>
          </DataGrid.ContextMenu>
          <DataGrid.Columns>
            <DataGridTextColumn Header="Tarih" Binding="{Binding Tarih}" Width="95" />
            <DataGridTextColumn Header="İrsaliye No" Binding="{Binding IrsaliyeNo}" Width="105" />
            <DataGridTextColumn Header="Sipariş No" Binding="{Binding SiparisNo}" Width="100" />
            <DataGridTextColumn Header="Çimento Cinsi" Binding="{Binding CimentoCinsi}" Width="140" />
            <DataGridTextColumn Header="Çimento Sınıfı" Binding="{Binding CimentoSinifi}" Width="115" />
            <DataGridTextColumn Header="Miktar" Binding="{Binding Miktar, StringFormat=N2}" Width="80" />
            <DataGridTextColumn Header="Birim" Binding="{Binding Birim}" Width="65" />
            <DataGridTextColumn Header="Birim Fiyatı" Binding="{Binding BirimFiyati, StringFormat='₺{0:N2}'}" Width="105" />
            <DataGridTextColumn Header="Toplam Tutar" Binding="{Binding ToplamTutar, StringFormat='₺{0:N2}'}" Width="115" />
            <DataGridTextColumn Header="Tedarikçi" Binding="{Binding Tedarikci}" Width="130" />
            <DataGridTextColumn Header="Şantiye" Binding="{Binding IndirildigiSaha}" Width="120" />
            <DataGridTextColumn Header="Teslim Alan" Binding="{Binding TeslimAlan}" Width="110" />
            <DataGridTextColumn Header="Açıklama" Binding="{Binding Aciklama}" Width="*" MinWidth="140" />
            <DataGridTemplateColumn Header="İşlemler" Width="70" IsReadOnly="True">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <Button Style="{StaticResource DashGhostButtonStyle}" Padding="6,4" BorderThickness="0"
                          Tag="{Binding}" Click="SatirIslem_Tikla" ToolTip="İşlemler">
                    <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{StaticResource DashTextSecondaryBrush}" />
                  </Button>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>

        <!-- Footer toplamları -->
        <Border Grid.Row="2" Style="{StaticResource ErpGridFooterStyle}">
          <Grid>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock x:Name="TxtFooterKayit" Text="Toplam 0 kayıt" FontSize="12" FontWeight="SemiBold"
                         Foreground="White" Margin="0,0,24,0" />
              <TextBlock x:Name="TxtFooterTon" Text="0,00 Ton" FontSize="12" FontWeight="SemiBold"
                         Foreground="#94A3B8" Margin="0,0,24,0" />
              <TextBlock x:Name="TxtFooterTutar" Text="₺0,00" FontSize="12" FontWeight="SemiBold"
                         Foreground="#94A3B8" />
              <TextBlock x:Name="TxtGrupBilgi" Text="" FontSize="12" Foreground="#94A3B8"
                         Margin="16,0,0,0" Visibility="Collapsed" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
              <TextBlock Text="Sayfa boyutu:" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center"
                         Margin="0,0,8,0" />
              <ComboBox x:Name="CmbSayfaBoyutu" Width="110" Height="32" FontSize="12">
                <ComboBoxItem Content="25 / Sayfa" Tag="25" IsSelected="True" />
                <ComboBoxItem Content="50 / Sayfa" Tag="50" />
                <ComboBoxItem Content="100 / Sayfa" Tag="100" />
              </ComboBox>
            </StackPanel>
          </Grid>
        </Border>

        <controls:SayfalamaCubugu x:Name="SayfalamaBar" Grid.Row="3" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
