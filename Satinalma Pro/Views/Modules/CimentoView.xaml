<UserControl x:Class="SatinalmaPro.Views.Modules.CimentoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:helpers="clr-namespace:SatinalmaPro.Helpers"
             xmlns:controls="clr-namespace:SatinalmaPro.Views.Controls">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
            CornerRadius="14" Padding="14,12" Margin="0,0,0,12">
      <Grid>
        <StackPanel Orientation="Horizontal">
          <Button Style="{StaticResource PrimaryToolbarButtonStyle}" Click="ExcelYukle_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Excel Yükle" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="SablonIndir_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Şablon İndir" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="PdfIndir_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="PDF İndir" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="PdfYazdir_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="PDF Yazdır" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="YeniKayit_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Yeni Kayıt" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Click="DisaAktar_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Dışa Aktar" />
            </StackPanel>
          </Button>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Style="{StaticResource ToolbarButtonStyle}" Margin="0" Click="Yenile_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Yenile" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
            CornerRadius="14" Padding="14,12,30,12" Margin="0,0,0,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" MinWidth="220" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,10,0">
          <TextBlock Text="Ara" Style="{StaticResource FilterLabelStyle}" />
          <Grid>
            <TextBox x:Name="TxtArama" Style="{StaticResource FilterBoxStyle}" TextChanged="FiltreDegisti"
                     ui:ControlHelper.PlaceholderText="İrsaliye no, çimento cinsi, tedarikçi veya saha ara..." />
            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                       Foreground="{StaticResource InkMutedBrush}" HorizontalAlignment="Right"
                       VerticalAlignment="Center" Margin="0,0,12,0" IsHitTestVisible="False" />
          </Grid>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="0,0,8,0">
          <TextBlock Text="Başlangıç" Style="{StaticResource FilterLabelStyle}" />
          <DatePicker x:Name="DpBaslangic" Width="140" SelectedDateChanged="FiltreDegisti" />
        </StackPanel>

        <StackPanel Grid.Column="2" Margin="0,0,8,0">
          <TextBlock Text="Bitiş" Style="{StaticResource FilterLabelStyle}" />
          <DatePicker x:Name="DpBitis" Width="140" SelectedDateChanged="FiltreDegisti" />
        </StackPanel>

        <StackPanel Grid.Column="3" Margin="0,0,8,0">
          <TextBlock Text="Tedarikçi" Style="{StaticResource FilterLabelStyle}" />
          <ComboBox x:Name="CmbTedarikci" Style="{StaticResource FilterComboStyle}"
                    MinWidth="150" SelectionChanged="TedarikciDegisti" />
        </StackPanel>

        <StackPanel Grid.Column="4" Margin="0,0,8,0">
          <TextBlock Text="Çimento Cinsi" Style="{StaticResource FilterLabelStyle}" />
          <Button x:Name="BtnCimentoCinsiSec" Style="{StaticResource ToolbarButtonStyle}"
                  MinWidth="170" Click="CimentoCinsiSec_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock x:Name="TxtCimentoCinsiSecim" Text="Tümü" />
            </StackPanel>
          </Button>
        </StackPanel>

        <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Bottom">
          <Button Style="{StaticResource PrimaryToolbarButtonStyle}" Margin="0,0,8,0"
                  Click="FiltrelenenleriFaturala_Click">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Faturası Kesildi İşaretle" />
            </StackPanel>
          </Button>
          <Button Style="{StaticResource ToolbarButtonStyle}" Content="Filtreleri Temizle"
                  Click="FiltreleriTemizle_Click" />
        </StackPanel>
      </Grid>
    </Border>

    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
      <Border Style="{StaticResource StatChipStyle}">
        <StackPanel>
          <TextBlock Text="Toplam Kayıt" FontSize="11" Foreground="{StaticResource InkMutedBrush}" />
          <TextBlock x:Name="TxtToplamKayit" Text="0" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" Margin="0,2,0,0" />
        </StackPanel>
      </Border>
      <Border Style="{StaticResource StatChipStyle}">
        <StackPanel>
          <TextBlock Text="Toplam Miktar" FontSize="11" Foreground="{StaticResource InkMutedBrush}" />
          <TextBlock x:Name="TxtToplamMiktar" Text="0 Ton" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" Margin="0,2,0,0" />
        </StackPanel>
      </Border>
      <Border Style="{StaticResource StatChipStyle}">
        <StackPanel>
          <TextBlock Text="Toplam Tutar" FontSize="11" Foreground="{StaticResource InkMutedBrush}" />
          <TextBlock x:Name="TxtToplamTutar" Text="₺0" FontSize="22" FontWeight="SemiBold" Foreground="#F59E0B" Margin="0,2,0,0" />
        </StackPanel>
      </Border>
      <Border Style="{StaticResource StatChipStyle}" Margin="0">
        <StackPanel>
          <TextBlock Text="Filtrelenen" FontSize="11" Foreground="{StaticResource InkMutedBrush}" />
          <TextBlock x:Name="TxtFiltrelenen" Text="0 kayıt" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" Margin="0,2,0,0" />
        </StackPanel>
      </Border>
    </StackPanel>

    <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
            CornerRadius="14" Padding="14,12,30,12" Margin="0,0,0,12">
      <StackPanel Orientation="Horizontal">
        <Button x:Name="BtnKayitDuzenle" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"
                IsEnabled="False" Click="KayitDuzenle_Click" Content="Düzenle" />
        <Button x:Name="BtnKayitSil" Style="{StaticResource ToolbarButtonStyle}" Margin="0"
                IsEnabled="False" Click="KayitSil_Click" Content="Sil" />
      </StackPanel>
    </Border>

    <Border Grid.Row="4" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
            CornerRadius="14" Padding="1">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
      <DataGrid x:Name="CimentoGrid" Grid.Row="0" Style="{StaticResource ModuleDataGridStyle}"
                AlternatingRowBackground="Transparent" LoadingRow="CimentoGrid_LoadingRow"
                SelectionChanged="CimentoGrid_SelectionChanged"
                MouseDoubleClick="CimentoGrid_MouseDoubleClick" ScrollViewer.HorizontalScrollBarVisibility="Auto">
        <DataGrid.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Düzenle" Click="MenuDuzenle_Click" />
            <Separator />
            <MenuItem Header="Sil" Click="MenuSil_Click" />
          </ContextMenu>
        </DataGrid.ContextMenu>
        <DataGrid.Columns>
          <DataGridTextColumn Header="Tarih" Binding="{Binding Tarih}" Width="95" />
          <DataGridTextColumn Header="İrsaliye No" Binding="{Binding IrsaliyeNo}" Width="105" />
          <DataGridTextColumn Header="Çimento Sınıfı" Binding="{Binding CimentoSinifi}" Width="115" />
          <DataGridTextColumn Header="Çimento Cinsi" Binding="{Binding CimentoCinsi}" Width="150" />
          <DataGridTemplateColumn Header="Fatura Durumu" Width="115" IsReadOnly="True">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Border Padding="8,6" Margin="2" CornerRadius="4" Cursor="Hand"
                        MouseLeftButtonUp="FaturaDurumu_Tikla" Tag="{Binding}">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Background" Value="#FEE2E2" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding FaturasiKesildi}" Value="True">
                          <Setter Property="Background" Value="#FEF08A" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                  <TextBlock Text="{Binding FaturaDurumuMetin}" HorizontalAlignment="Center"
                             FontSize="12" FontWeight="SemiBold" />
                </Border>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="Miktar" Binding="{Binding Miktar, StringFormat=N2}" Width="80" />
          <DataGridTextColumn Header="Birim" Binding="{Binding Birim}" Width="65" />
          <DataGridTextColumn Header="Birim Fiyatı" Binding="{Binding BirimFiyati, StringFormat='₺{0:N2}'}" Width="105" />
          <DataGridTextColumn Header="% Artış" Binding="{Binding ArtisYuzdesiMetin}" Width="80" />
          <DataGridTextColumn Header="Toplam Tutar" Binding="{Binding ToplamTutar, StringFormat='₺{0:N2}'}" Width="115" />
          <DataGridTextColumn Header="Tedarikçi" Binding="{Binding Tedarikci}" Width="130" />
          <DataGridTextColumn Header="İndirildiği Saha" Binding="{Binding IndirildigiSaha}" Width="120" />
          <DataGridTextColumn Header="Teslim Alan" Binding="{Binding TeslimAlan}" Width="110" />
          <DataGridTextColumn Header="Açıklama" Binding="{Binding Aciklama}" Width="*" MinWidth="140" />
        </DataGrid.Columns>
      </DataGrid>
      <controls:SayfalamaCubugu x:Name="SayfalamaBar" Grid.Row="1" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
