<Window x:Class="SatinalmaPro.Views.Modules.FiloGiderDuzenleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Gider Kaydı"
        Width="460"
        Height="420"
        MinWidth="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="Tarih" Style="{StaticResource FilterLabelStyle}" />
      <TextBox x:Name="TxtTarih" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,12" />

      <TextBlock Text="Gider Tipi" Style="{StaticResource FilterLabelStyle}" />
      <ComboBox x:Name="CmbGiderTipi" Style="{StaticResource FilterComboStyle}" Margin="0,0,0,12" IsEditable="True">
        <ComboBoxItem Content="Bakım" />
        <ComboBoxItem Content="Tamir" />
        <ComboBoxItem Content="Sigorta" />
        <ComboBoxItem Content="Kasko" />
        <ComboBoxItem Content="Muayene" />
        <ComboBoxItem Content="Yakıt" />
        <ComboBoxItem Content="Diğer" />
      </ComboBox>

      <TextBlock Text="Tutar (₺)" Style="{StaticResource FilterLabelStyle}" />
      <TextBox x:Name="TxtTutar" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,12" />

      <TextBlock Text="Belge No" Style="{StaticResource FilterLabelStyle}" />
      <TextBox x:Name="TxtBelgeNo" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,12" />

      <TextBlock Text="Açıklama" Style="{StaticResource FilterLabelStyle}" />
      <TextBox x:Name="TxtAciklama" Style="{StaticResource FilterBoxStyle}" Height="70"
               TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="12,10" />
    </StackPanel>

    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button Content="İptal" Style="{StaticResource ToolbarButtonStyle}" Width="100" Margin="0,0,8,0"
              Click="Iptal_Click" />
      <Button Content="Kaydet" Style="{StaticResource PrimaryToolbarButtonStyle}" Width="100"
              Click="Kaydet_Click" />
    </StackPanel>
  </Grid>
</Window>
