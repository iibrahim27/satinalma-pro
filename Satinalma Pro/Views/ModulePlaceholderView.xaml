<UserControl x:Class="SatinalmaPro.Views.ModulePlaceholderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
    <Border Background="White"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="1"
            CornerRadius="32"
            Padding="56,48"
            MaxWidth="480">
      <Border.Effect>
        <DropShadowEffect BlurRadius="60" ShadowDepth="0" Opacity="0.08" Color="#000000" />
      </Border.Effect>
      <StackPanel HorizontalAlignment="Center">
        <Border Width="72" Height="72" CornerRadius="24" Margin="0,0,0,28">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
              <GradientStop Color="#6366F1" Offset="0" />
              <GradientStop Color="#22D3EE" Offset="1" />
            </LinearGradientBrush>
          </Border.Background>
          <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="28" Foreground="White"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <TextBlock x:Name="TxtBaslik"
                   FontSize="24"
                   FontWeight="Light"
                   Foreground="{StaticResource InkBrush}"
                   TextAlignment="Center"
                   TextWrapping="Wrap" />
        <Border Height="1" Width="48" Background="{StaticResource LineBrush}" Margin="0,20" />
        <TextBlock Text="Modül arayüzü henüz tasarlanmadı."
                   FontSize="14"
                   Foreground="{StaticResource InkMutedBrush}"
                   TextAlignment="Center"
                   TextWrapping="Wrap" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
