<Window x:Class="SatinalmaPro.Views.KullaniciYonetimWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kullanıcı Yönetimi"
        Width="980" Height="780"
        MinWidth="900" MinHeight="700"
        WindowStartupLocation="CenterOwner"
        Background="White">
  <TabControl Margin="16">
    <TabItem Header="Kullanıcılar">
      <Grid Margin="4">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="1.4*" MinHeight="280" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" MinHeight="200" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
          <TextBlock Text="Kullanıcılar, roller ve modül yetkileri" FontSize="14" FontWeight="SemiBold" />
          <TextBlock Text="Listeden satıra tıklayın veya «Düzenle»ye basın → form dolar → «Değişiklikleri Kaydet» ile kaydedin."
                     FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <DataGrid x:Name="KullaniciGrid" Grid.Row="1" Style="{StaticResource ModuleDataGridStyle}"
                  SelectionUnit="FullRow" SelectionMode="Single"
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                  VerticalScrollBarVisibility="Auto"
                  MouseDoubleClick="KullaniciGrid_MouseDoubleClick"
                  SelectionChanged="KullaniciGrid_SelectionChanged">
          <DataGrid.Columns>
            <DataGridTemplateColumn Header="" Width="96">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <Button Content="Düzenle" Style="{StaticResource ToolbarButtonStyle}" Padding="10,4"
                          Click="KullaniciSatirDuzenle_Click" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="Ad Soyad" Binding="{Binding AdSoyad}" Width="*" MinWidth="120" />
            <DataGridTextColumn Header="E-posta" Binding="{Binding Eposta}" Width="*" MinWidth="160" />
            <DataGridTextColumn Header="Rol" Binding="{Binding Rol}" Width="110" />
            <DataGridTextColumn Header="Yetkiler" Binding="{Binding ModulOzeti}" Width="140" />
            <DataGridCheckBoxColumn Header="Aktif" Binding="{Binding Aktif}" Width="60" />
          </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Margin="0,12,0,0">
          <Border Background="#FFF7ED" BorderBrush="#FDBA74" BorderThickness="1"
                  CornerRadius="8" Padding="12,10">
            <StackPanel>
              <TextBlock x:Name="TxtFormBaslik" Text="Yeni kullanıcı ekle" FontWeight="SemiBold" FontSize="13" />
              <TextBlock x:Name="TxtFormIpucu" Text="Yeni kayıt için alanları doldurup «Kullanıcı Ekle»ye basın."
                         FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <Grid Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="10" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="10" />
              <ColumnDefinition Width="140" />
              <ColumnDefinition Width="10" />
              <ColumnDefinition Width="130" />
              <ColumnDefinition Width="10" />
              <ColumnDefinition Width="90" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Ad Soyad" FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,4" />
            <TextBlock Grid.Row="0" Grid.Column="2" Text="E-posta" FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,4" />
            <TextBlock Grid.Row="0" Grid.Column="4" Text="Şifre" FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,4" />
            <TextBlock Grid.Row="0" Grid.Column="6" Text="Rol" FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,4" />
            <TextBlock Grid.Row="0" Grid.Column="8" Text="Aktif" FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,4" />

            <TextBox x:Name="TxtYeniAd" Grid.Row="1" Grid.Column="0" Style="{StaticResource FilterBoxStyle}" />
            <TextBox x:Name="TxtYeniEposta" Grid.Row="1" Grid.Column="2" Style="{StaticResource FilterBoxStyle}" />
            <PasswordBox x:Name="TxtYeniSifre" Grid.Row="1" Grid.Column="4" Height="38" Padding="10,8" />
            <ComboBox x:Name="CmbYeniRol" Grid.Row="1" Grid.Column="6" Style="{StaticResource FilterComboStyle}"
                      SelectionChanged="CmbYeniRol_SelectionChanged" />
            <CheckBox x:Name="ChkAktif" Grid.Row="1" Grid.Column="8" Content="Evet" VerticalAlignment="Center" IsChecked="True" />
          </Grid>

          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,8">
            <Button x:Name="BtnGuncelle" Style="{StaticResource PrimaryToolbarButtonStyle}" Content="Değişiklikleri Kaydet (Güncelle)"
                    Margin="0,0,8,0" IsEnabled="False" Click="Guncelle_Click" />
            <Button x:Name="BtnEkle" Style="{StaticResource PrimaryToolbarButtonStyle}" Content="Kullanıcı Ekle"
                    Margin="0,0,8,0" Click="KullaniciEkle_Click" />
            <Button x:Name="BtnSil" Style="{StaticResource ToolbarButtonStyle}" Content="Pasifleştir"
                    Margin="0,0,8,0" IsEnabled="False" Click="Sil_Click" />
            <Button x:Name="BtnSifreSifir" Style="{StaticResource ToolbarButtonStyle}" Content="Şifre Sıfırlama Maili"
                    Margin="0,0,8,0" IsEnabled="False" Click="SifreSifir_Click" />
            <Button Style="{StaticResource ToolbarButtonStyle}" Content="Yeni kullanıcı modu"
                    Margin="0,0,8,0" Click="SecimiTemizle_Click" />
            <Button Style="{StaticResource ToolbarButtonStyle}" Content="Yenile" Click="Yenile_Click" />
          </StackPanel>
        </StackPanel>

        <Border Grid.Row="3" Margin="0,0,0,0" BorderBrush="{StaticResource LineBrush}" BorderThickness="1"
                CornerRadius="10" Padding="12,10">
          <DockPanel>
            <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
              <TextBlock Text="Modül yetkileri (okuma / yazma / sekmeler)" FontWeight="SemiBold" VerticalAlignment="Center" />
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource ToolbarButtonStyle}" Content="Rol varsayılanını yükle"
                        Margin="0,0,8,0" Click="RolVarsayilaniniSec_Click" />
                <Button Style="{StaticResource ToolbarButtonStyle}" Content="Tümünü temizle"
                        Click="TumunuTemizle_Click" />
              </StackPanel>
            </Grid>
            <TextBlock DockPanel.Dock="Top"
                       Text="Okuma: modül görünür. Yazma: düzenleme yapabilir. Sekmeler: sadece işaretli sekmeler açılır (boş = tümü)."
                       FontSize="11" Foreground="{StaticResource InkMutedBrush}" Margin="0,0,0,10" TextWrapping="Wrap" />
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel x:Name="ModulYetkiPanel" />
            </ScrollViewer>
          </DockPanel>
        </Border>

      </Grid>
    </TabItem>

    <TabItem Header="E-posta Şablonu" Loaded="EpostaTab_Loaded">
      <StackPanel Margin="12">
        <TextBlock Text="Şifre sıfırlama e-postası" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6" />
        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource InkMutedBrush}" FontSize="12" Margin="0,0,0,16"
                   Text="Şablon Firestore'da saklanır. Kullanıcıya mail gönder dediğinizde Firebase şifre sıfırlama bağlantısı gönderir. Değişkenler: {adSoyad}, {eposta}, {firmaAdi}" />

        <TextBlock Text="Konu" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBox x:Name="TxtEpostaKonu" Style="{StaticResource FilterBoxStyle}" Margin="0,0,0,12" />

        <TextBlock Text="Mesaj metni (referans / kayıt)" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBox x:Name="TxtEpostaGovde" AcceptsReturn="True" TextWrapping="Wrap"
                 Height="220" VerticalScrollBarVisibility="Auto"
                 Padding="10,8" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" Margin="0,0,0,16" />

        <Button Style="{StaticResource PrimaryToolbarButtonStyle}" Content="Şablonu Kaydet (Buluta)"
                HorizontalAlignment="Left" Click="EpostaSablonKaydet_Click" />
      </StackPanel>
    </TabItem>
  </TabControl>
</Window>
