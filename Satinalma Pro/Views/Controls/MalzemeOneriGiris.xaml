<UserControl x:Class="SatinalmaPro.Views.Controls.MalzemeOneriGiris"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <TextBox x:Name="MetinKutusu"
             BorderThickness="0"
             Padding="4,2"
             VerticalContentAlignment="Center"
             TextChanged="MetinKutusu_TextChanged"
             LostKeyboardFocus="MetinKutusu_LostKeyboardFocus"
             PreviewKeyDown="MetinKutusu_PreviewKeyDown" />
    <Popup x:Name="OneriPopup"
           PlacementTarget="{Binding ElementName=MetinKutusu}"
           Placement="Bottom"
           StaysOpen="True"
           AllowsTransparency="True"
           PopupAnimation="Fade">
      <Border BorderBrush="#CBD5E1"
              BorderThickness="1"
              Background="White"
              CornerRadius="4"
              MinWidth="{Binding ActualWidth, ElementName=MetinKutusu}"
              MaxWidth="420">
        <ListBox x:Name="OneriListesi"
                 MaxHeight="160"
                 MinWidth="200"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 SelectionChanged="OneriListesi_SelectionChanged"
                 PreviewMouseLeftButtonDown="OneriListesi_PreviewMouseLeftButtonDown">
          <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
              <Setter Property="Padding" Value="8,6" />
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            </Style>
          </ListBox.ItemContainerStyle>
        </ListBox>
      </Border>
    </Popup>
  </Grid>
</UserControl>
