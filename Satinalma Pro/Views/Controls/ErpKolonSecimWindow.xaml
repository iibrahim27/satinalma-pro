<Window x:Class="SatinalmaPro.Views.Controls.ErpKolonSecimWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kolon Görünürlüğü"
        Width="360" Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource ErpBgBrush}">
  <Border Style="{StaticResource ErpCard}" Margin="16" Padding="20">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <StackPanel Margin="0,0,0,16">
        <TextBlock Text="Kolonları Yönet" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource DashTextBrush}" />
        <TextBlock Text="Görünür kolonları seçin. Sürükleyerek sıralayabilirsiniz." FontSize="12"
                   Foreground="{StaticResource DashTextSecondaryBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
      </StackPanel>
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="KolonListesi" />
      </ScrollViewer>
      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
        <Button Style="{StaticResource ToolbarButtonStyle}" Content="Tümünü Göster" Click="TumunuGoster_Click" Margin="0,0,8,0" Padding="14,8" />
        <Button Style="{StaticResource ToolbarButtonStyle}" Content="Sıfırla" Click="Sifirla_Click" Margin="0,0,8,0" Padding="14,8" />
        <Button Style="{StaticResource PrimaryToolbarButtonStyle}" Content="Tamam" Click="Tamam_Click" Padding="14,8" IsDefault="True" />
      </StackPanel>
    </Grid>
  </Border>
</Window>
