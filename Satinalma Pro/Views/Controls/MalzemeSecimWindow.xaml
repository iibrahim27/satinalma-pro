<Window x:Class="SatinalmaPro.Views.Controls.MalzemeSecimWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Malzeme Seç"
        Width="560"
        Height="580"
        MinWidth="420"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="White">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Margin="0,0,0,14">
      <TextBlock Text="Alınan Malzemeler"
                 FontSize="17" FontWeight="SemiBold"
                 Foreground="{StaticResource InkBrush}" />
      <TextBlock Text="Listeden malzeme seçin. Arama kutusu ile filtreleyebilirsiniz."
                 FontSize="12" Foreground="{StaticResource InkMutedBrush}"
                 Margin="0,4,0,0" TextWrapping="Wrap" />
    </StackPanel>

    <Grid Grid.Row="1" Margin="0,0,0,12">
      <TextBox x:Name="TxtAra" Padding="10,8"
               TextChanged="TxtAra_TextChanged"
               PreviewKeyDown="TxtAra_PreviewKeyDown" />
      <TextBlock Text="Ara..." IsHitTestVisible="False"
                 Foreground="{StaticResource InkMutedBrush}"
                 Margin="12,0,0,0" VerticalAlignment="Center">
        <TextBlock.Style>
          <Style TargetType="TextBlock">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding Text, ElementName=TxtAra}" Value="">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </TextBlock.Style>
      </TextBlock>
    </Grid>

    <Border Grid.Row="2" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8">
      <ListBox x:Name="Liste" BorderThickness="0"
               MouseDoubleClick="Liste_MouseDoubleClick"
               PreviewKeyDown="Liste_PreviewKeyDown">
        <ListBox.ItemContainerStyle>
          <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,8" />
          </Style>
        </ListBox.ItemContainerStyle>
      </ListBox>
    </Border>

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
      <TextBlock x:Name="TxtSayac" VerticalAlignment="Center"
                 Foreground="{StaticResource InkMutedBrush}" FontSize="12"
                 Margin="0,0,16,0" />
      <Button Content="İptal" Style="{StaticResource ToolbarButtonStyle}"
              Click="Iptal_Click" Margin="0,0,8,0" Padding="16,8" IsCancel="True" />
      <Button Content="Tamam" Style="{StaticResource PrimaryToolbarButtonStyle}"
              Click="Tamam_Click" Padding="18,8" IsDefault="True" />
    </StackPanel>
  </Grid>
</Window>
