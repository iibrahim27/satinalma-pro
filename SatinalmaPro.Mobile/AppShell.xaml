<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:SatinalmaPro.Mobile.Views"
       x:Class="SatinalmaPro.Mobile.AppShell"
       FlyoutBehavior="Flyout"
       Title="Satınalma Pro"
       Shell.BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource PageBackgroundDark}}">

    <Shell.FlyoutHeader>
        <Grid Padding="20,28,20,20">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#2563EB" Offset="0" />
                    <GradientStop Color="#1D4ED8" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>
            <VerticalStackLayout VerticalOptions="Center" Spacing="8">
                <Border Width="56" Height="56" StrokeShape="RoundRectangle 16" StrokeThickness="0"
                        BackgroundColor="#33FFFFFF" HorizontalOptions="Start">
                    <Image Source="app_logo.png" HeightRequest="36" WidthRequest="36"
                           HorizontalOptions="Center" VerticalOptions="Center" Aspect="AspectFit" />
                </Border>
                <Label x:Name="LblKullanici" TextColor="White" FontSize="17" FontAttributes="Bold" />
                <Label x:Name="LblRol" TextColor="#BFDBFE" FontSize="13" />
                <Border Padding="10,4" StrokeShape="RoundRectangle 8" StrokeThickness="0"
                        BackgroundColor="#33FFFFFF" HorizontalOptions="Start"
                        IsVisible="False" x:Name="BadgeBildirim">
                    <Label x:Name="LblBildirimSayi" TextColor="White" FontSize="11" FontAttributes="Bold" />
                </Border>
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <ShellContent Title="Panel" Route="main" ContentTemplate="{DataTemplate views:AnaSayfaPage}" />

</Shell>
