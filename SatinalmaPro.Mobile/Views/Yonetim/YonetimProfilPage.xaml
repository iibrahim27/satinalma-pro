<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SatinalmaPro.Mobile.ViewModels.Yonetim"
             x:Class="SatinalmaPro.Mobile.Views.Yonetim.YonetimProfilPage"
             x:DataType="vm:YonetimProfilViewModel"
             Title="Profil"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <Grid Style="{StaticResource Md3AppBar}" Margin="-16,-16,-16,0">
                <Label Text="Profil" Style="{StaticResource Md3SectionTitle}" />
            </Grid>

            <!-- Kullanıcı Bilgileri -->
            <Border Style="{StaticResource Md3ElevatedCard}">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                    <Border WidthRequest="64" HeightRequest="64" StrokeShape="RoundRectangle 32"
                            BackgroundColor="{StaticResource Md3PrimaryContainer}" StrokeThickness="0">
                        <Label Text="👤" FontSize="28" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout VerticalOptions="Center" Spacing="4">
                        <Label Text="{Binding KullaniciAdi}" Style="{StaticResource Md3CardTitle}" FontSize="18" />
                        <Label Text="{Binding Eposta}" Style="{StaticResource Md3Muted}" />
                        <Border Padding="8,3" HorizontalOptions="Start" StrokeThickness="0"
                                StrokeShape="RoundRectangle 10" BackgroundColor="{StaticResource Md3PrimaryContainer}">
                            <Label Text="{Binding Rol, StringFormat='Rol: {0}'}" FontSize="12" FontAttributes="Bold"
                                   TextColor="{StaticResource Md3Primary}" />
                        </Border>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Ayarlar -->
            <Label Text="Hesap" Style="{StaticResource Md3SectionTitle}" />

            <Border Style="{StaticResource Md3OutlinedCard}">
                <VerticalStackLayout Spacing="0">
                    <Grid Padding="4,12" ColumnDefinitions="Auto,*,Auto">
                        <Label Text="🔒" FontSize="20" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Şifre Değiştir" Style="{StaticResource Md3CardSubtitle}"
                               VerticalOptions="Center" Margin="12,0,0,0" />
                        <Label Grid.Column="2" Text="›" FontSize="22" VerticalOptions="Center"
                               TextColor="{StaticResource MutedTextLight}" />
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SifreDegistirCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource Md3Outline}" />
                    <Grid Padding="4,12" ColumnDefinitions="Auto,*,Auto">
                        <Label Text="🔔" FontSize="20" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Bildirim Ayarları" Style="{StaticResource Md3CardSubtitle}"
                               VerticalOptions="Center" Margin="12,0,0,0" />
                        <Switch Grid.Column="2" IsToggled="{Binding BildirimlerAcik}" VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Button Text="Çıkış Yap" Style="{StaticResource Md3BtnOutlined}"
                    Command="{Binding CikisYapCommand}" Margin="0,8,0,24" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
