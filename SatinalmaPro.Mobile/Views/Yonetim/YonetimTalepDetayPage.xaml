<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SatinalmaPro.Mobile.ViewModels.Yonetim"
             xmlns:mod="clr-namespace:SatinalmaPro.Mobile.Models.Yonetim"
             xmlns:ctrl="clr-namespace:SatinalmaPro.Mobile.Views.Controls.Yonetim"
             x:Class="SatinalmaPro.Mobile.Views.Yonetim.YonetimTalepDetayPage"
             x:DataType="vm:YonetimTalepDetayViewModel"
             Title="Talep Detayı">

    <ctrl:SayfaDurumGorunumu x:Name="DurumGorunumu"
                              Durum="{Binding SayfaDurumu}"
                              HataMesaj="{Binding HataMesaji}">
        <ctrl:SayfaDurumGorunumu.Icerik>
            <Grid RowDefinitions="*,Auto">
                <ScrollView Grid.Row="0" Padding="16">
                    <VerticalStackLayout Spacing="16">

                        <!-- Başlık Kartı -->
                        <Border Style="{StaticResource Md3ElevatedCard}">
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="{Binding Talep.TalepNo}" FontSize="22" FontAttributes="Bold"
                                           FontFamily="OpenSansSemibold"
                                           TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight}, Dark={StaticResource PrimaryTextDark}}" />
                                    <Border Grid.Column="1" Padding="10,4" StrokeThickness="0"
                                            StrokeShape="RoundRectangle 12"
                                            BackgroundColor="{Binding Talep.OncelikArkaPlan}">
                                        <Label Text="{Binding Talep.OncelikMetni}" FontSize="11" FontAttributes="Bold"
                                               TextColor="{Binding Talep.OncelikRengi}" />
                                    </Border>
                                </Grid>
                                <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Md3Outline}, Dark={StaticResource Md3OutlineDark}}" />
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                                    <Label Grid.Row="0" Text="Şantiye" Style="{StaticResource Md3Muted}" />
                                    <Label Grid.Row="0" Grid.Column="1" Text="{Binding Talep.Santiye}" Style="{StaticResource Md3CardSubtitle}" />
                                    <Label Grid.Row="1" Text="Talep Eden" Style="{StaticResource Md3Muted}" />
                                    <Label Grid.Row="1" Grid.Column="1" Text="{Binding Talep.TalepEden}" Style="{StaticResource Md3CardSubtitle}" />
                                    <Label Grid.Row="2" Text="Tarih" Style="{StaticResource Md3Muted}" />
                                    <Label Grid.Row="2" Grid.Column="1" Text="{Binding Talep.TalepTarihi}" Style="{StaticResource Md3CardSubtitle}" />
                                    <Label Grid.Row="3" Text="Durum" Style="{StaticResource Md3Muted}" />
                                    <Label Grid.Row="3" Grid.Column="1" Text="{Binding Talep.DurumMetni}" FontAttributes="Bold"
                                           TextColor="{StaticResource Md3Primary}" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Malzeme Listesi -->
                        <Label Text="Malzeme Listesi" Style="{StaticResource Md3SectionTitle}" />
                        <Border Style="{StaticResource Md3OutlinedCard}" Padding="0">
                            <CollectionView ItemsSource="{Binding Talep.Malzemeler}" SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="mod:YonetimMalzemeOgesi">
                                        <Grid Padding="16,12" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                                            <Label Text="{Binding Ad}" Style="{StaticResource Md3CardSubtitle}" VerticalOptions="Center" />
                                            <Label Grid.Column="1" Text="{Binding Miktar}" FontAttributes="Bold"
                                                   TextColor="{StaticResource Md3Primary}" VerticalOptions="Center" />
                                            <Label Grid.Column="2" Text="{Binding Birim}" Style="{StaticResource Md3Muted}" VerticalOptions="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </Border>

                        <!-- Açıklama -->
                        <Label Text="Talep Açıklaması" Style="{StaticResource Md3SectionTitle}" />
                        <Border Style="{StaticResource Md3OutlinedCard}">
                            <Label Text="{Binding Talep.Aciklama}" Style="{StaticResource Md3CardSubtitle}" LineBreakMode="WordWrap" />
                        </Border>

                        <!-- Fotoğraflar -->
                        <VerticalStackLayout IsVisible="{Binding Talep.FotografVar}" Spacing="8">
                            <Label Text="Fotoğraflar" Style="{StaticResource Md3SectionTitle}" />
                            <CollectionView ItemsSource="{Binding Talep.Fotograflar}" SelectionMode="None"
                                            HeightRequest="100">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Border WidthRequest="100" HeightRequest="100" StrokeShape="RoundRectangle 12"
                                                BackgroundColor="{AppThemeBinding Light={StaticResource Md3SurfaceVariant}, Dark={StaticResource Md3SurfaceVariantDark}}"
                                                StrokeThickness="0">
                                            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="4">
                                                <Label Text="🖼" FontSize="28" HorizontalOptions="Center" />
                                                <Label Text="{Binding .}" FontSize="9" Style="{StaticResource Md3Muted}"
                                                       HorizontalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1" />
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>

                        <!-- Dosyalar -->
                        <VerticalStackLayout IsVisible="{Binding Talep.DosyaVar}" Spacing="8">
                            <Label Text="Dosyalar" Style="{StaticResource Md3SectionTitle}" />
                            <CollectionView ItemsSource="{Binding Talep.Dosyalar}" SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Border Style="{StaticResource Md3OutlinedCard}" Margin="0,0,0,8" Padding="14">
                                            <HorizontalStackLayout Spacing="10">
                                                <Label Text="📎" FontSize="18" VerticalOptions="Center" />
                                                <Label Text="{Binding .}" Style="{StaticResource Md3CardSubtitle}" VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="80" Color="Transparent" />
                    </VerticalStackLayout>
                </ScrollView>

                <!-- Aksiyon Butonları -->
                <Border Grid.Row="1" Padding="16,12,16,24"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Md3Surface}, Dark={StaticResource PageBackgroundDark}}"
                        StrokeThickness="0">
                    <Border.Shadow>
                        <Shadow Radius="12" Opacity="0.08" Brush="{StaticResource Black}" Offset="0,-2" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="10">

                        <!-- Acil aksiyonlar -->
                        <VerticalStackLayout IsVisible="{Binding AcilAksiyonlar}" Spacing="10">
                            <Button Text="Acil Alımı Onayla" Style="{StaticResource Md3BtnDanger}"
                                    Command="{Binding AcilAlimiOnaylaCommand}"
                                    IsEnabled="{Binding AksiyonAktif}" />
                            <Button Text="Reddet" Style="{StaticResource Md3BtnOutlined}"
                                    Command="{Binding ReddetCommand}"
                                    IsEnabled="{Binding AksiyonAktif}" />
                        </VerticalStackLayout>

                        <!-- Normal aksiyonlar -->
                        <VerticalStackLayout IsVisible="{Binding NormalAksiyonlar}" Spacing="10">
                            <Button Text="Teklif İste" Style="{StaticResource Md3BtnInfo}"
                                    Command="{Binding TeklifIsteCommand}"
                                    IsEnabled="{Binding AksiyonAktif}" />
                            <Button Text="Doğrudan Onayla" Style="{StaticResource Md3BtnSuccess}"
                                    Command="{Binding DogrudanOnaylaCommand}"
                                    IsEnabled="{Binding AksiyonAktif}" />
                            <Button Text="Reddet" Style="{StaticResource Md3BtnOutlined}"
                                    Command="{Binding ReddetCommand}"
                                    IsEnabled="{Binding AksiyonAktif}" />
                        </VerticalStackLayout>

                        <ActivityIndicator IsRunning="{Binding IslemYapiliyor}" IsVisible="{Binding IslemYapiliyor}"
                                           Color="{StaticResource Md3Primary}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </ctrl:SayfaDurumGorunumu.Icerik>
    </ctrl:SayfaDurumGorunumu>

</ContentPage>
