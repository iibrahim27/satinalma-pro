<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SatinalmaPro.Mobile.ViewModels.Yonetim"
             xmlns:mod="clr-namespace:SatinalmaPro.Mobile.Models.Yonetim"
             xmlns:ctrl="clr-namespace:SatinalmaPro.Mobile.Views.Controls.Yonetim"
             x:Class="SatinalmaPro.Mobile.Views.Yonetim.YonetimBildirimlerPage"
             x:DataType="vm:YonetimBildirimlerViewModel"
             Title="Bildirimler"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" Style="{StaticResource Md3AppBar}" ColumnDefinitions="*,Auto">
            <Label Text="Bildirimler" Style="{StaticResource Md3SectionTitle}" />
            <Border Grid.Column="1" IsVisible="{Binding OkunmamisVar}"
                    Padding="10,4" StrokeThickness="0" StrokeShape="RoundRectangle 12"
                    BackgroundColor="{StaticResource Danger}" VerticalOptions="Center">
                <Label Text="{Binding OkunmamisSayisi}" TextColor="White" FontSize="12" FontAttributes="Bold" />
            </Border>
        </Grid>

        <ctrl:SayfaDurumGorunumu x:Name="DurumGorunumu" Grid.Row="1"
                                  Durum="{Binding SayfaDurumu}"
                                  HataMesaj="{Binding HataMesaji}"
                                  BosBaslik="Bildirim yok"
                                  BosMesaj="Yeni bildirimler burada görünecek.">
            <ctrl:SayfaDurumGorunumu.Icerik>
                <RefreshView x:Name="RefreshView">
                    <CollectionView ItemsSource="{Binding Bildirimler}" SelectionMode="None" Margin="16,8">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="mod:YonetimBildirimOgesi">
                                <Border Margin="0,0,0,10" Padding="16" StrokeShape="RoundRectangle 16" StrokeThickness="1">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding Okundu}" Value="False">
                                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Md3PrimaryContainer}, Dark={StaticResource CardBackgroundDark}}" />
                                            <Setter Property="Stroke" Value="{StaticResource Md3Primary}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border" Binding="{Binding Okundu}" Value="True">
                                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Md3Surface}, Dark={StaticResource CardBackgroundDark}}" />
                                            <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Md3Outline}, Dark={StaticResource Md3OutlineDark}}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:YonetimBildirimlerViewModel}}, Path=BildirimeTiklaCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <Border WidthRequest="44" HeightRequest="44" StrokeShape="RoundRectangle 22"
                                                StrokeThickness="0"
                                                BackgroundColor="{AppThemeBinding Light={StaticResource Md3SurfaceVariant}, Dark={StaticResource Md3SurfaceVariantDark}}"
                                                VerticalOptions="Start">
                                            <Label Text="{Binding TipIkon}" FontSize="20"
                                                   HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                                            <Label Text="{Binding Baslik}" Style="{StaticResource Md3CardTitle}" />
                                            <Label Text="{Binding Mesaj}" Style="{StaticResource Md3CardSubtitle}" LineBreakMode="WordWrap" />
                                            <Label Text="{Binding Zaman}" Style="{StaticResource Md3Muted}" />
                                        </VerticalStackLayout>
                                        <BoxView Grid.Column="2" WidthRequest="8" HeightRequest="8"
                                                 CornerRadius="4" VerticalOptions="Start" Margin="0,6,0,0"
                                                 Color="{StaticResource Md3Primary}">
                                            <BoxView.Triggers>
                                                <DataTrigger TargetType="BoxView" Binding="{Binding Okundu}" Value="True">
                                                    <Setter Property="IsVisible" Value="False" />
                                                </DataTrigger>
                                            </BoxView.Triggers>
                                        </BoxView>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </RefreshView>
            </ctrl:SayfaDurumGorunumu.Icerik>
        </ctrl:SayfaDurumGorunumu>
    </Grid>

</ContentPage>
