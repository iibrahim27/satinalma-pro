<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SatinalmaPro.Mobile.Views.StokCikisPage"
             Title="Stok Çıkışı">

    <Grid RowDefinitions="Auto,*,Auto" Padding="16,12">
        <!-- Üst bilgi -->
        <VerticalStackLayout Grid.Row="0" Spacing="4" Margin="0,0,0,12">
            <Label Text="Depodan çıkış — aynı kişiye birden fazla malzeme verebilirsiniz."
                   FontSize="12" TextColor="{StaticResource Gray500}" LineBreakMode="WordWrap" />
            <HorizontalStackLayout Spacing="12">
                <Label x:Name="LblTarih" FontSize="12" TextColor="{StaticResource Gray600}" />
                <Label x:Name="LblBelgeNo" FontSize="12" TextColor="{StaticResource Gray600}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- Kalemler -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="8">
                <Grid ColumnDefinitions="*,88,64" ColumnSpacing="8" Padding="4,0">
                    <Label Grid.Column="0" Text="Malzeme adı" Style="{StaticResource LblSection}" FontSize="13" />
                    <Label Grid.Column="1" Text="Miktar" Style="{StaticResource LblSection}" FontSize="13" />
                    <Label Grid.Column="2" Text="" />
                </Grid>

                <VerticalStackLayout x:Name="SatirlarPanel" Spacing="6" />

                <Button Text="+ Satır Ekle"
                        Clicked="SatirEkle_Clicked"
                        Style="{StaticResource BtnSecondary}"
                        Margin="0,4,0,0" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- Alt: teslim alan + kaydet -->
        <VerticalStackLayout Grid.Row="2" Spacing="10" Margin="0,12,0,0">
            <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />
            <Label Text="Teslim edilen adı" Style="{StaticResource LblSection}" FontSize="13" />
            <Entry x:Name="TxtTeslimEdilen"
                   Placeholder="Malzemeyi teslim alan kişi (tüm kalemler için tek isim)"
                   ReturnType="Done" />
            <Button Text="Kaydet" Clicked="Kaydet_Clicked" Style="{StaticResource BtnBrand}" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
