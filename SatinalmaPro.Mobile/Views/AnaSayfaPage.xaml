<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SatinalmaPro.Mobile.ViewModels"
             xmlns:svc="clr-namespace:SatinalmaPro.Shared.Services;assembly=SatinalmaPro.Shared"
             x:Class="SatinalmaPro.Mobile.Views.AnaSayfaPage"
             x:DataType="vm:DashboardViewModel"
             Title="Panel">

    <RefreshView IsRefreshing="{Binding Yukleniyor}"
                 Command="{Binding SayfaAcildiCommand}">
        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="16">

                <!-- Üst başlık -->
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding PanelBasligi}" FontSize="22" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight}, Dark={StaticResource PrimaryTextDark}}" />
                        <Label Text="{Binding AltBaslik}" FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}" />
                        <Label Text="{Binding SonGuncelleme, StringFormat='Son güncelleme: {0}'}"
                               FontSize="11" TextColor="{AppThemeBinding Light={StaticResource MutedTextLight}, Dark={StaticResource MutedTextDark}}" />
                    </VerticalStackLayout>
                    <Image Grid.Column="1" Source="app_logo.png" HeightRequest="52" WidthRequest="52" VerticalOptions="Start" />
                </Grid>

                <!-- Özet kartları -->
                <Label Text="Özet" FontSize="16" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight}, Dark={StaticResource PrimaryTextDark}}" Margin="0,4,0,0" />
                <CollectionView ItemsSource="{Binding Kartlar}"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="10" VerticalItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="svc:DashboardKart">
                            <Border StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                                    Padding="14" StrokeShape="RoundRectangle 12">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DashboardViewModel}}, Path=KartaGitCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="4">
                                    <BoxView HeightRequest="4" Color="{Binding Renk}" CornerRadius="2" />
                                    <Label Text="{Binding Deger}" FontSize="28" FontAttributes="Bold"
                                           TextColor="{Binding Renk}" />
                                    <Label Text="{Binding Baslik}" FontSize="13" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight}, Dark={StaticResource PrimaryTextDark}}" />
                                    <Label Text="{Binding AltMetin}" FontSize="11"
                                           TextColor="{AppThemeBinding Light={StaticResource MutedTextLight}, Dark={StaticResource MutedTextDark}}" LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Son aktivite -->
                <Label Text="Son İşlemler" FontSize="16" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight}, Dark={StaticResource PrimaryTextDark}}" Margin="0,8,0,0" />
                <Border StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundLight}, Dark={StaticResource CardBackgroundDark}}"
                        Padding="4" StrokeShape="RoundRectangle 12">
                    <CollectionView ItemsSource="{Binding SonAktivite}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="svc:DashboardAktivite">
                                <Grid Padding="12,10" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DashboardViewModel}}, Path=AktiviteyeGitCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding Baslik}" FontSize="14" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight}, Dark={StaticResource PrimaryTextDark}}"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding Alt}" FontSize="12"
                                               TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}" LineBreakMode="TailTruncation" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1" Text="{Binding GorunenDurum}" FontSize="11" Style="{StaticResource LblPrimary}"
                                           VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>

                <Label Text="Veriler otomatik güncellenir. Kartlara dokunarak ilgili ekrana gidebilirsiniz."
                       FontSize="11" Style="{StaticResource LblMuted}" HorizontalTextAlignment="Center" Margin="0,8,0,16" />

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
