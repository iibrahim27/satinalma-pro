<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SatinalmaPro.Mobile.Views.StokSayimPage"
             Title="Stok Sayım">

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="12">
            <Picker x:Name="PickerMalzeme" Title="Malzeme seçin" SelectedIndexChanged="Picker_Changed" />
            <Picker x:Name="PickerDepo" Title="Depo/Saha seçin" SelectedIndexChanged="Picker_Changed" />
            <Label x:Name="LblMevcut" Style="{StaticResource LblSecondary}" />
            <Entry x:Name="TxtSayim" Placeholder="Sayım miktarı" Keyboard="Numeric" />
            <Button Text="Sayım Kaydet" Clicked="Kaydet_Clicked" Style="{StaticResource BtnInfoDark}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
