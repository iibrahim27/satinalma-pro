<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:SatinalmaPro.Mobile.Views"
             x:Class="SatinalmaPro.Mobile.Views.OnaylananMalzemelerPage"
             Title="Onaylanan Malzemeler">

    <RefreshView x:Name="RefreshView">
        <Grid RowDefinitions="Auto,*">
            <SearchBar x:Name="TxtArama" Placeholder="Talep no, malzeme veya firma ara"
                       TextChanged="AramaDegisti" Margin="12,8,12,4" />
        <CollectionView x:Name="Liste" Grid.Row="1" SelectionMode="None">
            <CollectionView.EmptyView>
                <Label Text="Onaylanmış malzeme bulunamadı." HorizontalOptions="Center" VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource MutedTextLight}, Dark={StaticResource MutedTextDark}}" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="views:OnaylananMalzemeGorunum">
                    <Border Style="{StaticResource TalepKartBorderStyle}">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding Malzeme}" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource PrimaryTextLight}, Dark={StaticResource PrimaryTextDark}}" />
                            <Label Text="{Binding Firma}" TextColor="{AppThemeBinding Light={StaticResource SecondaryTextLight}, Dark={StaticResource SecondaryTextDark}}" />
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="{Binding TalepNo}" Style="{StaticResource LblMuted}" FontSize="12" />
                                <Label Text="{Binding SiparisNo}" Style="{StaticResource LblInfo}" FontSize="12" />
                            </HorizontalStackLayout>
                            <Label Text="{Binding VadeOzeti}" Style="{StaticResource LblMuted}" FontSize="12" />
                            <Label Text="{Binding KabulDurumu}" Style="{StaticResource LblWarning}" FontSize="12" />
                            <Label Text="{Binding MiktarOzeti}" Style="{StaticResource LblAccent}" FontSize="12" />
                            <Label Text="{Binding FiyatOzeti}" Style="{StaticResource LblSuccess}" FontSize="12" />
                            <HorizontalStackLayout Spacing="6">
                                <Button Text="PDF" Clicked="PdfPaylas_Clicked" CommandParameter="{Binding .}"
                                        Style="{StaticResource BtnSmallInfo}" />
                                <Button Text="Mal Kabul" Clicked="MalKabul_Clicked" CommandParameter="{Binding .}"
                                        Style="{StaticResource BtnSmallInfo}" IsVisible="{Binding IslemYapabilir}" />
                                <Button Text="Tamamla" Clicked="Tamamla_Clicked" CommandParameter="{Binding .}"
                                        BackgroundColor="{StaticResource Purple}" TextColor="{StaticResource OnPrimary}" FontSize="11" CornerRadius="8" Padding="10,6"
                                        IsVisible="{Binding IslemYapabilir}" />
                                <Button Text="Stoka Aktar" Clicked="StogaAktar_Clicked" CommandParameter="{Binding .}"
                                        Style="{StaticResource BtnSmallSuccess}" IsVisible="{Binding IslemYapabilir}" />
                            </HorizontalStackLayout>
                            <Button Text="{Binding TopluKabulMetni}" Clicked="TopluMalKabul_Clicked" CommandParameter="{Binding .}"
                                    BackgroundColor="{StaticResource Purple}" TextColor="{StaticResource OnPrimary}"
                                    FontSize="11" CornerRadius="8" Padding="10,6"
                                    IsVisible="{Binding TopluKabulYapabilir}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        </Grid>
    </RefreshView>
</ContentPage>
